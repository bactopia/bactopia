// main script name
manifest {
    author = 'Robert A. Petit III'
    name = 'bactopia'
    homePage = 'https://github.com/bactopia/bactopia'
    description = 'An extensive workflow for processing sequencing of bacterial genomes.'
    mainScript = 'main.nf'
    version = '4.0.0'
    nextflowVersion = '>=25.04.6'
}

params {
    workflow {
        name = "bactopia"
        logo_name = "bactopia"
        description = "The main end-to-end Bactopia pipeline for bacterial genomes"
    }
}

// Feature Flags
nextflow.enable.strict = true

// Version
params.bactopia_version = '4.0.0'

// Includes
params.bactopia_cache = env("BACTOPIA_CACHEDIR") ? "${env('BACTOPIA_CACHEDIR')}" : "${env('HOME')}/.bactopia"
includeConfig "./conf/params.config"
includeConfig "./conf/params/bactopia.config"

// Module specific params.config
includeConfig "./modules/csvtk/concat/module.config"
includeConfig "./modules/amrfinderplus/run/module.config"
includeConfig "./modules/bakta/download/module.config"
includeConfig "./modules/bakta/run/module.config"
includeConfig "./modules/mlst/module.config"
includeConfig "./modules/mash/dist/module.config"
includeConfig "./modules/agrvate/module.config"
includeConfig "./modules/clermontyping/module.config"
includeConfig "./modules/ectyper/module.config"
includeConfig "./modules/emmtyper/module.config"
includeConfig "./modules/genotyphi/parse/module.config"
includeConfig "./modules/hicap/module.config"
includeConfig "./modules/hpsuissero/module.config"
includeConfig "./modules/kleborate/module.config"
includeConfig "./modules/legsta/module.config"
includeConfig "./modules/lissero/module.config"
includeConfig "./modules/meningotype/module.config"
includeConfig "./modules/ngmaster/module.config"
includeConfig "./modules/pasty/module.config"
includeConfig "./modules/pbptyper/module.config"
includeConfig "./modules/seqsero2/module.config"
includeConfig "./modules/seroba/run/module.config"
includeConfig "./modules/shigapass/module.config"
includeConfig "./modules/shigatyper/module.config"
includeConfig "./modules/shigeifinder/module.config"
includeConfig "./modules/sistr/module.config"
includeConfig "./modules/spatyper/module.config"
includeConfig "./modules/ssuissero/module.config"
includeConfig "./modules/sccmec/module.config"
includeConfig "./modules/stecfinder/module.config"
includeConfig "./modules/tbprofiler/profile/module.config"
includeConfig "./modules/tbprofiler/collate/module.config"
includeConfig "./modules/bactopia/datasets/module.config"
includeConfig "./modules/prokka/module.config"
includeConfig "./modules/bactopia/gather/module.config"
includeConfig "./modules/bactopia/qc/module.config"
includeConfig "./modules/bactopia/assembler/module.config"
includeConfig "./modules/bactopia/sketcher/module.config"

// Set output directory
outputDir = params.outdir
workflow.output.mode = params.publish_dir_mode
workflow.output.overwrite = params.force ? true : 'standard'

// Set up run directory
params.singularity_cache = env("NXF_SINGULARITY_CACHEDIR") ? "${env('NXF_SINGULARITY_CACHEDIR')}" : "${params.singularity_cache}"
params.run_timestamp = new java.util.Date().format('yyyyMMdd-HHmmss')
params.rundir = params.is_ci ? "bactopia-runs/${params.run_name}" : "bactopia-runs/${params.run_name}-${params.run_timestamp}"
params.infodir = "${params.outdir}/${params.rundir}/nf-reports"

// Load nf-core custom profiles from different Institutions
includeConfig !env('NXF_OFFLINE') && params.custom_config_base ? "${params.custom_config_base}/nfcore_custom.config" : "/dev/null"

// Load Bactopia custom profiles from different institutions.
// Uncomment in the event a bactopia specific profile is added
//includeConfig !System.getenv('NXF_OFFLINE') && params.custom_config_base ? "${params.custom_config_base}/pipeline/bactopia.config" : "/dev/null"

// Base Config
includeConfig "./conf/base.config"

// Profiles
includeConfig "./conf/profiles.config"

// Reporting configuration
timeline {
    enabled = true
    overwrite = true
    file = "${params.infodir}/${params.workflow.name}-timeline.html"
}

report {
    enabled = true
    overwrite = true
    file = "${params.infodir}/${params.workflow.name}-report.html"
}

trace {
    enabled = true
    overwrite = true
    file = "${params.infodir}/${params.workflow.name}-trace.txt"
    fields = ['task_id','hash','native_id','process','tag','name','status','exit','module','container','cpus','time','disk','memory','attempt','start','complete','duration','realtime','queue','%cpu','%mem','rss','vmem']
}

dag {
    enabled = true
    overwrite = true
    file = "${params.infodir}/${params.workflow.name}-dag.svg"
}

// Plugins
plugins {
    id 'nf-bactopia@1.0.9'
}

bactopia {
    parametersSchema = "${projectDir}/nextflow_schema.json"
}