/*
This file includes default process values for phyloflash/phyloflash.
*/

process {
    withName: 'PHYLOFLASH' {
        // Optional arguments
        ext.args = ""
        
        // Environment information
        ext.env = [
            toolName: "bioconda::phyloflash=3.4.2".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/phyloflash:3.4.2--hdfd78af_0",
            image: "https://depot.galaxyproject.org/singularity/phyloflash:3.4.2--hdfd78af_0",
            condaDir: "${params.condadir}",
        ]
        
        ext.wf = params.wf
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "phyloflash"

        // WF specific parameters
        ext.allow_multiple_16s = params.allow_multiple_16s
    }
}
