/*
This file includes default process configurations
*/

process {
    withName: 'ROARY' {
        // Optional arguments
        ext.args = {[
            params.use_prank ? "-e" : "-n", // use prank or mafft
            "-i ${params.i}",
            "-cd ${params.cd}",
            "-g ${params.g}",
            params.s ? "-s" : "",
            params.ap ? "-ap" : "",
            "-iv ${params.iv}"
        ].join(' ').trim()}
        
        // Environment information
        ext.conda = "${moduleDir}/environment.yml"
        ext.singularity = 'https://depot.galaxyproject.org/singularity/roary:3.13.0--pl526h516909a_0'
        ext.docker = 'quay.io/biocontainers/roary:3.13.0--pl526h516909a_0'

        // Misc
        ext.prefix = { "${meta.id}" }
        ext.rundir = "${task.process}"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = { "${task.process}".replace(":", "_") }
    }
}
