/*
This file includes default process values for roary.
*/

process {
    withName: 'ROARY' {
        // Optional arguments
        ext.args = [
            params.use_prank ? "-e" : "-n", // use prank or mafft
            "-i ${params.i}",
            "-cd ${params.cd}",
            "-g ${params.g}",
            params.s ? "-s" : "",
            params.ap ? "-ap" : "",
            "-iv ${params.iv}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.env = [
            toolName: "bioconda::roary=3.13.0".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "quay.io/biocontainers/roary:3.13.0--pl526h516909a_0",
            image: "https://depot.galaxyproject.org/singularity/roary:3.13.0--pl526h516909a_0",
            condaDir: "${params.condadir}",
        ]
        
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "roary"
    }
}
