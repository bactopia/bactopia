{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/bactopia/bactopia/master/modules/roary/schema.json",
    "title": "Roary Module",
    "description": "A module for building a pangenome",
    "type": "object",
    "$defs": {
        "roary_parameters": {
            "title": "Roary Parameters",
            "type": "object",
            "description": "",
            "default": "",
            "fa_icon": "fas fa-exclamation-circle",
            "properties": {
                "use_prank": {
                    "type": "boolean",
                    "default": false,
                    "description": "Use PRANK instead of MAFFT for core gene"
                },
                "use_roary": {
                    "type": "boolean",
                    "default": false,
                    "description": "Use Roary instead of PIRATE in the 'pangenome' subworkflow"
                },
                "i": {
                    "type": "integer",
                    "default": 95,
                    "description": "Minimum percentage identity for blastp"
                },
                "cd": {
                    "type": "integer",
                    "default": 99,
                    "description": "Percentage of isolates a gene must be in to be core"
                },
                "g": {
                    "type": "integer",
                    "default": 50000,
                    "description": "Maximum number of clusters"
                },
                "s": {
                    "type": "boolean",
                    "default": false,
                    "description": "Do not split paralogs"
                },
                "ap": {
                    "type": "boolean",
                    "default": false,
                    "description": "Allow paralogs in core alignment"
                },
                "iv": {
                    "type": "number",
                    "default": 1.5,
                    "description": "MCL inflation value"
                }
            }
        }
    },
    "allOf": [
        {
            "$ref": "#/$defs/roary_parameters"
        }
    ]
}
