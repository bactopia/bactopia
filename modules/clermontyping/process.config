/*
This file includes default process values for clermontyping.
*/

process {
    withName: 'CLERMONTYPING' {
        // Optional arguments
        ext.args = params.clermon_threshold > 0 ? "--threshold ${params.clermon_threshold}" : ""

        // Environment information
        ext.env = [
            toolName: "bioconda::clermontyping=24.02".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "quay.io/biocontainers/clermontyping:24.02--py312hdfd78af_1",
            image: "https://depot.galaxyproject.org/singularity/clermontyping:24.02--py312hdfd78af_1",
            condaDir: "${params.condadir}",
        ]

        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "clermontyping"
    }
}
