/*
This file includes default process configurations
*/

process {
    withName: 'QUAST' {
        // Optional arguments
        ext.args = {[
            "--plots-format ${params.plots_format}",
            "--contig-thresholds ${params.contig_thresholds}"
        ].join(' ').trim()}
        
        // Environment information
        ext.conda = "${moduleDir}/environment.yml"
        ext.singularity = 'https://depot.galaxyproject.org/singularity/quast:5.3.0--py39pl5321heaaa4ec_0'
        ext.docker = 'quay.io/biocontainers/quast:5.3.0--py39pl5321heaaa4ec_0'

        // Misc
        ext.prefix = { "${meta.id}" }
        ext.rundir = "${task.process}"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = { "${task.process}".replace(":", "_") }
    }
}
