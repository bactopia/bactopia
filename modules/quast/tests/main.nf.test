nextflow_process {
    name "Test QUAST"
    script "../main.nf"
    process "QUAST"
    tag "modules"
    tag "quast"

    test("quast - module - SRR2838702 - uncompressed") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "SRR2838702"],
                        fna: file("${params.test_data_dir}/datasets/generic/GCF_000292685.fna"),
                        meta_file: file("${params.test_data_dir}/species/portiera/compressed/SRR2838702/main/gather/SRR2838702-meta.tsv")
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.versions
                ).match() }
            )
        }
    }

    test("quast - module - SRR2838702 - compressed") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "SRR2838702"],
                        fna: file("${params.test_data_dir}/species/portiera/compressed/SRR2838702/main/assembler/SRR2838702.fna.gz"),
                        meta_file: file("${params.test_data_dir}/species/portiera/compressed/SRR2838702/main/gather/SRR2838702-meta.tsv")
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.versions
                ).match() }
            )
        }
    }

    test("quast - module - SRR2838702 - no reference") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "SRR2838702"],
                        fna: file("${params.test_data_dir}/datasets/generic/GCF_000292685.fna"),
                        meta_file: file("${params.test_data_dir}/datasets/generic/genome/GCF_000292685-meta-noref.tsv")
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.versions
                ).match() }
            )
        }
    }
}
