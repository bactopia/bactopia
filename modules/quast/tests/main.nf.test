nextflow_process {
    name "Test QUAST"
    script "../main.nf"
    process "QUAST"
    tag "modules"
    tag "quast"

    test("quast - module - GCF_000292685 - uncompressed") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_000292685"],
                        assembly: file("${params.test_data_dir}/data/species/portiera/genome/GCF_000292685.fna"),
                        meta_file: file("${params.test_data_dir}/data/species/portiera/genome/GCF_000292685-meta.tsv")
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.versions
                ).match() }
            )
        }
    }

    test("quast - module - GCF_000292685 - compressed") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_000292685"],
                        assembly: file("${params.test_data_dir}/data/species/portiera/genome/GCF_000292685.fna.gz"),
                        meta_file: file("${params.test_data_dir}/data/species/portiera/genome/GCF_000292685-meta.tsv")
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.versions
                ).match() }
            )
        }
    }
}
