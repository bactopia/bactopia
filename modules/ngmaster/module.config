params {
    // ngmaster
    ngm_csv = false
}

process {
    withName: 'NGMASTER' {
        // Optional arguments
        ext.args = [
            params.ngm_csv ? "--csv" : ""
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.toolName = "bioconda::ngmaster=0.5.8".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/ngmaster:0.5.8--pyhdfd78af_1"
        ext.image = "https://depot.galaxyproject.org/singularity/ngmaster:0.5.8--pyhdfd78af_1"
        ext.condaDir = "${params.condadir}"
        
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "ngmaster"
    }
}
