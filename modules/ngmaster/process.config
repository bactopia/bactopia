process {
    withName: 'NGMASTER' {
        // Optional arguments
        ext.args = {[
            params.csv ? "--csv" : ""
        ].join(' ').trim()}
        
        // Environment information
        ext.conda = "bioconda::ngmaster=0.5.8"
        ext.singularity = "https://depot.galaxyproject.org/singularity/ngmaster:0.5.8--pyhdfd78af_1"
        ext.docker = "quay.io/biocontainers/ngmaster:0.5.8--pyhdfd78af_1"
        
        ext.prefix = { params.prefix ? params.prefix : "${params.wf == 'bactopia' ? meta.id : meta.name}" }
        ext.rundir = "${params.rundir}"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = params.is_workflow ? params.wf : params.process_name
    }
}
