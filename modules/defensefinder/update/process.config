/*
This file includes default process values for defensefinder.
*/

process {
    withName: 'DEFENSEFINDER_UPDATE' {
        // Optional arguments
        ext.args = ""
        
        // Environment information
        ext.env = [
            toolName: "bioconda::defense-finder=2.0.0".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/defense-finder:1.3.0--pyhdfd78af_0",
            image: "https://depot.galaxyproject.org/singularity/defense-finder:1.3.0--pyhdfd78af_0",
            condaDir: "${params.condadir}",
        ]
        
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "defensefinder"
        ext.df_version = "2.0.0"
        ext.df_models_version = "2.0.2"
        ext.casfinder_version = "3.1.0"
    }
}
