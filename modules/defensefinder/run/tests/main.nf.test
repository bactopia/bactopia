nextflow_process {
    name "Test DEFENSEFINDER_RUN"
    script "../main.nf"
    process "DEFENSEFINDER_RUN"
    tag "modules"
    tag "defensefinder"
    tag "defensefinder_run"

    test("defensefinder - module - SRR2838702") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "SRR2838702"],
                        faa: file("${params.test_data_dir}/species/portiera/compressed/SRR2838702/main/assembler/SRR2838702.fna.gz")
                    )
                )
                input[1] = file("${params.test_data_dir}/datasets/defensefinder/defensefinder.tar")
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.genes_tsv,
                    record.hmmer_tsv,
                    record.systems_tsv,
                    record.versions
                ).match() }
            )
        }
    }
}
