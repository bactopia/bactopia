process {
    withName: 'DEFENSEFINDER_RUN' {
        // Optional arguments
        ext.args = {[
            params.df_nocutga ? "--no-cut-ga" : "",
            "--coverage ${params.df_coverage}",
            "--db-type ${params.df_dbtype}"
        ].join(' ').trim()}
        
        // Environment information
        ext.conda = "bioconda::defense-finder=2.0.0"
        ext.singularity = "https://depot.galaxyproject.org/singularity/defense-finder:2.0.0--pyhdfd78af_0"
        ext.docker = "quay.io/biocontainers/defense-finder:2.0.0--pyhdfd78af_0"
        
        ext.prefix = { params.prefix ? params.prefix : "${params.wf == 'bactopia' ? meta.id : meta.name}" }
        ext.rundir = "${params.rundir}"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = params.is_workflow ? params.wf : params.process_name
        ext.df_preserveraw = params.df_preserveraw
        ext.df_version = "2.0.0"
        ext.df_models_version = "2.0.2"
        ext.casfinder_version = "3.1.0"
    }
}
