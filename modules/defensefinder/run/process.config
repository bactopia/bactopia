/*
This file includes default process values for defensefinder.
*/

process {
    withName: 'DEFENSEFINDER_RUN|DEFENSEFINDER_UPDATE' {
        // Optional arguments
        ext.args = [
            params.df_nocutga ? "--no-cut-ga" : "",
            "--coverage ${params.df_coverage}",
            "--db-type ${params.df_dbtype}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.env = [
            toolName: "bioconda::defense-finder=2.0.0".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/defense-finder:2.0.0--pyhdfd78af_0",
            image: "https://depot.galaxyproject.org/singularity/defense-finder:2.0.0--pyhdfd78af_0",
            condaDir: "${params.condadir}",
        ]
        
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "defensefinder"
        ext.df_preserveraw = params.df_preserveraw
        ext.df_version = "2.0.0"
        ext.df_models_version = "2.0.2"
        ext.casfinder_version = "3.1.0"
    }

    withName: 'DEFENSEFINDER_UPDATE' {
        storeDir = params.datasets_cache
        publishDir = params.datasets_cache
    }
}
