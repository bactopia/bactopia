/*
Bactopia Module Configuration

Defines parameter defaults, the container images, resource labels, and other settings
for the process defined in this directory.
*/

params {
    // defense-finder
    df_preserveraw = false
    df_nocutga = false
    df_coverage = 0.4
    df_dbtype = "ordered_replicon"
}

process {
    withName: 'DEFENSEFINDER_RUN|DEFENSEFINDER_UPDATE' {
        // Optional arguments
        ext.args = [
            params.df_preserveraw ? "--preserve-raw" : "",
            params.df_nocutga ? "--no-cut-ga" : "",
            "--coverage ${params.df_coverage}",
            "--db-type ${params.df_dbtype}",
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.toolName = "bioconda::defense-finder=2.0.0".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/defense-finder:2.0.0--pyhdfd78af_0"
        ext.image = "https://depot.galaxyproject.org/singularity/defense-finder:2.0.0--pyhdfd78af_0"
        ext.condaDir = "${params.condadir}"
        
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "defensefinder"

        // WF specific parameters
        ext.df_preserveraw = params.df_preserveraw
        ext.df_version = "2.0.0"
        ext.df_models_version = "2.0.2"
        ext.casfinder_version = "3.1.0"
    }

    withName: 'DEFENSEFINDER_UPDATE' {
        storeDir = params.datasets_cache
        ext.scope = "run"
    }
}
