/*
Bactopia Module Configuration

Defines parameter defaults, the container images, resource labels, and other settings
for the process defined in this directory.
*/

params {
    // defense-finder
    defensefinder_preserveraw = false
    defensefinder_nocutga = false
    defensefinder_coverage = 0.4
    defensefinder_dbtype = "ordered_replicon"
}

process {
    withName: 'DEFENSEFINDER_RUN' {
        // Optional arguments
        ext.args = [
            params.defensefinder_preserveraw ? "--preserve-raw" : "",
            params.defensefinder_nocutga ? "--no-cut-ga" : "",
            "--coverage ${params.defensefinder_coverage}",
            "--db-type ${params.defensefinder_dbtype}",
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::defense-finder=2.0.1".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/defense-finder:2.0.1--pyhdfd78af_0"
        ext.image = "https://depot.galaxyproject.org/singularity/defense-finder:2.0.1--pyhdfd78af_0"
        ext.condaDir = "${params.condadir}"

        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "defensefinder"

        // WF specific parameters
        ext.defensefinder_preserveraw = params.defensefinder_preserveraw
        ext.defensefinder_version = "2.0.0"
        ext.defensefinder_models_version = "2.0.2"
        ext.casfinder_version = "3.1.0"
    }
}
