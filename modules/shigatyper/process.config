/*
This file includes default process values for shigatyper.
*/

process {
    withName: 'SHIGATYPER' {
        // Optional arguments
        ext.args = ""
        
        // Environment information
        ext.env = [
            toolName: "bioconda::shigatyper=2.0.5".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/shigatyper:2.0.5--pyhdfd78af_0",
            image: "https://depot.galaxyproject.org/singularity/shigatyper:2.0.5--pyhdfd78af_0",
            condaDir: "${params.condadir}",
        ]
        
        ext.wf = params.wf
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "shigatyper"
    }
}
