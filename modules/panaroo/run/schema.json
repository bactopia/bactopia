{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/bactopia/bactopia/master/modules/panaroo/run/schema.json",
    "title": "Panaroo Run Module",
    "description": "A module for running Panaroo pangenome analysis",
    "type": "object",
    "$defs": {
        "panaroo_run_parameters": {
            "title": "Panaroo Run Parameters",
            "type": "object",
            "description": "",
            "default": "",
            "fa_icon": "fas fa-exclamation-circle",
            "properties": {
        "panaroo_mode": {
            "type": "string",
            "default": "strict",
            "description": "The stringency mode at which to run panaroo",
            "enum": ["strict", "moderate", "sensitive"]
        },
        "panaroo_alignment": {
            "type": "string",
            "default": "core",
            "description": "Output alignment of core genes or all genes",
            "enum": ["core", "pan"]
        },
        "panaroo_aligner": {
            "type": "string",
            "default": "mafft",
            "description": "Aligner to use for multiple sequence alignment",
            "enum": ["prank", "mafft", "clustal"]
        },
        "panaroo_core_threshold": {
            "type": "number",
            "default": 0.95,
            "description": "Core-genome sample threshold",
            "hidden": true
        },
        "panaroo_threshold": {
            "type": "number",
            "default": 0.98,
            "description": "Sequence identity threshold",
            "hidden": true
        },
        "panaroo_family_threshold": {
            "type": "number",
            "default": 0.7,
            "description": "Minimum family support threshold",
            "hidden": true
        },
        "len_dif_percent": {
            "type": "number",
            "default": 0.98,
            "description": "Length difference cutoff",
            "hidden": true
        },
        "merge_paralogs": {
            "type": "boolean",
            "default": false,
            "description": "Don't split paralogs"
                },
                "panaroo_opts": {
                    "type": "string",
                    "default": "",
                    "description": "Extra Panaroo options"
                }
            }
        }
    },
    "allOf": [
        {
            "$ref": "#/$defs/panaroo_run_parameters"
        }
    ]
}
