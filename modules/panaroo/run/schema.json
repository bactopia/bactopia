{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/bactopia/bactopia/master/modules/panaroo/run/schema.json",
    "title": "Panaroo Run Module",
    "description": "A module for running Panaroo pangenome analysis",
    "type": "object",
    "$defs": {
        "panaroo_run_parameters": {
            "title": "Panaroo Run Parameters",
            "type": "object",
            "description": "",
            "default": "",
            "fa_icon": "fas fa-exclamation-circle",
            "properties": {
                "panaroo_mode": {
                    "type": "string",
                    "default": "strict",
                    "description": "The stringency mode at which to run panaroo",
                    "fa_icon": "fas fa-expand-arrows-alt",
                    "enum": [
                        "strict",
                        "moderate",
                        "sensitive"
                    ],
                    "hidden": true
                },
                "panaroo_alignment": {
                    "type": "string",
                    "default": "core",
                    "description": "Output alignments of core genes or all genes",
                    "fa_icon": "fas fa-expand-arrows-alt",
                    "enum": [
                        "core",
                        "pan"
                    ],
                    "hidden": true
                },
                "panaroo_aligner": {
                    "type": "string",
                    "default": "mafft",
                    "description": "Aligner to use for core/pan genome alignment",
                    "fa_icon": "fas fa-expand-arrows-alt",
                    "enum": [
                        "mafft",
                        "prank",
                        "clustal"
                    ],
                    "hidden": true
                },
                "panaroo_core_threshold": {
                    "type": "number",
                    "default": 0.95,
                    "description": "Core-genome sample threshold",
                    "fa_icon": "fas fa-expand-arrows-alt",
                    "hidden": true
                },
                "panaroo_threshold": {
                    "type": "number",
                    "default": 0.98,
                    "description": "Sequence identity threshold",
                    "fa_icon": "fas fa-expand-arrows-alt",
                    "hidden": true
                },
                "panaroo_family_threshold": {
                    "type": "number",
                    "default": 0.7,
                    "description": "Protein family sequence identity threshold",
                    "fa_icon": "fas fa-expand-arrows-alt",
                    "hidden": true
                },
                "len_dif_percent": {
                    "type": "number",
                    "default": 0.98,
                    "description": "Length difference cutoff",
                    "fa_icon": "fas fa-expand-arrows-alt",
                    "hidden": true
                },
                "merge_paralogs": {
                    "type": "boolean",
                    "default": false,
                    "description": "Do not split paralogs",
                    "fa_icon": "fas fa-expand-arrows-alt"
                },
                "panaroo_opts": {
                    "type": "string",
                    "default": "",
                    "description": "Additional options to pass to panaroo",
                    "fa_icon": "fas fa-expand-arrows-alt"
                }
            }
        }
    },
    "allOf": [
        {
            "$ref": "#/$defs/panaroo_run_parameters"
        }
    ]
}
