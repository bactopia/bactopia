/*
This file includes default process values for panaroo/run.
*/

process {
    withName: 'PANAROO_RUN' {
        // Optional arguments
        ext.args = [
            params.panaroo_merge_paralogs ? "--merge_paralogs" : "",
            "--clean-mode ${params.panaroo_mode}",
            "--threshold ${params.panaroo_threshold}",
            "--family_threshold ${params.panaroo_family_threshold}",
            "--len_dif_percent ${params.panaroo_len_dif_percent}",
            "--alignment ${params.panaroo_alignment}",
            "--aligner ${params.panaroo_aligner}",
            "--core_threshold ${params.panaroo_core_threshold}",
            "${params.panaroo_opts}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::panaroo=1.5.1".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/panaroo:1.5.1--pyhdfd78af_0"
        ext.image = "https://depot.galaxyproject.org/singularity/panaroo:1.5.1--pyhdfd78af_0"
        ext.condaDir = "${params.condadir}"
        
        ext.wf = params.wf
        ext.scope = "run"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "panaroo_run"
    }
}
