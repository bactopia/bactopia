/*
This file includes default process values for panaroo/run.
*/

process {
    withName: 'PANAROO_RUN' {
        // Optional arguments
        ext.args = [
            "--mode ${params.panaroo_mode}",
            "--alignment ${params.panaroo_alignment}",
            "--aligner ${params.panaroo_aligner}",
            "--core_threshold ${params.panaroo_core_threshold}",
            "--threshold ${params.panaroo_threshold}",
            "--family_threshold ${params.panaroo_family_threshold}",
            "--len_dif_percent ${params.len_dif_percent}",
            params.merge_paralogs ? "--merge_paralogs" : "",
            params.panaroo_opts
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.env = [
            toolName: "bioconda::panaroo=1.5.1".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/panaroo:1.5.1--pyhdfd78af_0",
            image: "https://depot.galaxyproject.org/singularity/panaroo:1.5.1--pyhdfd78af_0",
            condaDir: "${params.condadir}",
        ]
        
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "panaroo_run"
    }
}
