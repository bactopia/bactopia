process {
    withName: 'PANAROO_RUN' {
        // Optional arguments
        ext.args = {[
            "--mode ${params.panaroo_mode}",
            "--alignment ${params.panaroo_alignment}",
            "--aligner ${params.panaroo_aligner}",
            "--core_threshold ${params.panaroo_core_threshold}",
            "--threshold ${params.panaroo_threshold}",
            "--family_threshold ${params.panaroo_family_threshold}",
            "--len_dif_percent ${params.len_dif_percent}",
            params.merge_paralogs ? "--merge_paralogs" : "",
            params.panaroo_opts
        ].join(' ').trim()}
        
        // Environment information
        ext.conda = "bioconda::panaroo=1.5.1"
        ext.singularity = "https://depot.galaxyproject.org/singularity/panaroo:1.5.1--pyhdfd78af_0"
        ext.docker = "quay.io/biocontainers/panaroo:1.5.1--pyhdfd78af_0"
        
        ext.prefix = { params.prefix ? params.prefix : "${params.wf == 'bactopia' ? meta.id : meta.name}" }
        ext.rundir = "${params.rundir}"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = params.is_workflow ? params.wf : params.process_name
    }
}
