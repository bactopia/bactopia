params {
    // panaroo_run
    panaroo_aligner = 'mafft'
    panaroo_alignment = 'core'
    panaroo_core_threshold = 0.95
    panaroo_family_threshold = 0.7
    panaroo_len_dif_percent = 0.98
    panaroo_merge_paralogs = false
    panaroo_mode = 'strict'
    panaroo_opts = ''
    panaroo_threshold = 0.98
}

process {
    withName: 'PANAROO_RUN' {
        ext.wf = params.wf
        ext.scope = "run"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "panaroo_run"

        // Tool arguments
        ext.args = [
            params.panaroo_merge_paralogs ? "--merge_paralogs" : "",
            "--clean-mode ${params.panaroo_mode}",
            "--threshold ${params.panaroo_threshold}",
            "--family_threshold ${params.panaroo_family_threshold}",
            "--len_dif_percent ${params.panaroo_len_dif_percent}",
            "--alignment ${params.panaroo_alignment}",
            "--aligner ${params.panaroo_aligner}",
            "--core_threshold ${params.panaroo_core_threshold}",
            "${params.panaroo_opts}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::panaroo=1.6.0".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/panaroo:1.6.0--pyhdfd78af_0"
        ext.image = "https://depot.galaxyproject.org/singularity/panaroo:1.6.0--pyhdfd78af_0"
        ext.condaDir = "${params.condadir}"
    }
}
