params {
    // No parameters
}

process {
    withName: 'RGI_HEATMAP' {
        ext.wf = params.wf
        ext.scope = "run"
        ext.subdir = ""
        ext.logs_subdir = "rgi-heatmap"
        ext.process_name = "rgi_heatmap"

        // Tool arguments
        ext.args = [
            params.rgi_frequency ? "--frequency" : "",
            params.rgi_category ? "--category ${params.rgi_category}" : "",
            params.rgi_cluster ? "--cluster ${params.rgi_cluster}" : "",
            "--display ${params.rgi_display}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::rgi=6.0.5".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/rgi:6.0.5--pyh05cac1d_0"
        ext.image = "https://depot.galaxyproject.org/singularity/rgi:6.0.5--pyh05cac1d_0"
        ext.condaDir = "${params.condadir}"
    }
}
