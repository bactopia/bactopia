/*
This file includes default process configurations
*/

process {
    withName: 'RGI_HEATMAP' {
        // Optional arguments
        
        // Environment information
        ext.conda = "${moduleDir}/environment.yml"
        ext.singularity = 'https://depot.galaxyproject.org/singularity/rgi:6.0.3--pyha8f3691_0'
        ext.docker = 'quay.io/biocontainers/rgi:6.0.3--pyha8f3691_0'

        // Misc
        ext.prefix = { "${meta.id}" }
        ext.rundir = "${task.process}"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = { "${task.process}".replace(":", "_") }
    }
}
