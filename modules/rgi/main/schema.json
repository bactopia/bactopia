{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/bactopia/bactopia/master/modules/rgi/main/schema.json",
    "title": "RGI Main Module",
    "description": "A module to run RGI (Resistance Gene Identifier) main analysis",
    "type": "object",
    "$defs": {
        "rgi_main_parameters": {
            "title": "RGI Main Parameters",
            "type": "object",
            "description": "",
            "default": "",
            "fa_icon": "fas fa-exclamation-circle",
            "properties": {
                "use_diamond": {
                    "type": "boolean",
                    "default": false,
                    "description": "Use DIAMOND alignment tool instead of BLAST"
                },
                "include_loose": {
                    "type": "boolean",
                    "default": false,
                    "description": "Include loose hits in addition to strict hits"
                },
                "exclude_nudge": {
                    "type": "boolean",
                    "default": false,
                    "description": "Exclude nudged hits from results"
                },
                "rgi_category": {
                    "type": "string",
                    "default": "",
                    "description": "Specify a category"
                },
                "rgi_frequency": {
                    "type": "boolean",
                    "default": false,
                    "description": "Include frequency data"
                },
                "rgi_cluster": {
                    "type": "string",
                    "default": "",
                    "description": "Clustering option"
                },
                "rgi_display": {
                    "type": "string",
                    "default": "plain",
                    "description": "Display format for results"
                }
            }
        }
    },
    "allOf": [
        {
            "$ref": "#/$defs/rgi_main_parameters"
        }
    ]
}
