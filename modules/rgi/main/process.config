/*
This file includes default process configurations
*/

process {
    withName: 'RGI_MAIN' {
        // Optional arguments
        ext.args = {[
            params.use_diamond ? "--alignment_tool DIAMOND" : "",
            params.include_loose ? "--include_loose" : "",
            params.exclude_nudge ? "--exclude_nudge" : "",
            params.rgi_category ? "--category ${params.rgi_category}" : "",
            params.rgi_frequency ? "--include_frequency" : "",
            params.rgi_cluster ? "--cluster ${params.rgi_cluster}" : "",
            "--display ${params.rgi_display}"
        ].join(' ').trim()}
        
        // Environment information
        ext.conda = "${moduleDir}/environment.yml"
        ext.singularity = 'https://depot.galaxyproject.org/singularity/rgi:6.0.3--pyha8f3691_0'
        ext.docker = 'quay.io/biocontainers/rgi:6.0.3--pyha8f3691_0'

        // Misc
        ext.prefix = { "${meta.id}" }
        ext.rundir = "${task.process}"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = { "${task.process}".replace(":", "_") }
    }
}
