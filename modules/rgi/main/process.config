/*
This file includes default process values for rgi/main.
*/

process {
    withName: 'RGI_MAIN' {
        // Optional arguments
        ext.args = [
            params.use_diamond ? "--alignment_tool DIAMOND" : "--alignment_tool BLAST",
            params.include_loose ? "--include_loose" : "",
            params.exclude_nudge ? "--exclude_nudge" : ""
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.env = [
            toolName: "bioconda::rgi=6.0.3".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/rgi:6.0.3--pyha8f3691_0",
            image: "https://depot.galaxyproject.org/singularity/rgi:6.0.3--pyha8f3691_0",
            condaDir: "${params.condadir}",
        ]
        
        ext.wf = params.wf
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "rgi_main"
    }
}
