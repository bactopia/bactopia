nextflow_process {
    name "Test MIDAS_SPECIES"
    script "../main.nf"
    process "MIDAS_SPECIES"
    tag "modules"
    tag "midas"
    tag "midas_species"

    test("midas - module - SRR2838702") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "SRR2838702"],
                        r1: file("${params.test_data_dir}/data/species/portiera/illumina/SRR2838702_R1.fastq.gz"),
                        r2: file("${params.test_data_dir}/data/species/portiera/illumina/SRR2838702_R2.fastq.gz"),
                        se: file("${params.test_data_dir}/data/empty/EMPTY.fastq.gz"),
                        lr: file("${params.test_data_dir}/data/empty/EMPTY.fastq.gz")
                    )
                )
                input[1] = file("${params.test_data_dir}/data/datasets/midas/midas")
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.abundances,
                    record.versions
                ).match() }
            )
        }
    }
}
