{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "species": {
            "type": ["string", "null"],
            "default": null,
            "description": "Species to download"
        },
        "accession": {
            "type": ["string", "null"],
            "default": null,
            "description": "Accession to download"
        },
        "accessions": {
            "type": ["string", "null"],
            "default": null,
            "description": "File with accessions to download"
        },
        "limit": {
            "type": ["integer", "null"],
            "default": null,
            "description": "Limit number of downloads"
        },
        "format": {
            "type": "string",
            "default": "fasta",
            "description": "Format to download",
            "hidden": true
        },
        "section": {
            "type": "string",
            "default": "refseq",
            "description": "NCBI section to download from",
            "hidden": true
        },
        "assembly_level": {
            "type": "string",
            "default": "complete",
            "description": "Assembly level",
            "hidden": true
        },
        "kingdom": {
            "type": "string",
            "default": "bacteria",
            "description": "Kingdom to download",
            "hidden": true
        },
        "keep_downloads": {
            "type": "boolean",
            "default": false,
            "description": "Keep downloaded files"
        },
        "max_retry": {
            "type": "integer",
            "default": 10,
            "description": "Maximum download retries",
            "hidden": true
        }
    }
}
