nextflow_process {
    name "Test NCBIGENOMEDOWNLOAD"
    script "../main.nf"
    process "NCBIGENOMEDOWNLOAD"

    // This test requires internet access to download from NCBI FTP servers.
    // It should only be run in environments with network connectivity.

    test("ncbigenomedownload - module - single accession") {
        tag "ncbigenomedownload"
        tag "internet"

        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
                // Use a small genome for fast testing
                accession = "GCF_000006945.2"
            }
            process {
                """
                // Create an accessions file with a single entry
                def accessions_file = file("\${workDir}/accessions.txt")
                accessions_file.text = "GCF_000006945.2\\n"

                input[0] = accessions_file
                """
            }
        }

        then {
            // TODO: Validate specific output files once test is run with internet
            assertAll(
                { assert process.success },
                { assert process.out[0][0].meta.id == "ncbigenomedownload" }
            )
        }
    }
}
