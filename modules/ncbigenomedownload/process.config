/*
This file includes default process values for ncbigenomedownload.
*/

process {
    withName: 'NCBIGENOMEDOWNLOAD' {
        // Optional arguments
        ext.args = [
            params.kingdom,
            "--section ${params.section}",
            "--formats ${params.format}",
            "--assembly-levels ${params.assembly_level}",
            "--verbose",
            params.enable_conda ? "" : "--no-cache" 
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.env = [
            toolName: "bioconda::ncbi-genome-download=0.3.3".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/ncbi-genome-download:0.3.3--pyh7cba7a3_0",
            image: "https://depot.galaxyproject.org/singularity/ncbi-genome-download:0.3.3--pyh7cba7a3_0",
            condaDir: "${params.condadir}",
        ]
        
        ext.wf = params.wf
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "ncbigenomedownload"

        // Additional arguments
        ext.max_retry = params.max_retry
        ext.meta = [
            id: "ncbigenomedownload",
            limit: params.limit,
            accession: params.accession,
            species: params.species
        ]
    }
}
