/*
This file includes default process values for ncbigenomedownload.
*/

process {
    withName: 'NCBIGENOMEDOWNLOAD' {
        // Optional arguments
        ext.args = [
            "--format ${params.format}",
            "--section ${params.section}",
            "--assembly-level ${params.assembly_level}",
            "--kingdom ${params.kingdom}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.env = [
            toolName: "bioconda::ncbi-genome-download=0.3.3".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/ncbi-genome-download:0.3.3--pyh7cba7a3_0",
            image: "https://depot.galaxyproject.org/singularity/ncbi-genome-download:0.3.3--pyh7cba7a3_0",
            condaDir: "${params.condadir}",
        ]
        
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "ncbigenomedownload"
    }
}
