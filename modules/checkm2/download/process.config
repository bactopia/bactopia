/*
This file includes default process values for checkm2 download.
*/

process {
    withName: 'CHECKM2_DOWNLOAD' {
        // Customize the publish directory
        publishDir = [
            path: params.checkm2_db,
            mode: params.publish_dir_mode,
            overwrite: true
        ]

        // Optional arguments
        ext.args = ""

        // Environment information
        ext.env = [
            toolName: "conda-forge::aria2=1.36.0".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/aria2:1.36.0",
            image: "https://depot.galaxyproject.org/singularity/aria2:1.36.0",
            condaDir: "${params.condadir}",
        ]

        ext.wf = params.wf
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "checkm2_download"
    }
}
