params {
    // checkm2_download
    checkm2_db = null
    download_checkm2 = false
}

process {
    withName: 'CHECKM2_DOWNLOAD' {
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "checkm2_download"
        publishDir = [[
            path: params.checkm2_db,
            mode: params.publish_dir_mode,
            overwrite: true
        ]]

        // Tool arguments
        ext.args = ""

        // Environment information
        ext.toolName = "conda-forge::aria2=1.36.0".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/aria2:1.36.0"
        ext.image = "https://depot.galaxyproject.org/singularity/aria2:1.36.0"
        ext.condaDir = "${params.condadir}"
    }
}
