/*
This file includes default process values for checkm2 predict.
*/

process {
    withName: 'CHECKM2_PREDICT' {
        // Optional arguments
        ext.args = [
            params.checkm2_general ? "--general" : "",
            params.checkm2_specific ? "--specific" : "",
            params.checkm2_allmodels ? "--allmodels" : "",
            params.checkm2_genes ? "--genes" : "",
            "${params.checkm2_opts}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.env = [
            toolName: "bioconda::checkm2=1.0.2".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/checkm2:1.0.2--pyh7cba7a3_0",
            image: "https://depot.galaxyproject.org/singularity/checkm2:1.0.2--pyh7cba7a3_0",
            condaDir: "${params.condadir}",
        ]

        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "checkm2"
    }
}
