/*
Bactopia Module Configuration

Defines parameter defaults, the container images, resource labels, and other settings
for the process defined in this directory.
*/

params {
    // CheckM2
    checkm2_lowmem = null
    checkm2_general = null
    checkm2_specific = null
    checkm2_allmodels = null
    checkm2_genes = null
    checkm2_opts = ""
}

process {
    withName: 'CHECKM2_PREDICT' {
        // Optional arguments
        ext.args = [
            params.checkm2_general ? "--general" : "",
            params.checkm2_specific ? "--specific" : "",
            params.checkm2_allmodels ? "--allmodels" : "",
            params.checkm2_genes ? "--genes" : "",
            "${params.checkm2_opts}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::checkm2=1.0.2".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/checkm2:1.0.2--pyh7cba7a3_0"
        ext.image = "https://depot.galaxyproject.org/singularity/checkm2:1.0.2--pyh7cba7a3_0"
        ext.condaDir = "${params.condadir}"

        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "checkm2"
    }
}
