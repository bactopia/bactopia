params {
    // nohuman_run
    nohuman_confidence = 0.0
    nohuman_human = false
    nohuman_save_report = false
}

process {
    withName: 'NOHUMAN_RUN' {
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "nohuman"

        // Tool arguments
        ext.args = [
            params.nohuman_confidence > 0 ? "--conf ${params.nohuman_confidence}" : "",
            params.nohuman_human ? "--human" : ""
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::bactopia-teton=1.1.4".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/bactopia-teton:1.1.4--hdfd78af_0"
        ext.image = "https://depot.galaxyproject.org/singularity/bactopia-teton:1.1.4--hdfd78af_0"
        ext.condaDir = "${params.condadir}"

        // Module-specific parameters
        ext.nohuman_save_report = params.nohuman_save_report
    }
}
