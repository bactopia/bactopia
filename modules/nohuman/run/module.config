/*
Bactopia Module Configuration

Defines parameter defaults, the container images, resource labels, and other settings
for the process defined in this directory.
*/

params {
    // Nohuman Run
    nohuman_confidence = 0.0
    nohuman_human = false
    nohuman_save_report = false
}

process {
    withName: 'NOHUMAN_RUN' {
        // Optional arguments
        ext.args = [
            params.nohuman_confidence > 0 ? "--conf ${params.nohuman_confidence}" : "",
            params.nohuman_human ? "--human" : ""
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::bactopia-teton=1.1.2".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/bactopia-teton:1.1.2--hdfd78af_0"
        ext.image = "https://depot.galaxyproject.org/singularity/bactopia-teton:1.1.2--hdfd78af_0"
        ext.condaDir = "${params.condadir}"

        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "nohuman"

        // Custom params in the module
        ext.nohuman_save_report = params.nohuman_save_report
    }
}
