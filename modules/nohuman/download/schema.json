{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/bactopia/bactopia/master/modules/nohuman/download/schema.json",
    "title": "Nohuman Download Module",
    "description": "A module for downloading the nohuman database for human read removal",
    "type": "object",
    "$defs": {
        "nohuman_download_parameters": {
            "title": "Nohuman Download Parameters",
            "type": "object",
            "description": "",
            "default": "",
            "fa_icon": "fas fa-exclamation-circle",
            "properties": {
                "nohuman_db": {
                    "type": "string",
                    "description": "Path to the nohuman database or directory to download it to",
                    "fa_icon": "fas fa-file-alt",
                    "is_required": true
                },
                "nohuman_db_version": {
                    "type": "string",
                    "default": "",
                    "description": "Database version to download (default: latest HPRC release)",
                    "fa_icon": "fas fa-expand-arrows-alt"
                },
                "nohuman_save_as_tarball": {
                    "type": "boolean",
                    "description": "Save the nohuman database as a tarball",
                    "default": false,
                    "fa_icon": "fas fa-file-alt"
                },
                "download_nohuman": {
                    "type": "boolean",
                    "description": "Download the nohuman database to the path given by --nohuman_db",
                    "default": false,
                    "fa_icon": "fas fa-italic"
                }
            }
        }
    },
    "allOf": [
        {
            "$ref": "#/$defs/nohuman_download_parameters"
        }
    ]
}
