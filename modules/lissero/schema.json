{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/bactopia/bactopia/master/modules/lissero/schema.json",
    "title": "LisSero Module",
    "description": "A module for serogroup typing prediction for Listeria monocytogenes",
    "type": "object",
    "$defs": {
        "lissero_parameters": {
            "title": "LisSero Parameters",
            "type": "object",
            "description": "",
            "default": "",
            "fa_icon": "fas fa-exclamation-circle",
            "properties": {
                "lissero_min_id": {
                    "type": "number",
                    "default": 95.0,
                    "description": "Minimum percent identity to accept a match",
                    "fa_icon": "fas fa-percentage"
                },
                "lissero_min_cov": {
                    "type": "number",
                    "default": 95.0,
                    "description": "Minimum coverage of the gene to accept a match",
                    "fa_icon": "fas fa-percentage"
                }
            }
        }
    },
    "allOf": [
        {
            "$ref": "#/$defs/lissero_parameters"
        }
    ]
}
