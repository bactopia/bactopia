/*
This file includes default process values for phispy.
*/

process {
    withName: 'PHISPY' {
        // Optional arguments
        ext.args = [
            "--number ${params.phispy_number}",
            "--mincontigsize ${params.phispy_mincontigsize}",
            "--windowsize ${params.phispy_windowsize}",
            "--nonprophage_genegaps ${params.phispy_nonprophage_genegaps}",
            "--phage_genes ${params.phispy_phage_genes}",
            "--randomforest_trees ${params.phispy_randomforest_trees}",
            params.phispy_opts
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.env = [
            toolName: "bioconda::phispy=4.2.21".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/phispy:4.2.21--py310h0dbaff4_2",
            image: "https://depot.galaxyproject.org/singularity/phispy:4.2.21--py310h0dbaff4_2",
            condaDir: "${params.condadir}",
        ]
        
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "phispy"
    }
}
