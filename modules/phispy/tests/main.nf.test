nextflow_process {
    name "Test PHISPY"
    script "../main.nf"
    process "PHISPY"
    tag "modules"
    tag "phispy"

    test("phispy - module - GCF_900478275") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_900478275"],
                        gbff: file("${params.test_data_dir}/species/haemophilus_influenzae/compressed/GCF_900478275/main/annotator/prokka/GCF_900478275.gbk.gz")
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.versions
                ).match() }
            )
        }
    }
}
