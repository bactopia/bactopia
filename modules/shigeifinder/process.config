/*
This file includes default process configurations
*/

process {
    withName: 'SHIGEIFINDER' {
        // Optional arguments
        
        // Environment information
        ext.conda = "${moduleDir}/environment.yml"
        ext.singularity = 'https://depot.galaxyproject.org/singularity/shigeifinder:1.3.5--pyhdfd78af_0'
        ext.docker = 'quay.io/biocontainers/shigeifinder:1.3.5--pyhdfd78af_0'

        // Misc
        ext.prefix = { "${meta.id}" }
        ext.rundir = "${task.process}"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = { "${task.process}".replace(":", "_") }
    }
}
