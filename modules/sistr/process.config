/*
This file includes default process values for sistr.
*/

process {
    withName: 'SISTR' {
        // Optional arguments
        ext.args = [
            params.full_cgmlst ? "--use-full-cgmlst-db" : ""
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.env = [
            toolName: "bioconda::sistr_cmd=1.1.3".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "quay.io/biocontainers/sistr_cmd:1.1.3--pyhdc42f0e_0",
            image: "https://depot.galaxyproject.org/singularity/sistr_cmd:1.1.3-pyhdc42f0e_0",
            condaDir: "${params.condadir}",
        ]
        
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "sistr"
    }
}
