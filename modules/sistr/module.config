/*
Bactopia Module Configuration

Defines parameter defaults, the container images, resource labels, and other settings
for the process defined in this directory.
*/

params {
    // SISTR
    sistr_full_cgmlst = false
}

process {
    withName: 'SISTR' {
        // Optional arguments
        ext.args = [
            params.sistr_full_cgmlst ? "--use-full-cgmlst-db" : ""
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.toolName = "bioconda::sistr_cmd=1.1.3".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/sistr_cmd:1.1.3--pyhdc42f0e_0"
        ext.image = "https://depot.galaxyproject.org/singularity/sistr_cmd:1.1.3-pyhdc42f0e_0"
        ext.condaDir = "${params.condadir}"
        
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "sistr"
    }
}
