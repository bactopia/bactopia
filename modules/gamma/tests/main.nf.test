nextflow_process {
    name "Test GAMMA"
    script "../main.nf"
    process "GAMMA"
    tag "modules"
    tag "gamma"

    test("gamma - module - SRR2838702 - uncompressed") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        meta: [name: "SRR2838702"],
                        fna: file("${params.test_data_dir}/datasets/generic/GCF_000292685.fna")
                    )
                )
                input[1] = file("${params.test_data_dir}/datasets/blast/primers/GCF_000292685.ffn")
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.gamma,
                    record.psl,
                    record.versions
                ).match() }
            )
        }
    }

    test("gamma - module - SRR2838702 - compressed") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        meta: [name: "SRR2838702"],
                        fna: file("${params.test_data_dir}/species/portiera/compressed/SRR2838702/main/assembler/SRR2838702.fna.gz")
                    )
                )
                input[1] = file("${params.test_data_dir}/datasets/blast/primers/GCF_000292685.ffn")
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.gamma,
                    record.psl,
                    record.versions
                ).match() }
            )
        }
    }
}
