/*
This file includes default process values for gamma.
*/

process {
    withName: 'GAMMA' {
        // Optional arguments
        ext.args = [
            params.write_fasta ? "--fasta" : "",
            params.write_fasta ? "--gff" : "",
            params.extended ? "--extended" : "",
            params.all_matches ? "--all" : "",
            "--percent_identity ${params.percent_identity}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.env = [
            toolName: "bioconda::gamma=2.2".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/gamma:2.2--hdfd78af_0",
            image: "https://depot.galaxyproject.org/singularity/gamma:2.2--hdfd78af_0",
            condaDir: "${params.condadir}",
        ]

        ext.wf = params.wf
        ext.rundir = params.rundir
        ext.subdir = params.run_name
        ext.logs_subdir = ""
        ext.process_name = "gamma"
    }

    withName: 'CSVTK_CONCAT' {
        ext.logs_subdir = "gamma-concat"
        ext.prefix = "gamma"
        ext.process_name = params.merge_folder
        ext.subdir = params.run_name
    }
}
