nextflow_process {
    name "Test SRAHUMANSCRUBBER_SCRUB"
    script "../main.nf"
    process "SRAHUMANSCRUBBER_SCRUB"
    tag "modules"
    tag "srahumanscrubber"
    tag "srahumanscrubber_scrub"

    test("srahumanscrubber - module - SRR2838702 - PE") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "SRR2838702", runtype: "paired-end"],
                        r1: file("${params.test_data_dir}/data/species/portiera/illumina/SRR2838702_R1.fastq.gz"),
                        r2: file("${params.test_data_dir}/data/species/portiera/illumina/SRR2838702_R2.fastq.gz"),
                        se: null,
                        lr: null
                    )
                )
                input[1] = file("${params.test_data_dir}/data/datasets/srahumanscrubber/20250916v2.human_filter.db")
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.scrub_report,
                    record.versions
                ).match() }
            )
        }
    }

    test("srahumanscrubber - module - SRR2838702 - SE") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "SRR2838702", runtype: "single-end"],
                        r1: null,
                        r2: null,
                        se: file("${params.test_data_dir}/data/species/portiera/illumina/SRR2838702SE.fastq.gz"),
                        lr: null
                    )
                )
                input[1] = file("${params.test_data_dir}/data/datasets/srahumanscrubber/20250916v2.human_filter.db")
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.scrub_report,
                    record.versions
                ).match() }
            )
        }
    }
}
