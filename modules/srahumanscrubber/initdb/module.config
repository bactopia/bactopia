/*
Bactopia Module Configuration

Defines parameter defaults, the container images, resource labels, and other settings
for the process defined in this directory.
*/

params {
    // No parameters for this module
}

process {
    withName: 'SRAHUMANSCRUBBER_INITDB' {
        storeDir = params.datasets_cache

        // Optional arguments
        ext.args = ""

        // Environment information
        ext.toolName = "bioconda::sra-human-scrubber=2.2.1".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/sra-human-scrubber:2.2.1--hdfd78af_0"
        ext.image = "https://depot.galaxyproject.org/singularity/sra-human-scrubber:2.2.1--hdfd78af_0"
        ext.condaDir = "${params.condadir}"

        // Additional parameters
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "sra-human-scrubber"
    }
}
