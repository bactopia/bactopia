/*
This file includes default values for the process-specific parameters.
*/

process {
    withName: 'SRAHUMANSCRUBBER_INITDB' {
        // Optional arguments
        ext.args = ""

        // Environment information
        ext.env = [
            toolName: "bioconda::sra-human-scrubber=2.2.1".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/sra-human-scrubber:2.2.1--hdfd78af_0",
            image: "https://depot.galaxyproject.org/singularity/sra-human-scrubber:2.2.1--hdfd78af_0",
            condaDir: "${params.condadir}",
        ]

        // Additional parameters
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "sra-human-scrubber-initdb"
    }
}
