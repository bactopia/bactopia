/*
This file includes default process values for bakta download.
*/

process {
    withName: 'BAKTA_DOWNLOAD' {
        // Optional arguments
        ext.args = ""

        // Environment information
        ext.env = [
            toolName: "bioconda::bakta=1.11.0".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/bakta:1.11.0--pyhdfd78af_0",
            image: "https://depot.galaxyproject.org/singularity/bakta:1.11.0--pyhdfd78af_0",
            condaDir: "${params.condadir}",
        ]

        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "bakta_download"
    }
}
