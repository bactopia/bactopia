/*
This file includes default process values for bakta run.
*/

process {
    withName: 'BAKTA_RUN' {
        // Optional arguments
        ext.args = [
            params.skip_trna ? "--skip-trna" : "",
            params.skip_tmrna ? "--skip-tmrna" : "",
            params.skip_rrna ? "--skip-rrna" : "",
            params.skip_ncrna ? "--skip-ncrna" : "",
            params.skip_ncrna_region ? "--skip-ncrna-region" : "",
            params.skip_crispr ? "--skip-crispr" : "",
            params.skip_cds ? "--skip-cds" : "",
            params.skip_sorf ? "--skip-sorf" : "",
            params.skip_gap ? "--skip-gap" : "",
            params.skip_ori ? "--skip-ori" : "",
            params.compliant ? "--compliant" : "",
            params.keep_contig_headers ? "--keep-contig-headers" : "",
            "--min-contig-length ${params.min_contig_length}",
            "${params.bakta_opts}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.env = [
            toolName: "bioconda::bakta=1.11.4".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/bakta:1.11.4--pyhdfd78af_0",
            image: "https://depot.galaxyproject.org/singularity/bakta:1.11.4--pyhdfd78af_0",
            condaDir: "${params.condadir}",
        ]

        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "bakta"
        ext.skip_compression = params.skip_compression
    }
}
