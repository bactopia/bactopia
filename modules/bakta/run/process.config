/*
This file includes default process values for bakta run.
*/

process {
    withName: 'BAKTA_RUN' {
        // Optional arguments
        ext.args = [
            params.min_contig_length > 1 ? "--min-contig-length ${params.min_contig_length}" : "",
            params.compliant ? "--compliant" : "",
            params.complete ? "--complete" : "",
            params.genus ? "--genus ${params.genus}" : "",
            params.species ? "--species ${params.species}" : "",
            params.strain ? "--strain ${params.strain}" : "",
            params.plasmid ? "--plasmid ${params.plasmid}" : "",
            params.gram ? "--gram ${params.gram}" : "",
            params.prodigal_translation_table ? "--translation-table ${params.prodigal_translation_table}" : "",
            params.keep_contig_headers ? "--keep-contig-headers" : "",
            params.skip_amr ? "--skip-amr" : "",
            params.skip_crispr ? "--skip-crispr" : "",
            params.skip_cds ? "--skip-cds" : "",
            params.skip_trna ? "--skip-trna" : "",
            params.skip_rrna ? "--skip-rrna" : "",
            params.skip_ncrna ? "--skip-ncrna" : "",
            params.skip_ncrna_region ? "--skip-ncrna-region" : "",
            params.skip_gap ? "--skip-gap" : "",
            params.skip_ori ? "--skip-ori" : "",
            params.skip_plot ? "--skip-plot" : "",
            params.skip_sorf ? "--skip-sorf" : ""
        ].join(' ')

        // Environment information
        ext.env = [
            toolName: "bioconda::bakta=1.11.0".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "quay.io/biocontainers/bakta:1.11.0--pyhdfd78af_0",
            image: "https://depot.galaxyproject.org/singularity/bakta:1.11.0--pyhdfd78af_0",
            condaDir: "${params.condadir}",
        ]

        ext.cpus = { Math.floor(task.cpus * 0.75) >= 1 ? Math.floor(task.cpus * 0.75) : 1 }
        ext.prefix = { "bakta" }
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "bakta"
    }
}
