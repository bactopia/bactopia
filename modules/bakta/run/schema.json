{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Bakta Run Module",
    "type": "object",
    "properties": {
        "min_contig_length": {
            "type": "integer",
            "description": "Minimum contig size (--min-contig-length)",
            "default": 1
        },
        "skip_compression": {
            "type": "boolean",
            "description": "Skip gzip compression of output files",
            "default": false
        },
        "compliant": {
            "type": "boolean",
            "description": "Force Genbank/ENA/DDJB compliance (--compliant)",
            "default": false
        },
        "complete": {
            "type": "boolean",
            "description": "All sequences are complete replicons (--complete)",
            "default": false
        },
        "prodigal_tf": {
            "type": "string",
            "description": "Training file to use for CDS prediction (--prodigal-tf)",
            "default": ""
        },
        "prodigal_translation_table": {
            "type": "integer",
            "description": "Translation table to use for CDS prediction (--translation-table)",
            "default": 11
        },
        "proteins": {
            "type": "string",
            "description": "FASTA file of trusted proteins to use for annotation (--proteins)",
            "default": ""
        },
        "genus": {
            "type": "string",
            "description": "Genus name (--genus)",
            "default": ""
        },
        "species": {
            "type": "string",
            "description": "Species name (--species)",
            "default": ""
        },
        "strain": {
            "type": "string",
            "description": "Strain name (--strain)",
            "default": ""
        },
        "plasmid": {
            "type": "string",
            "description": "Plasmid name (--plasmid)",
            "default": ""
        },
        "gram": {
            "type": "string",
            "description": "Gram type: [+, -] (--gram)",
            "default": ""
        },
        "replicons": {
            "type": "string",
            "description": "Replicon table (--replicons)",
            "default": ""
        },
        "skip_amr": {
            "type": "boolean",
            "description": "Skip AMR detection (--skip-amr)",
            "default": false
        },
        "skip_crispr": {
            "type": "boolean",
            "description": "Skip CRISPRs detection (--skip-crispr)",
            "default": false
        },
        "skip_cds": {
            "type": "boolean",
            "description": "Skip CDS detection (--skip-cds)",
            "default": false
        },
        "skip_trna": {
            "type": "boolean",
            "description": "Skip tRNA detection (--skip-trna)",
            "default": false
        },
        "skip_rrna": {
            "type": "boolean",
            "description": "Skip rRNA detection (--skip-rrna)",
            "default": false
        },
        "skip_ncrna": {
            "type": "boolean",
            "description": "Skip ncRNA detection (--skip-ncrna)",
            "default": false
        },
        "skip_ncrna_region": {
            "type": "boolean",
            "description": "Skip ncRNA region detection (--skip-ncrna-region)",
            "default": false
        },
        "skip_gap": {
            "type": "boolean",
            "description": "Skip gap detection (--skip-gap)",
            "default": false
        },
        "skip_ori": {
            "type": "boolean",
            "description": "Skip oriC/oriV detection (--skip-ori)",
            "default": false
        },
        "skip_plot": {
            "type": "boolean",
            "description": "Skip plot generation (--skip-plot)",
            "default": false
        },
        "skip_sorf": {
            "type": "boolean",
            "description": "Skip sORF detection (--skip-sorf)",
            "default": false
        },
        "use_bakta": {
            "type": "boolean",
            "description": "Use Bakta for annotation",
            "default": false
        }
    }
}
