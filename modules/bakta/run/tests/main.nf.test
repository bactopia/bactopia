nextflow_process {
    name "Test BAKTA_RUN"
    script "../main.nf"
    process "BAKTA_RUN"
    tag "modules"
    tag "bakta"
    tag "bakta_run"

    test("bakta - module - SRR2838702 - tarball (light)") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        meta: [name: "SRR2838702"],
                        fna: file("${params.test_data_dir}/species/portiera/compressed/SRR2838702/main/assembler/SRR2838702.fna.gz")
                    )
                )
                input[1] = file("${params.test_data_dir}/datasets/bakta/light/bakta-light.tar.gz")
                input[2] = file("${params.test_data_dir}/empty/EMPTY_PROTEINS")
                input[3] = file("${params.test_data_dir}/empty/EMPTY_PRODIGAL_TF")
                input[4] = file("${params.test_data_dir}/empty/EMPTY_REPLICONS")
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.txt,
                    record.versions
                ).match() }
            )
        }
    }

    test("bakta - module - SRR2838702 - path (full)") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        meta: [name: "SRR2838702"],
                        fna: file("${params.test_data_dir}/species/portiera/compressed/SRR2838702/main/assembler/SRR2838702.fna.gz")
                    )
                )
                input[1] = file("${params.test_data_dir}/datasets/bakta/light/db-light")
                input[2] = file("${params.test_data_dir}/empty/EMPTY_PROTEINS")
                input[3] = file("${params.test_data_dir}/empty/EMPTY_PRODIGAL_TF")
                input[4] = file("${params.test_data_dir}/empty/EMPTY_REPLICONS")
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.txt,
                    record.versions
                ).match() }
            )
        }
    }
}
