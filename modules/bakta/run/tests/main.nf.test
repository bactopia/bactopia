nextflow_process {
    name "Test BAKTA_RUN"
    script "../main.nf"
    process "BAKTA_RUN"
    tag "modules"
    tag "bakta"
    tag "bakta_run"

    test("bakta - module - GCF_000292685 - tarball") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_000292685"],
                        assembly: file("${params.test_data_dir}/data/species/portiera/genome/GCF_000292685.fna.gz")
                    )
                )
                input[1] = file("${params.test_data_dir}/data/datasets/bakta/bakta.tar.gz")
                input[2] = file("${params.test_data_dir}/data/empty/EMPTY_PROTEINS")
                input[3] = file("${params.test_data_dir}/data/empty/EMPTY_PRODIGAL_TF")
                input[4] = file("${params.test_data_dir}/data/empty/EMPTY_REPLICONS")
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.txt,
                    record.versions
                ).match() }
            )
        }
    }

    test("bakta - module - GCF_000292685 - path") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_000292685"],
                        assembly: file("${params.test_data_dir}/data/species/portiera/genome/GCF_000292685.fna.gz")
                    )
                )
                input[1] = file("${params.test_data_dir}/data/datasets/bakta/db")
                input[2] = file("${params.test_data_dir}/data/empty/EMPTY_PROTEINS")
                input[3] = file("${params.test_data_dir}/data/empty/EMPTY_PRODIGAL_TF")
                input[4] = file("${params.test_data_dir}/data/empty/EMPTY_REPLICONS")
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.txt,
                    record.versions
                ).match() }
            )
        }
    }
}
