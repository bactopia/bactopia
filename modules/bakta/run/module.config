/*
Bactopia Module Configuration

Defines parameter defaults, the container images, resource labels, and other settings
for the process defined in this directory.
*/

params {
    // Bakta Options
    //bakta_prodigal_tf = null // TODO: Remove when Path? is fixed
    //bakta_proteins = null    // TODO: Remove when Path? is fixed
    //bakta_replicons = null   // TODO: Remove when Path? is fixed
    bakta_min_contig_length = 1
    bakta_keep_contig_headers = false
    bakta_compliant = false
    bakta_skip_trna = false
    bakta_skip_tmrna = false
    bakta_skip_rrna = false
    bakta_skip_ncrna = false
    bakta_skip_ncrna_region = false
    bakta_skip_crispr = false
    bakta_skip_cds = false
    bakta_skip_sorf = false
    bakta_skip_gap = false
    bakta_skip_ori = false
    bakta_opts = ""
}

process {
    withName: 'BAKTA_RUN' {
        // Optional arguments
        ext.args = [
            params.bakta_skip_trna ? "--skip-trna" : "",
            params.bakta_skip_tmrna ? "--skip-tmrna" : "",
            params.bakta_skip_rrna ? "--skip-rrna" : "",
            params.bakta_skip_ncrna ? "--skip-ncrna" : "",
            params.bakta_skip_ncrna_region ? "--skip-ncrna-region" : "",
            params.bakta_skip_crispr ? "--skip-crispr" : "",
            params.bakta_skip_cds ? "--skip-cds" : "",
            params.bakta_skip_sorf ? "--skip-sorf" : "",
            params.bakta_skip_gap ? "--skip-gap" : "",
            params.bakta_skip_ori ? "--skip-ori" : "",
            params.bakta_compliant ? "--compliant" : "",
            params.bakta_keep_contig_headers ? "--keep-contig-headers" : "",
            "--min-contig-length ${params.bakta_min_contig_length}",
            "${params.bakta_opts}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::bakta=1.11.4".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/bakta:1.11.4--pyhdfd78af_0"
        ext.image = "https://depot.galaxyproject.org/singularity/bakta:1.11.4--pyhdfd78af_0"
        ext.condaDir = "${params.condadir}"

        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "bakta"
        ext.skip_compression = params.skip_compression
    }
}
