nextflow_process {
    name "Test EMMTYPER"
    script "../main.nf"
    process "EMMTYPER"

    test("emmtyper - module - GCF_006364235") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_006364235"],
                        assembly: file("${params.test_data_dir}/data/species/streptococcus_pyogenes/genome/GCF_006364235.fna.gz")
                    )
                )
                input[1] = null
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.versions
                ).match() }
            )
        }
    }

    test("emmtyper - module - GCF_006364235 - with db") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_006364235"],
                        assembly: file("${params.test_data_dir}/data/species/streptococcus_pyogenes/genome/GCF_006364235.fna.gz")
                    )
                )
                input[1] = file("${params.test_data_dir}/data/datasets/emmtyper/emmtyper.tfa")
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.versions
                ).match() }
            )
        }
    }
}
