process {
    withName: 'EMMTYPER' {
        // Optional arguments
        ext.args = {[
            "--workflow ${params.emmtyper_wf}",
            "--cluster-distance ${params.cluster_distance}",
            "--percent-identity ${params.percid}",
            "--culling-limit ${params.culling_limit}",
            "--mismatch ${params.mismatch}",
            "--align-diff ${params.align_diff}",
            "--gap ${params.gap}",
            "--min-perfect ${params.min_perfect}",
            "--min-good ${params.min_good}",
            "--max-size ${params.max_size}"
        ].join(' ').trim()}
        
        // Environment information
        ext.conda = "bioconda::emmtyper=0.2.0"
        ext.singularity = "https://depot.galaxyproject.org/singularity/emmtyper:0.2.0--py_0"
        ext.docker = "quay.io/biocontainers/emmtyper:0.2.0--py_0"
        
        ext.prefix = { params.prefix ? params.prefix : "${params.wf == 'bactopia' ? meta.id : meta.name}" }
        ext.rundir = "${params.rundir}"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = params.is_workflow ? params.wf : params.process_name
    }
}
