params {
    // blast_blastp
    blastp_max_target_seqs = 2000
    blastp_opts = ""
    blastp_outfmt = "sseqid qseqid pident qlen slen length nident positive mismatch gapopen gaps qstart qend sstart send evalue bitscore"
    blastp_qcov_hsp_perc = 50
    blastp_query = null
}

process {
    withName: 'BLAST_BLASTP' {
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "blastp"
        ext.outfmt = params.blastp_outfmt

        // Tool arguments
        ext.args = [
            "-outfmt '6 ${params.blastp_outfmt}'",
            "-qcov_hsp_perc ${params.blastp_qcov_hsp_perc}",
            "-max_target_seqs ${params.blastp_max_target_seqs}",
            params.blastp_opts
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::blast=2.17.0".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/blast:2.17.0--h66d330f_0"
        ext.image = "https://depot.galaxyproject.org/singularity/blast:2.17.0--h66d330f_0"
        ext.condaDir = "${params.condadir}"
    }
}
