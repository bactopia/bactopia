nextflow_process {
    name "Test BLAST_BLASTP"
    script "../main.nf"
    process "BLAST_BLASTP"
    tag "modules"
    tag "blast"
    tag "blast_blastp"

    test("blastp - module - SRX1390622") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "SRR2838702"],
                        blastdb: file("${params.test_data_dir}/species/portiera/compressed/SRR2838702/main/annotator/prokka/SRR2838702-blastdb.tar.gz")
                    )
                )
                input[1] = file("${params.test_data_dir}/datasets/blast/single-protein.faa")
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.versions
                ).match() }
            )
        }
    }
}
