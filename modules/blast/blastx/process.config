/*
This file includes default process values for blast blastx.
*/

process {
    withName: 'BLAST_BLASTX' {
        // Optional arguments
        ext.args = [
            "-outfmt '6 ${params.blastx_outfmt}'",
            "-qcov_hsp_perc ${params.blastx_qcov_hsp_perc}",
            "-max_target_seqs ${params.blastx_max_target_seqs}",
            params.blastx_opts
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.env = [
            toolName: "bioconda::blast=2.16.0".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/blast:2.16.0--hc155240_2",
            image: "https://depot.galaxyproject.org/singularity/blast:2.16.0--hc155240_2",
            condaDir: "${params.condadir}",
        ]

        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "blastx"
        ext.outfmt = params.blastx_outfmt
    }
}
