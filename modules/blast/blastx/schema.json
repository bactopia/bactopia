{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/bactopia/bactopia/master/modules/blast/blastx/schema.json",
    "title": "BLASTX Module",
    "description": "A module for rapidly aligning against proteins",
    "type": "object",
    "$defs": {
        "blast_parameters": {
            "title": "BLASTX Parameters",
            "type": "object",
            "description": "",
            "default": "",
            "fa_icon": "fas fa-exclamation-circle",
            "properties": {
        "blastx_query": {
            "type": ["string", "null"],
            "description": "Query sequence(s) for BLASTX",
            "default": null
        },
        "blastx_outfmt": {
            "type": "string",
            "description": "Output format specification",
            "default": "sseqid qseqid pident qlen slen length nident positive mismatch gapopen gaps qstart qend sstart send evalue bitscore"
        },
        "blastx_opts": {
            "type": "string",
            "description": "Additional BLASTX options",
            "default": ""
        },
        "blastx_qcov_hsp_perc": {
            "type": "integer",
            "description": "Percent query coverage per hsp",
            "default": 50
        },
        "blastx_max_target_seqs": {
            "type": "integer",
            "description": "Maximum number of aligned sequences to keep",
            "default": 2000
        }
            }
        }
    },
    "allOf": [
        {
            "$ref": "#/$defs/blast_parameters"
        }
    ]
}
