/*
Bactopia Module Configuration

Defines parameter defaults, the container images, resource labels, and other settings
for the process defined in this directory.
*/

params {
    // BLAST Parameters
    blastn_query = null
    blastn_outfmt = "sseqid qseqid pident qlen slen length nident positive mismatch gapopen gaps qstart qend sstart send evalue bitscore"
    blastn_opts = ""
    blastn_perc_identity = 50
    blastn_qcov_hsp_perc = 50
    blastn_max_target_seqs = 2000
    blastn_use_genes = false
}

process {
    withName: 'BLAST_BLASTN' {
        // Optional arguments
        ext.args = [
            "-outfmt '6 ${params.blastn_outfmt}'",
            "-perc_identity ${params.blastn_perc_identity}",
            "-qcov_hsp_perc ${params.blastn_qcov_hsp_perc}",
            "-max_target_seqs ${params.blastn_max_target_seqs}",
            params.blastn_opts
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::blast=2.16.0".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/blast:2.16.0--hc155240_2"
        ext.image = "https://depot.galaxyproject.org/singularity/blast:2.16.0--hc155240_2"
        ext.condaDir = "${params.condadir}"

        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "blastn"
        ext.use_genes = params.blastn_use_genes
        ext.outfmt = params.blastn_outfmt
    }
}
