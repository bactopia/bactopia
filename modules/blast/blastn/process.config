/*
This file includes default process values for blast blastn.
*/

process {
    withName: 'BLAST_BLASTN' {
        // Optional arguments
        ext.args = [
            "-outfmt \"6 ${params.blastn_outfmt}\"",
            params.blastn_perc_identity ? "-perc_identity ${params.blastn_perc_identity}" : "",
            params.blastn_qcov_hsp_perc ? "-qcov_hsp_perc ${params.blastn_qcov_hsp_perc}" : "",
            params.blastn_max_target_seqs ? "-max_target_seqs ${params.blastn_max_target_seqs}" : "",
            params.blastn_opts ? "${params.blastn_opts}" : ""
        ].join(' ')

        // Environment information
        ext.env = [
            toolName: "bioconda::blast=2.16.0".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "quay.io/biocontainers/blast:2.16.0--hc155240_2",
            image: "https://depot.galaxyproject.org/singularity/blast:2.16.0--hc155240_2",
            condaDir: "${params.condadir}",
        ]

        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "blastn"
    }
}
