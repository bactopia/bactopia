/*
This file includes default process values for blast blastn.
*/

process {
    withName: 'BLAST_BLASTN' {
        // Optional arguments
        ext.args = [
            "-outfmt '6 ${params.blastn_outfmt}'",
            "-perc_identity ${params.blastn_perc_identity}",
            "-qcov_hsp_perc ${params.blastn_qcov_hsp_perc}",
            "-max_target_seqs ${params.blastn_max_target_seqs}",
            params.blastn_opts
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.env = [
            toolName: "bioconda::blast=2.16.0".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/blast:2.16.0--hc155240_2",
            image: "https://depot.galaxyproject.org/singularity/blast:2.16.0--hc155240_2",
            condaDir: "${params.condadir}",
        ]

        ext.wf = params.wf
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "blastn"
        ext.use_genes = params.blastn_use_genes
        ext.outfmt = params.blastn_outfmt
    }
}
