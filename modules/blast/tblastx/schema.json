{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/bactopia/bactopia/master/modules/blast/tblastx/schema.json",
    "title": "TBLASTX Module",
    "description": "A module for rapidly aligning against contigs and genes",
    "type": "object",
    "$defs": {
        "blast_parameters": {
            "title": "TBLASTX Parameters",
            "type": "object",
            "description": "",
            "default": "",
            "fa_icon": "fas fa-exclamation-circle",
            "properties": {
        "tblastx_query": {
            "type": ["string", "null"],
            "description": "Query sequence(s) for TBLASTX",
            "default": null
        },
        "tblastx_outfmt": {
            "type": "string",
            "description": "Output format specification",
            "default": "sseqid qseqid pident qlen slen length nident positive mismatch gapopen gaps qstart qend sstart send evalue bitscore"
        },
        "tblastx_opts": {
            "type": "string",
            "description": "Additional TBLASTX options",
            "default": ""
        },
        "tblastx_qcov_hsp_perc": {
            "type": "integer",
            "description": "Percent query coverage per hsp",
            "default": 50
        },
        "tblastx_max_target_seqs": {
            "type": "integer",
            "description": "Maximum number of aligned sequences to keep",
            "default": 2000
        },
        "tblastx_use_genes": {
            "type": "boolean",
            "description": "Use genes (ffn) instead of contigs (fna) for database",
            "default": false
        }
            }
        }
    },
    "allOf": [
        {
            "$ref": "#/$defs/blast_parameters"
        }
    ]
}
