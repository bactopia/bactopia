nextflow_process {
    name "Test BLAST_TBLASTN"
    script "../main.nf"
    process "BLAST_TBLASTN"

    test("tblastn - module - SRX1390622") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "SRX1390622"],
                        blastdb: file("${params.test_data_dir}/data/species/portiera/genome/SRX1390622-blastdb.tar.gz")
                    )
                )
                input[1] = file("${params.test_data_dir}/data/species/portiera/genome/single-protein.faa")
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.versions
                ).match() }
            )
        }
    }
}
