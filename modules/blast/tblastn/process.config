/*
This file includes default process values for blast tblastn.
*/

process {
    withName: 'BLAST_TBLASTN' {
        // Optional arguments
        ext.args = [
            "-outfmt '6 ${params.tblastn_outfmt}'",
            "-qcov_hsp_perc ${params.tblastn_qcov_hsp_perc}",
            "-max_target_seqs ${params.tblastn_max_target_seqs}",
            params.tblastn_opts
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::blast=2.16.0".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/blast:2.16.0--hc155240_2"
        ext.image = "https://depot.galaxyproject.org/singularity/blast:2.16.0--hc155240_2"
        ext.condaDir = "${params.condadir}"

        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "tblastn"
        ext.use_genes = params.tblastn_use_genes
        ext.outfmt = params.tblastn_outfmt
    }
}
