{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "BLAST TBLASTN Module",
    "type": "object",
    "properties": {
        "tblastn_query": {
            "type": ["string", "null"],
            "description": "Query sequence(s) for TBLASTN",
            "default": null
        },
        "tblastn_outfmt": {
            "type": "string",
            "description": "Output format specification",
            "default": "sseqid qseqid pident qlen slen length nident positive mismatch gapopen gaps qstart qend sstart send evalue bitscore"
        },
        "tblastn_opts": {
            "type": "string",
            "description": "Additional TBLASTN options",
            "default": ""
        },
        "tblastn_qcov_hsp_perc": {
            "type": "integer",
            "description": "Percent query coverage per hsp",
            "default": 50
        },
        "tblastn_max_target_seqs": {
            "type": "integer",
            "description": "Maximum number of aligned sequences to keep",
            "default": 2000
        },
        "tblastn_use_genes": {
            "type": "boolean",
            "description": "Use genes (ffn) instead of contigs (fna) for database",
            "default": false
        }
    }
}
