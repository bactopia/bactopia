params {
    // stecfinder
    stecfinder_cutoff = 10.0
    stecfinder_h_depth = 1.0
    stecfinder_h_length = 60.0
    stecfinder_hits = false
    stecfinder_ipah_depth = 1.0
    stecfinder_ipah_length = 10.0
    stecfinder_length = 50.0
    stecfinder_o_depth = 1.0
    stecfinder_o_length = 60.0
    stecfinder_stx_depth = 1.0
    stecfinder_stx_length = 10.0
    stecfinder_use_reads = false
}

process {
    withName: 'STECFINDER' {
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "stecfinder"

        // Tool arguments
        ext.args = [
            params.stecfinder_use_reads  ? "-r" : "",
            params.stecfinder_hits ? "--hits" : "",
            "--cutoff ${params.stecfinder_cutoff}",
            "--length ${params.stecfinder_length}",
            "--ipaH_length ${params.stecfinder_ipah_length}",
            "--ipaH_depth ${params.stecfinder_ipah_depth}",
            "--stx_length ${params.stecfinder_stx_length}",
            "--stx_depth ${params.stecfinder_stx_depth}",
            "--o_length ${params.stecfinder_o_length}",
            "--o_depth ${params.stecfinder_o_depth}",
            "--h_length ${params.stecfinder_h_length}",
            "--h_depth ${params.stecfinder_h_depth}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::stecfinder=1.1.2".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/stecfinder:1.1.2--pyhdfd78af_0"
        ext.image = "https://depot.galaxyproject.org/singularity/stecfinder:1.1.2--pyhdfd78af_0"
        ext.condaDir = "${params.condadir}"

        // Module-specific parameters
        ext.stecfinder_use_reads = params.stecfinder_use_reads
    }
}
