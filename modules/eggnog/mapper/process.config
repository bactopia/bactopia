process {
    withName: 'EGGNOG_MAPPER' {
        // Optional arguments
        ext.args = {[
            "--genepred ${params.genepred}",
            "-m ${params.mode}",
            params.eggnog_opts
        ].join(' ').trim()}
        
        // Environment information
        ext.conda = "bioconda::eggnog-mapper=2.1.12"
        ext.singularity = "https://depot.galaxyproject.org/singularity/eggnog-mapper:2.1.12--pyhdfd78af_0"
        ext.docker = "quay.io/biocontainers/eggnog-mapper:2.1.12--pyhdfd78af_0"
        
        ext.prefix = { params.prefix ? params.prefix : "${params.wf == 'bactopia' ? meta.id : meta.name}" }
        ext.rundir = "${params.rundir}"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = params.is_workflow ? params.wf : params.process_name
    }
}
