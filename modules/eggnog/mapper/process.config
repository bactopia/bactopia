/*
This file includes default process values for eggnog.
*/

process {
    withName: 'EGGNOG_MAPPER' {
        // Optional arguments
        ext.args = [
            "--genepred ${params.eggnog_genepred}",
            "-m ${params.eggnog_mode}",
            "${params.eggnog_opts}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.env = [
            toolName: "bioconda::eggnog-mapper=2.1.12".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/eggnog-mapper:2.1.12--pyhdfd78af_0",
            image: "https://depot.galaxyproject.org/singularity/eggnog-mapper:2.1.12--pyhdfd78af_0",
            condaDir: "${params.condadir}",
        ]
        
        ext.wf = params.wf
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "eggnog"
    }
}
