/*
Bactopia Module Configuration

Defines parameter defaults, the container images, resource labels, and other settings
for the process defined in this directory.
*/

params {
    // eggnog-mapper db download
    eggnog_db = null
    eggnog_save_as_tarball = false
    download_eggnog = false
    eggnog_skip_diamond = false
    eggnog_install_hmm = false
    eggnog_install_mmseq = false
    eggnog_install_pfam = false
    eggnog_hmmer_taxid = 2
}

process {
    withName: 'EGGNOG_DOWNLOAD' {
        publishDir = [[
            path: params.eggnog_db, 
            mode: params.publish_dir_mode, 
            overwrite: true
        ]]

        // Optional arguments
        ext.args = [
            params.eggnog_skip_diamond ? "-D" : "",
            params.eggnog_install_hmm ? "-H -d ${params.eggnog_hmmer_taxid} " : "",
            params.eggnog_install_mmseq ? "-M" : "",
            params.eggnog_install_pfam ? "-P" : "",
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        
        // Environment information
        ext.toolName = "bioconda::eggnog-mapper=2.1.12".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/eggnog-mapper:2.1.12--pyhdfd78af_0"
        ext.image = "https://depot.galaxyproject.org/singularity/eggnog-mapper:2.1.12--pyhdfd78af_0"
        ext.condaDir = "${params.condadir}"
        
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "eggnog"
        ext.eggnog_save_as_tarball = params.eggnog_save_as_tarball
    }
}
