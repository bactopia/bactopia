params {
    // eggnog_download
    download_eggnog = false
    eggnog_db = null
    eggnog_hmmer_taxid = 2
    eggnog_install_hmm = false
    eggnog_install_mmseq = false
    eggnog_install_pfam = false
    eggnog_save_as_tarball = false
    eggnog_skip_diamond = false
}

process {
    withName: 'EGGNOG_DOWNLOAD' {
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "eggnog"
        publishDir = [[
            path: params.eggnog_db,
            mode: params.publish_dir_mode,
            overwrite: true
        ]]

        // Tool arguments
        ext.args = [
            params.eggnog_skip_diamond ? "-D" : "",
            params.eggnog_install_hmm ? "-H -d ${params.eggnog_hmmer_taxid} " : "",
            params.eggnog_install_mmseq ? "-M" : "",
            params.eggnog_install_pfam ? "-P" : "",
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::eggnog-mapper=2.1.13".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/eggnog-mapper:2.1.13--pyhdfd78af_2"
        ext.image = "https://depot.galaxyproject.org/singularity/eggnog-mapper:2.1.13--pyhdfd78af_2"
        ext.condaDir = "${params.condadir}"

        // Module-specific parameters
        ext.eggnog_save_as_tarball = params.eggnog_save_as_tarball
    }
}
