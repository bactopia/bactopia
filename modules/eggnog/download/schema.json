{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/bactopia/bactopia/master/modules/eggnog/download/schema.json",
    "title": "eggNOG Downloader Module",
    "description": "A module for downloading eggNOG databases",
    "type": "object",
    "$defs": {
        "eggnog_download_parameters": {
            "title": "eggNOG Downloader Parameters",
            "type": "object",
            "description": "",
            "default": "",
            "fa_icon": "fas fa-exclamation-circle",
            "properties": {
        "eggnog_db": {
            "type": ["string", "null"],
            "default": null,
            "description": "Path to eggNOG database directory"
        },
        "eggnog_save_as_tarball": {
            "type": "boolean",
            "default": false,
            "description": "Save the eggNOG database as a tarball"
        },
        "download_eggnog": {
            "type": "boolean",
            "default": false,
            "description": "Download eggNOG database"
        },
        "skip_diamond": {
            "type": "boolean",
            "default": false,
            "description": "Skip diamond database download"
        },
        "install_hmm": {
            "type": "boolean",
            "default": false,
            "description": "Install HMM profiles"
        },
        "install_mmseq": {
            "type": "boolean",
            "default": false,
            "description": "Install MMseqs2 database"
        },
        "install_pfam": {
            "type": "boolean",
            "default": false,
            "description": "Install PFAM profiles"
        },
        "hmmer_taxid": {
            "type": "integer",
            "default": 2,
            "description": "NCBI taxonomy ID for HMMER database"
        }
            }
        }
    },
    "allOf": [
        {
            "$ref": "#/$defs/eggnog_download_parameters"
        }
    ]
}
