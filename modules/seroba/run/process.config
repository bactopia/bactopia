/*
This file includes default process configurations
*/

process {
    withName: 'SEROBA_RUN' {
        // Optional arguments
        ext.args = {[
            params.seroba_noclean ? "--noclean" : "",
            "--coverage ${params.seroba_coverage}"
        ].join(' ').trim()}
        
        // Environment information
        ext.conda = "${moduleDir}/environment.yml"
        ext.singularity = 'https://depot.galaxyproject.org/singularity/seroba:1.0.2--pyhdfd78af_1'
        ext.docker = 'quay.io/biocontainers/seroba:1.0.2--pyhdfd78af_1'

        // Misc
        ext.prefix = { "${meta.id}" }
        ext.rundir = "${task.process}"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = { "${task.process}".replace(":", "_") }
    }
}
