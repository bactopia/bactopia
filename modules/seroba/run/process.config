/*
This file includes default process values for seroba/run.
*/

process {
    withName: 'SEROBA_RUN' {
        // Optional arguments
        ext.args = [
            "--coverage ${params.seroba_coverage}",
            params.seroba_noclean ? "--noclean" : ""
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.env = [
            toolName: "bioconda::seroba=1.0.2".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "quay.io/biocontainers/seroba:1.0.2--pyhdfd78af_1",
            image: "https://depot.galaxyproject.org/singularity/seroba:1.0.2--pyhdfd78af_1",
            condaDir: "${params.condadir}",
        ]
        
        ext.wf = params.wf
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "seroba"
    }
}
