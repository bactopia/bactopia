params {
    // seroba_run
    seroba_coverage = 20
    seroba_noclean = false
}

process {
    withName: 'SEROBA_RUN' {
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "seroba"

        // Tool arguments
        ext.args = [
            "--coverage ${params.seroba_coverage}",
            params.seroba_noclean ? "--noclean" : ""
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::seroba=1.0.2".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/seroba:1.0.2--pyhdfd78af_1"
        ext.image = "https://depot.galaxyproject.org/singularity/seroba:1.0.2--pyhdfd78af_1"
        ext.condaDir = "${params.condadir}"
    }
}
