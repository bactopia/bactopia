params {
    // tbprofiler_collate
    tbprofiler_all_variants = false
    tbprofiler_full = false
    tbprofiler_itol = false
    tbprofiler_mark_missing = false
}

process {
    withName: 'TBPROFILER_COLLATE' {
        ext.wf = params.wf
        ext.scope = "run"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "tbprofiler-collate"

        // Tool arguments
        ext.args = [
            params.tbprofiler_itol ? "--itol" : "",
            params.tbprofiler_full ? "--full" : "",
            params.tbprofiler_all_variants ? "--all_variants" : "",
            params.tbprofiler_mark_missing ? "--mark_missing" : "",
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::tb-profiler=6.6.6".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/tb-profiler:6.6.6--pyhdfd78af_0"
        ext.image = "https://depot.galaxyproject.org/singularity/tb-profiler:6.6.6--pyhdfd78af_0"
        ext.condaDir = "${params.condadir}"
    }
}
