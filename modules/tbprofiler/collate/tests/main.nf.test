nextflow_process {
    name "Test TBPROFILER_COLLATE"
    script "../main.nf"
    process "TBPROFILER_COLLATE"
    tag "modules"
    tag "tbprofiler"
    tag "tbprofiler_collate"

    test("tbprofiler collate - module - test") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        meta: [name: "tbprofiler"],
                        json: [
                            file("${params.test_data_dir}/datasets/tbprofiler/illumina/SRR2838702.results.json.gz"),
                            file("${params.test_data_dir}/datasets/tbprofiler/nanopore/ERR3772599.results.json.gz")
                        ]
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.versions
                ).match() }
            )
        }
    }
}
