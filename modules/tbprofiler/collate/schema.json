{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/bactopia/bactopia/master/modules/tbprofiler/collate/schema.json",
    "title": "bactopia/tbprofiler/collate module",
    "description": "Collate TB-Profiler results from multiple samples",
    "type": "object",
    "definitions": {
        "tbprofiler_collate_parameters": {
            "title": "TB-Profiler Collate Parameters",
            "type": "object",
            "description": "Parameters for collating TB-Profiler results",
            "properties": {
                "itol": {
                    "type": "boolean",
                    "default": false,
                    "description": "Generate iTOL files"
                },
                "full": {
                    "type": "boolean",
                    "default": false,
                    "description": "Generate full output"
                },
                "all_variants": {
                    "type": "boolean",
                    "default": false,
                    "description": "Include all variants in output"
                },
                "mark_missing": {
                    "type": "boolean",
                    "default": false,
                    "description": "Mark missing data"
                }
            },
            "required": []
        }
    },
    "allOf": [
        {
            "$ref": "#/definitions/tbprofiler_collate_parameters"
        }
    ]
}
