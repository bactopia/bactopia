/*
This file includes default process values for iqtree.
*/

process {
    withName: 'IQTREE' {
        // Optional arguments
        ext.args = [
            "-m ${params.iqtree_model}",
            "-bb ${params.bb}",
            "-alrt ${params.alrt}",
            params.asr ? "-asr" : "",
            params.iqtree_opts ? "${params.iqtree_opts}" : ""
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.env = [
            toolName: "bioconda::iqtree=2.4.0".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/iqtree:2.4.0--h503566f_0",
            image: "https://depot.galaxyproject.org/singularity/iqtree:2.4.0--h503566f_0",
            condaDir: "${params.condadir}",
        ]
        
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "iqtree"
    }
}
