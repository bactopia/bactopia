nextflow_process {
    name "Test IQTREE"
    script "../main.nf"
    process "IQTREE"
    tag "modules"
    tag "iqtree"

    test("iqtree - module - test") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "test", process_name: "iqtree"],
                        aln: file("${params.test_data_dir}/datasets/generic/genome/genome.aln.gz")
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.versions
                ).match() }
            )
        }
    }

    test("iqtree - module - test (fast)") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "test", process_name: "iqtree-fast"],
                        aln: file("${params.test_data_dir}/datasets/generic/genome/genome.aln.gz")
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.versions
                ).match() }
            )
        }
    }
}
