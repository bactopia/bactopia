nextflow_process {
    name "Test IQTREE"
    script "../main.nf"
    process "IQTREE"

    test("iqtree - module - test") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "test"],
                        msa: file("${params.test_data_dir}/data/species/portiera/genome/genome.aln.gz")
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.phylogeny,
                    record.versions
                ).match() }
            )
        }
    }
}
