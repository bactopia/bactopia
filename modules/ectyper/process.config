process {
    withName: 'ECTYPER' {
        // Optional arguments
        ext.args = {[
            "--opid ${params.opid}",
            "--hpid ${params.hpid}",
            "--opcov ${params.opcov}",
            "--hpcov ${params.hpcov}",
            params.verify ? "--verify" : "",
            params.print_alleles ? "--alleles" : ""
        ].join(' ').trim()}
        
        // Environment information
        ext.conda = "bioconda::ectyper=1.0.0"
        ext.singularity = "https://depot.galaxyproject.org/singularity/ectyper:1.0.0--pyhdfd78af_1"
        ext.docker = "quay.io/biocontainers/ectyper:1.0.0--pyhdfd78af_1"
        
        ext.prefix = { params.prefix ? params.prefix : "${params.wf == 'bactopia' ? meta.id : meta.name}" }
        ext.rundir = "${params.rundir}"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = params.is_workflow ? params.wf : params.process_name
    }
}
