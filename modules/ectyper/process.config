/*
This file includes default process values for ectyper.
*/

process {
    withName: 'ECTYPER' {
        // Optional arguments
        ext.args = [
            params.ectyper_verify ? "--verify" : "",
            params.ectyper_print_alleles  ? "-s" : "",
            "-opid ${params.ectyper_opid}",
            "-opcov ${params.ectyper_opcov}",
            "-hpid ${params.ectyper_hpid}",
            "-hpcov ${params.ectyper_hpcov}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.env = [
            toolName: "bioconda::ectyper=1.0.0".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/ectyper:1.0.0--pyhdfd78af_1",
            image: "https://depot.galaxyproject.org/singularity/ectyper:1.0.0--pyhdfd78af_1",
            condaDir: "${params.condadir}",
        ]
        
        ext.wf = params.wf
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "ectyper"
    }
}
