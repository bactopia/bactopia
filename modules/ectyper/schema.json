{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/bactopia/bactopia/master/modules/ectyper/schema.json",
    "title": "ECTyper Module",
    "description": "A module for serotyping Escherichia coli genomes",
    "type": "object",
    "$defs": {
        "ectyper_parameters": {
            "title": "ECTyper Parameters",
            "type": "object",
            "description": "",
            "default": "",
            "fa_icon": "fas fa-exclamation-circle",
            "properties": {
                "ectyper_opid": {
                    "type": "integer",
                    "default": 90,
                    "description": "Percent identity required for an O antigen allele match",
                    "fa_icon": "fas fa-hashtag"
                },
                "ectyper_opcov": {
                    "type": "integer",
                    "default": 90,
                    "description": "Minimum percent coverage required for an O antigen allele match",
                    "fa_icon": "fas fa-hashtag"
                },
                "ectyper_hpid": {
                    "type": "integer",
                    "default": 95,
                    "description": "Percent identity required for an H antigen allele match",
                    "fa_icon": "fas fa-hashtag"
                },
                "ectyper_hpcov": {
                    "type": "integer",
                    "default": 50,
                    "description": "Minimum percent coverage required for an H antigen allele match",
                    "fa_icon": "fas fa-hashtag"
                },
                "ectyper_verify": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enable E. coli species verification",
                    "fa_icon": "fas fa-toggle-on",
                    "hidden": true
                },
                "ectyper_print_alleles": {
                    "type": "boolean",
                    "default": false,
                    "description": "Prints the allele sequences if enabled as the final column",
                    "fa_icon": "fas fa-toggle-on",
                    "hidden": true
                }
            }
        }
    },
    "allOf": [
        {
            "$ref": "#/$defs/ectyper_parameters"
        }
    ]
}
