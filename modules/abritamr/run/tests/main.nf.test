nextflow_process {
    name "Test ABRITAMR_RUN"
    script "../main.nf"
    process "ABRITAMR_RUN"
    tag "modules"
    tag "abritamr"
    tag "abritamr_run"

    test("abritamr - module - GCF_000292685 - uncompressed") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_000292685"],
                        assembly: file("${params.test_data_dir}/data/species/escherichia_coli/genome/GCF_001682305.fna")
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.summary,
                    record.matches,
                    record.partials,
                    record.virulence,
                    record.amrfinder,
                    record.versions
                ).match() }
            )
        }
    }

    test("abritamr - module - GCF_000292685 - compressed") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_000292685"],
                        assembly: file("${params.test_data_dir}/data/species/escherichia_coli/genome/GCF_001682305.fna.gz")
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.summary,
                    record.matches,
                    record.partials,
                    record.virulence,
                    record.amrfinder,
                    record.versions
                ).match() }
            )
        }
    }
}
