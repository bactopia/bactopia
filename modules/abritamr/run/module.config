params {
    // abritamr_run
    abritamr_identity = null
    abritamr_species = null
}

process {
    withName: 'ABRITAMR_RUN' {
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "abritamr"

        // Tool arguments
        ext.args = [
            params.abritamr_identity ? "--identity ${params.abritamr_identity}" : "",
            params.abritamr_species ? "--species ${params.abritamr_species}" : ""
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::abritamr=1.2.0".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/abritamr:1.2.0--pyh5707d69_1"
        ext.image = "https://depot.galaxyproject.org/singularity/abritamr:1.2.0--pyh5707d69_1"
        ext.condaDir = "${params.condadir}"
    }
}
