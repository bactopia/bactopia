/*
This file includes default process values for abritamr.
*/

process {
    withName: 'ABRITAMR_RUN' {
        // Optional arguments
        ext.args = [
            params.abritamr_identity ? "--identity ${params.abritamr_identity}" : "",
            params.abritamr_species ? "--species ${params.abritamr_species}" : ""
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::abritamr=1.0.19".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/abritamr:1.0.19--pyhdfd78af_0"
        ext.image = "https://depot.galaxyproject.org/singularity/abritamr:1.0.19--pyhdfd78af_0"
        ext.condaDir = "${params.condadir}"

        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "abritamr"
    }
}
