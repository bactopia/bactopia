/*
This file includes default process values for hicap.
*/

process {
    withName: 'HICAP' {
        // Optional arguments
        ext.args = [
            params.full_sequence ? "--full_sequence" : "",
            "--gene_coverage ${params.gene_coverage}",
            "--gene_identity ${params.gene_identity}",
            "--broken_gene_length ${params.broken_gene_length}",
            "--broken_gene_identity ${params.broken_gene_identity}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.env = [
            toolName: "bioconda::hicap=1.0.4".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/hicap:1.0.4--pyhdfd78af_1",
            image: "https://depot.galaxyproject.org/singularity/hicap:1.0.4--pyhdfd78af_1",
            condaDir: "${params.condadir}",
        ]
        
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "hicap"
    }
}
