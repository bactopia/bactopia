/*
This file includes default process configurations
*/

process {
    withName: 'SHIGAPASS' {
        // Optional arguments
        
        // Environment information
        ext.conda = "${moduleDir}/environment.yml"
        ext.singularity = 'https://depot.galaxyproject.org/singularity/shigapass:1.5.0--hdfd78af_0'
        ext.docker = 'quay.io/biocontainers/shigapass:1.5.0--hdfd78af_0'

        // Misc
        ext.prefix = { "${meta.id}" }
        ext.rundir = "${task.process}"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = { "${task.process}".replace(":", "_") }
    }
}
