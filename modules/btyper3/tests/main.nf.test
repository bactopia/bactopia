nextflow_process {
    name "Test BTYPER3"
    script "../main.nf"
    process "BTYPER3"
    tag "modules"
    tag "btyper3"

    test("btyper3 - module - GCF_000008445 - uncompressed") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_000008445"],
                        assembly: file("${params.test_data_dir}/data/species/bacillus_anthracis/genome/GCF_000008445.fna")
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.versions
                ).match() }
            )
        }
    }

    test("btyper3 - module - GCF_000008445 - compressed") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_000008445"],
                        assembly: file("${params.test_data_dir}/data/species/bacillus_anthracis/genome/GCF_000008445.fna.gz")
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.versions
                ).match() }
            )
        }
    }
}
