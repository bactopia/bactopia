{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/bactopia/bactopia/master/modules/btyper3/schema.json",
    "title": "BTyper3 Module",
    "description": "A module for taxonomic classification of Bacillus cereus group isolates.",
    "type": "object",
    "$defs": {
        "btyper3_parameters": {
            "title": "BTyper3 Parameters",
            "type": "object",
            "description": "",
            "default": "",
            "fa_icon": "fas fa-exclamation-circle",
            "properties": {
        "bt_virulence_identity": {
            "type": "integer",
            "description": "Minimum percent identity for virulence factors",
            "default": 70
        },
        "bt_virulence_coverage": {
            "type": "integer",
            "description": "Minimum percent coverage for virulence factors",
            "default": 80
        },
        "bt_identity": {
            "type": "integer",
            "description": "Minimum percent identity for general genes",
            "default": 50
        },
        "bt_coverage": {
            "type": "integer",
            "description": "Minimum percent coverage for general genes",
            "default": 70
        },
        "bt_overlap": {
            "type": "integer",
            "description": "Minimum percent overlap",
            "default": 70
        },
        "bt_opts": {
            "type": "string",
            "description": "Additional BTyper3 options",
            "default": ""
        }
            }
        }
    },
    "allOf": [
        {
            "$ref": "#/$defs/btyper3_parameters"
        }
    ]
}
