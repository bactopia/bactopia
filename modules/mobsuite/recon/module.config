params {
    // mobsuite_recon
    mobsuite_max_contig_size = 310000
    mobsuite_max_plasmid_size = 350000
    mobsuite_min_contig_size = 1000
    mobsuite_opts = ""
}

process {
    withName: 'MOBSUITE_RECON' {
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "mobsuite"

        // Tool arguments
        ext.args = [
            "--max_contig_size ${params.mobsuite_max_contig_size}",
            "--min_length ${params.mobsuite_min_contig_size}",
            "--max_plasmid_size ${params.mobsuite_max_plasmid_size}",
            "${params.mobsuite_opts}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::mob_suite=3.1.9".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/mob_suite:3.1.9--pyhdfd78af_1"
        ext.image = "https://depot.galaxyproject.org/singularity/mob_suite:3.1.9--pyhdfd78af_1"
        ext.condaDir = "${params.condadir}"
    }
}
