process {
    withName: 'MOBSUITE_RECON' {
        // Optional arguments
        ext.args = {[
            "--max_contig_size ${params.mb_max_contig_size}",
            "--min_contig_size ${params.mb_min_contig_size}",
            "--max_plasmid_size ${params.mb_max_plasmid_size}",
            params.mobsuite_opts
        ].join(' ').trim()}
        
        // Environment information
        ext.conda = "bioconda::mob_suite=3.1.9"
        ext.singularity = "https://depot.galaxyproject.org/singularity/mob_suite:3.1.9--pyhdfd78af_0"
        ext.docker = "quay.io/biocontainers/mob_suite:3.1.9--pyhdfd78af_0"
        
        ext.prefix = { params.prefix ? params.prefix : "${params.wf == 'bactopia' ? meta.id : meta.name}" }
        ext.rundir = "${params.rundir}"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = params.is_workflow ? params.wf : params.process_name
    }
}
