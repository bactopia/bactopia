/*
This file includes default process values for sccmec.
*/

process {
    withName: 'SCCMEC' {
        // Optional arguments
        ext.args = [
            "--min-targets-pident ${params.sccmec_min_targets_pident}",
            "--min-targets-coverage ${params.sccmec_min_targets_coverage}",
            "--min-regions-pident ${params.sccmec_min_regions_pident}",
            "--min-regions-coverage ${params.sccmec_min_regions_coverage}",
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.toolName = "bioconda::sccmec=1.2.0".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/sccmec:1.2.0--hdfd78af_0"
        ext.image = "https://depot.galaxyproject.org/singularity/sccmec:1.2.0--hdfd78af_0"
        ext.condaDir = "${params.condadir}"
        
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "sccmec"
    }
}
