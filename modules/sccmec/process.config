/*
This file includes default process configurations
*/

process {
    withName: 'SCCMEC' {
        // Optional arguments
        ext.args = {[
            "--min-targets-pident ${params.sccmec_min_targets_pident}",
            "--min-targets-coverage ${params.sccmec_min_targets_coverage}",
            "--min-regions-pident ${params.sccmec_min_regions_pident}",
            "--min-regions-coverage ${params.sccmec_min_regions_coverage}"
        ].join(' ').trim()}
        
        // Environment information
        ext.conda = "${moduleDir}/environment.yml"
        ext.singularity = 'https://depot.galaxyproject.org/singularity/sccmec:1.2.0--hdfd78af_0'
        ext.docker = 'quay.io/biocontainers/sccmec:1.2.0--hdfd78af_0'

        // Misc
        ext.prefix = { "${meta.id}" }
        ext.rundir = "${task.process}"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = { "${task.process}".replace(":", "_") }
    }
}
