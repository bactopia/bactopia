process {
    withName: 'HPSUISSERO' {
        // Optional arguments
        ext.args = ""
        
        // Environment information
        ext.conda = "bioconda::hpsuissero=1.0.1"
        ext.singularity = "https://depot.galaxyproject.org/singularity/hpsuissero:1.0.1--hdfd78af_0"
        ext.docker = "quay.io/biocontainers/hpsuissero:1.0.1--hdfd78af_0"
        
        ext.prefix = { params.prefix ? params.prefix : "${params.wf == 'bactopia' ? meta.id : meta.name}" }
        ext.rundir = "${params.rundir}"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = params.is_workflow ? params.wf : params.process_name
        ext.version = "1.0.1"
    }
}
