params {
    // HpsuisSero has no opts
}

process {
    withName: 'HPSUISSERO' {
        // Optional arguments
        ext.args = ""
        
        // Environment information
        ext.toolName = "bioconda::hpsuissero=1.0.1".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/hpsuissero:1.0.1--hdfd78af_0"
        ext.image = "https://depot.galaxyproject.org/singularity/hpsuissero:1.0.1--hdfd78af_0"
        ext.condaDir = "${params.condadir}"
        
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "hpsuissero"
        ext.version = "1.0.1"
    }
}
