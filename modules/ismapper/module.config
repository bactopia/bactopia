params {
    // ISMapper
    reference = null
    insertions = null
    ismap_min_clip = 10
    ismap_max_clip = 30
    ismap_cutoff = 6
    ismap_novel_gap_size = 15
    ismap_min_range = 0.9
    ismap_max_range = 1.1
    ismap_merging = 100
    ismap_all = null
    ismap_minqual = 30
}

process {
    withName: 'ISMAPPER' {
        // Optional arguments
        ext.args = [
            params.ismap_all ? "-all" : "",
            "--min_clip ${params.ismap_min_clip}",
            "--max_clip ${params.ismap_max_clip}",
            "--cutoff ${params.ismap_cutoff}",
            "--novel_gap_size ${params.ismap_novel_gap_size}",
            "--min_range ${params.ismap_min_range}",
            "--max_range ${params.ismap_max_range}",
            "--merging ${params.ismap_merging}",
            "--T ${params.ismap_minqual}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::ismapper=2.0.2".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/ismapper:2.0.2--pyhdfd78af_1"
        ext.image = "https://depot.galaxyproject.org/singularity/ismapper:2.0.2--pyhdfd78af_1"
        ext.condaDir = "${params.condadir}"

        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.logs_use_prefix = true
        ext.process_name = "ismapper"
    }
}
