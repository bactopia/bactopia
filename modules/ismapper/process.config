/*
This file includes default process values for ismapper.
*/

process {
    withName: 'ISMAPPER' {
        // Optional arguments
        ext.args = [
            params.ismap_all ? "-all" : "",
            "--min_clip ${params.min_clip}",
            "--max_clip ${params.max_clip}",
            "--cutoff ${params.cutoff}",
            "--novel_gap_size ${params.novel_gap_size}",
            "--min_range ${params.min_range}",
            "--max_range ${params.max_range}",
            "--merging ${params.merging}",
            "--T ${params.ismap_minqual}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.env = [
            toolName: "bioconda::ismapper=2.0.2".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "quay.io/biocontainers/ismapper:2.0.2--pyhdfd78af_1",
            image: "https://depot.galaxyproject.org/singularity/ismapper:2.0.2--pyhdfd78af_1",
            condaDir: "${params.condadir}",
        ]

        ext.rundir = params.rundir
        ext.subdir = params.run_name
        ext.logs_subdir = ""
        ext.logs_use_prefix = true
        ext.process_name = "ismapper"
    }
}
