nextflow_process {
    name "Test LEGSTA"
    script "../main.nf"
    process "LEGSTA"

    test("legsta - module - GCF_000048645") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_000048645"],
                        assembly: file("${params.test_data_dir}/data/species/legionella_pneumophila/genome/GCF_000048645.fna.gz")
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.versions
                ).match() }
            )
        }
    }
}
