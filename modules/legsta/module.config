params {
    // legsta
    legsta_noheader = false
}

process {
    withName: 'LEGSTA' {
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "legsta"

        // Tool arguments
        ext.args = [
            params.legsta_noheader ? "--noheader" : ""
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::legsta=0.5.2".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/legsta:0.5.2--hdfd78af_0"
        ext.image = "https://depot.galaxyproject.org/singularity/legsta:0.5.2--hdfd78af_0"
        ext.condaDir = "${params.condadir}"
    }
}
