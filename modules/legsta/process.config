process {
    withName: 'LEGSTA' {
        // Optional arguments
        ext.args = {[
            params.noheader ? "--noheader" : ""
        ].join(' ').trim()}
        
        // Environment information
        ext.conda = "bioconda::legsta=0.5.1"
        ext.singularity = "https://depot.galaxyproject.org/singularity/legsta:0.5.1--hdfd78af_2"
        ext.docker = "quay.io/biocontainers/legsta:0.5.1--hdfd78af_2"
        
        ext.prefix = { params.prefix ? params.prefix : "${params.wf == 'bactopia' ? meta.id : meta.name}" }
        ext.rundir = "${params.rundir}"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = params.is_workflow ? params.wf : params.process_name
    }
}
