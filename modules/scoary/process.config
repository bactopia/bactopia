/*
This file includes default process values for scoary.
*/

process {
    withName: 'SCOARY' {
        // Optional arguments
        ext.args = [
            params.scoary_permute > 0 ? "--permute ${params.scoary_permute}" : "",
            "--p_value_cutoff ${paramsscoary_p_value_cutoff}",
            "--correction ${params.scoary_correction}",
            "--start_col ${params.scoary_start_col}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.env = [
            toolName: "bioconda::scoary=1.6.16".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/scoary:1.6.16--py_2",
            image: "https://depot.galaxyproject.org/singularity/scoary:1.6.16--py_2",
            condaDir: "${params.condadir}",
        ]
        
        ext.wf = params.wf
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "scoary"
    }
}
