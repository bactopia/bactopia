/*
This file includes default process configurations
*/

process {
    withName: 'SCOARY' {
        // Optional arguments
        ext.args = {[
            "--p_value_cutoff ${params.p_value_cutoff}",
            "--correction ${params.correction}",
            params.permute > 0 ? "--permute ${params.permute}" : "",
            "--start_col ${params.start_col}"
        ].join(' ').trim()}
        
        // Environment information
        ext.conda = "${moduleDir}/environment.yml"
        ext.singularity = 'https://depot.galaxyproject.org/singularity/scoary:1.6.16--py_2'
        ext.docker = 'quay.io/biocontainers/scoary:1.6.16--py_2'

        // Misc
        ext.prefix = { "scoary" }
        ext.rundir = "${task.process}"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = { "${task.process}".replace(":", "_") }
    }
}
