/*
This file includes default process values for ssuissero.
*/

process {
    withName: 'SSUISSERO' {
        // Optional arguments
        ext.args = ""
        
        // Environment information
        ext.env = [
            toolName: "bioconda::ssuissero=1.0.1".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/ssuissero:1.0.1--hdfd78af_1",
            image: "https://depot.galaxyproject.org/singularity/ssuissero:1.0.1--hdfd78af_1",
            condaDir: "${params.condadir}",
        ]
        
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "ssuissero"
    }
}
