{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/bactopia/bactopia/main/modules/kraken2/schema.json",
    "title": "Kraken2 Parameters",
    "description": "The schema for Kraken2 parameters",
    "type": "object",
    "properties": {
        "use_k2scrubber": {
            "type": "boolean",
            "default": false,
            "description": "Use K2 scrubber mode"
        },
        "kraken2_db": {
            "type": ["string", "null"],
            "default": null,
            "description": "Path to Kraken2 database"
        },
        "quick_mode": {
            "type": "boolean",
            "default": false,
            "description": "Enable quick operation mode"
        },
        "confidence": {
            "type": "number",
            "default": 0.0,
            "description": "Confidence score threshold"
        },
        "minimum_base_quality": {
            "type": "integer",
            "default": 0,
            "description": "Minimum base quality used in classification"
        },
        "use_mpa_style": {
            "type": "boolean",
            "default": false,
            "description": "Format report output like Kraken 1's kraken-mpa-report"
        },
        "report_zero_counts": {
            "type": "boolean",
            "default": false,
            "description": "Report taxa with no reads"
        },
        "report_minimizer_data": {
            "type": "boolean",
            "default": false,
            "description": "Report minimizer data"
        },
        "use_names": {
            "type": "boolean",
            "default": false,
            "description": "Print scientific names instead of just taxids"
        },
        "memory_mapping": {
            "type": "boolean",
            "default": false,
            "description": "Avoids loading database into memory"
        },
        "minimum_hit_groups": {
            "type": "integer",
            "default": 2,
            "description": "Minimum number of hit groups needed to make a call"
        },
        "keep_filtered_reads": {
            "type": "boolean",
            "default": false,
            "description": "Keep filtered reads instead of removing them"
        }
    }
}
