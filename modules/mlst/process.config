process {
    withName: 'MLST' {
        // Optional arguments
        ext.args = {[
            params.scheme ? "--scheme ${params.scheme}" : "",
            "--minid ${params.minid}",
            "--mincov ${params.mincov}",
            "--minscore ${params.minscore}",
            params.nopath ? "--nopath" : ""
        ].join(' ').trim()}
        
        // Environment information
        ext.conda = "bioconda::mlst=2.23.0"
        ext.singularity = "https://depot.galaxyproject.org/singularity/mlst:2.23.0--hdfd78af_1"
        ext.docker = "quay.io/biocontainers/mlst:2.23.0--hdfd78af_1"
        
        ext.prefix = { params.prefix ? params.prefix : "${params.wf == 'bactopia' ? meta.id : meta.name}" }
        ext.rundir = "${params.rundir}"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = params.is_workflow ? params.wf : params.process_name
    }
}
