/*
This file includes default process values for pbptyper.
*/

process {
    withName: 'PBPTYPER' {
        // Optional arguments
        ext.args = [
            "--min-pident ${params.pbptyper_min_pident}",
            "--min-coverage ${params.pbptyper_min_coverage}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.env = [
            toolName: "bioconda::pbptyper=2.0.0".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/pbptyper:2.0.0--hdfd78af_0",
            image: "https://depot.galaxyproject.org/singularity/pbptyper:2.0.0--hdfd78af_0",
            condaDir: "${params.condadir}",
        ]
        
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "pbptyper"
    }
}
