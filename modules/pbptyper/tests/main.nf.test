nextflow_process {
    name "Test PBPTYPER"
    script "../main.nf"
    process "PBPTYPER"
    tag "modules"
    tag "pbptyper"

    test("pbptyper - module - GCF_001457635") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        meta: [name: "GCF_001457635"],
                        fna: file("${params.test_data_dir}/species/streptococcus_pneumoniae/assembly/GCF_001457635/main/assembler/GCF_001457635.fna.gz")
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.blast,
                    record.versions
                ).match() }
            )
        }
    }
}
