nextflow_process {
    name "Test SYLPH_PROFILE"
    script "../main.nf"
    process "SYLPH_PROFILE"
    tag "modules"
    tag "sylph"
    tag "sylph_profile"

    test("sylph - module - SRR2838702 (Paired End)") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "SRR2838702"],
                        r1: file("${params.test_data_dir}/species/portiera/reads/illumina/SRR2838702_R1.fastq.gz"),
                        r2: file("${params.test_data_dir}/species/portiera/reads/illumina/SRR2838702_R2.fastq.gz"),
                        se: null,
                        lr: null
                    )
                )
                input[1] = file("${params.test_data_dir}/datasets/sylph/gtdb-r226-c200-dbv1.syldb")
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.versions
                ).match() }
            )
        }
    }

    test("sylph - module - SRR2838702") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "SRR2838702SE"],
                        r1: null,
                        r2: null,
                        se: file("${params.test_data_dir}/species/portiera/reads/illumina/SRR2838702SE.fastq.gz"),
                        lr: null
                    )
                )
                input[1] = file("${params.test_data_dir}/datasets/sylph/gtdb-r226-c200-dbv1.syldb")
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.versions
                ).match() }
            )
        }
    }
}
