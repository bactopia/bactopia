/*
This file includes default process values for plasmidfinder.
*/

process {
    withName: 'PLASMIDFINDER' {
        // Optional arguments
        ext.args = [
            "-l ${params.pf_mincov}",
            "-t ${params.pf_threshold}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.env = [
            toolName: "bioconda::plasmidfinder=2.1.6=py310hdfd78af_1".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/plasmidfinder:2.1.6--py310hdfd78af_1",
            image: "https://depot.galaxyproject.org/singularity/plasmidfinder:2.1.6--py310hdfd78af_1",
            condaDir: "${params.condadir}",
        ]
        
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "plasmidfinder"
    }
}
