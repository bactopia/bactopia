/*
This file includes default values for shared parameters.
*/

params {
    // Snippy Parameters
    reference = null
    snippy_mapqual = 60
    snippy_basequal = 13
    snippy_mincov = 10
    snippy_minfrac = 0
    snippy_minqual = 100
    snippy_maxsoft = 10
    snippy_bwaopt = null
    snippy_fbopt = null
    snippy_remove_bam = false
    snippy_opts = null

    // only download genbank files when --accession is used
    format = "genbank"
    mix_downloads = false
}
