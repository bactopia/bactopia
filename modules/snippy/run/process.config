/*
This file includes default process values for snippy.
*/

process {
    withName: 'SNIPPY_RUN' {
        // Optional arguments
        ext.args = [
            params.snippy_bwaopt ? "--bwaopt ${params.snippy_bwaopt}" : "",
            params.snippy_fbopt ? "--fbopt ${params.snippy_fbopt}" : "",
            "--mapqual ${params.snippy_mapqual}",
            "--basequal ${params.snippy_basequal}",
            "--mincov ${params.snippy_mincov}",
            "--minfrac ${params.snippy_minfrac}",
            "--minqual ${params.snippy_minqual}",
            "--maxsoft ${params.snippy_maxsoft}",
            params.snippy_opts ? "${params.snippy_opts}" : "",
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.env = [
            toolName: "bioconda::bactopia-variants=1.0.2".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/bactopia-variants:1.0.2--hdfd78af_0",
            image: "https://depot.galaxyproject.org/singularity/bactopia-variants:1.0.2--hdfd78af_0",
            condaDir: "${params.condadir}",
        ]

        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = params.run_name
        ext.logs_subdir = ""
        ext.logs_use_prefix = true
        ext.process_name = "snippy"

        // WF specific parameters
        ext.mincov = params.snippy_mincov
        ext.snippy_remove_bam = params.snippy_remove_bam
        ext.skip_compression = params.skip_compression
    }
}
