nextflow_process {
    name "Test SNIPPY_RUN"
    script "../main.nf"
    process "SNIPPY_RUN"
    tag "modules"
    tag "snippy"
    tag "snippy_run"

    test("snippy_run - module - paired-end - uncompressed") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                // First record input: sample reads
                input[0] = Channel.of(
                    record(
                        _meta: [name: "ERR6005894"],
                        r1: file("${params.test_data_dir}/data/species/shigella_dysenteriae/illumina/ERR6005894_R1.fastq.gz"),
                        r2: file("${params.test_data_dir}/data/species/shigella_dysenteriae/illumina/ERR6005894_R2.fastq.gz"),
                        se: file("${params.test_data_dir}/data/empty/EMPTYSE.fastq.gz"),
                        lr: file("${params.test_data_dir}/data/empty/EMPTY.fastq.gz")
                    )
                )
                // Second record input: reference genome (GenBank format required)
                input[1] = file("${params.test_data_dir}/data/species/portiera/genome/GCF_000292685.gbk")
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert record.tab != null },
                { assert record.txt != null },
                { assert snapshot(
                    record.meta,
                    record.versions
                ).match() }
            )
        }
    }

    test("snippy_run - module - paired-end - compressed") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                // First record input: sample reads
                input[0] = Channel.of(
                    record(
                        _meta: [name: "SRR2838702SE"],
                        r1: file("${params.test_data_dir}/data/empty/EMPTY_R1.fastq.gz"),
                        r2: file("${params.test_data_dir}/data/empty/EMPTY_R2.fastq.gz"),
                        se: file("${params.test_data_dir}/data/species/portiera/illumina/SRR2838702SE.fastq.gz"),
                        lr: file("${params.test_data_dir}/data/empty/EMPTY.fastq.gz")
                    )
                )
                // Second record input: reference genome (GenBank format required)
                input[1] = file("${params.test_data_dir}/data/species/portiera/genome/GCF_000292685.gbk.gz")
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert record.tab != null },
                { assert record.txt != null },
                { assert snapshot(
                    record.meta,
                    record.versions
                ).match() }
            )
        }
    }
}
