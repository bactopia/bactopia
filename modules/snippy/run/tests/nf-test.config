config {
    testsDir "."
    workDir System.getenv("NFT_WORKDIR") ?: ".nf-test"
    configFile "nextflow.config"
    profile "docker"
    // Snippy Parameters (we need to force SNPs)
    options "--is_ci --max_memory 8.GB --snippy_mincov 1 --snippy_minqual 1 --snippy_basequal 1 --snippy_mapqual 1 --snippy_maxsoft 1"

    plugins {
        load "nft-utils@0.0.5"
    }
}
