/*
Bactopia Module Configuration

Defines parameter defaults, the container images, resource labels, and other settings
for the process defined in this directory.
*/

params {
    // Snippy Parameters
    reference = null
    snippy_mapqual = 60
    snippy_basequal = 13
    snippy_mincov = 10
    snippy_minfrac = 0
    snippy_minqual = 100
    snippy_maxsoft = 10
    snippy_bwaopt = null
    snippy_fbopt = null
    snippy_remove_bam = false
    snippy_opts = null

    // only download genbank files when --accession is used
    format = "genbank"
    mix_downloads = false
}

process {
    withName: 'SNIPPY_RUN' {
        // Optional arguments
        ext.args = [
            params.snippy_bwaopt ? "--bwaopt ${params.snippy_bwaopt}" : "",
            params.snippy_fbopt ? "--fbopt ${params.snippy_fbopt}" : "",
            "--mapqual ${params.snippy_mapqual}",
            "--basequal ${params.snippy_basequal}",
            "--mincov ${params.snippy_mincov}",
            "--minfrac ${params.snippy_minfrac}",
            "--minqual ${params.snippy_minqual}",
            "--maxsoft ${params.snippy_maxsoft}",
            params.snippy_opts ? "${params.snippy_opts}" : "",
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::bactopia-variants=1.0.2".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/bactopia-variants:1.0.2--hdfd78af_0"
        ext.image = "https://depot.galaxyproject.org/singularity/bactopia-variants:1.0.2--hdfd78af_0"
        ext.condaDir = "${params.condadir}"

        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = params.run_name
        ext.logs_subdir = ""
        ext.logs_use_prefix = true
        ext.process_name = "snippy"

        // WF specific parameters
        ext.mincov = params.snippy_mincov
        ext.snippy_remove_bam = params.snippy_remove_bam
        ext.skip_compression = params.skip_compression
    }
}
