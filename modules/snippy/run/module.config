params {
    // snippy_run
    format = "genbank"          // bactopia-lint: ignore MC009,JS004
    mix_downloads = false       // bactopia-lint: ignore MC009,JS004
    reference = null            // bactopia-lint: ignore MC009,JS004
    snippy_basequal = 13
    snippy_bwaopt = null
    snippy_fbopt = null
    snippy_mapqual = 60
    snippy_maxsoft = 10
    snippy_mincov = 10
    snippy_minfrac = 0
    snippy_minqual = 100
    snippy_opts = null
    snippy_remove_bam = false
}

process {
    withName: 'SNIPPY_RUN' {
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = params.run_name
        ext.logs_subdir = ""
        ext.logs_use_prefix = true
        ext.process_name = "snippy"

        // Tool arguments
        ext.args = [
            params.snippy_bwaopt ? "--bwaopt ${params.snippy_bwaopt}" : "",
            params.snippy_fbopt ? "--fbopt ${params.snippy_fbopt}" : "",
            "--mapqual ${params.snippy_mapqual}",
            "--basequal ${params.snippy_basequal}",
            "--mincov ${params.snippy_mincov}",
            "--minfrac ${params.snippy_minfrac}",
            "--minqual ${params.snippy_minqual}",
            "--maxsoft ${params.snippy_maxsoft}",
            params.snippy_opts ? "${params.snippy_opts}" : "",
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::bactopia-variants=1.0.4".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/bactopia-variants:1.0.4--hdfd78af_0"
        ext.image = "https://depot.galaxyproject.org/singularity/bactopia-variants:1.0.4--hdfd78af_0"
        ext.condaDir = "${params.condadir}"

        // Module-specific parameters
        ext.mincov = params.snippy_mincov
        ext.snippy_remove_bam = params.snippy_remove_bam
        ext.skip_compression = params.skip_compression
    }
}
