{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "use_pirate": {
            "type": "boolean",
            "default": false,
            "description": "Use PIRATE for pangenome analysis"
        },
        "steps": {
            "type": "string",
            "default": "50,60,70,80,90,95,98",
            "description": "% identity thresholds to use for pangenome construction",
            "hidden": true
        },
        "features": {
            "type": "string",
            "default": "CDS",
            "description": "Choose features to use for pangenome construction",
            "hidden": true
        },
        "para_off": {
            "type": "boolean",
            "default": false,
            "description": "Switch off paralog identification"
        },
        "z": {
            "type": "boolean",
            "default": false,
            "description": "Retain all intermediate files"
        },
        "pan_opt": {
            "type": "string",
            "default": "",
            "description": "Additional PIRATE options",
            "hidden": true
        }
    }
}
