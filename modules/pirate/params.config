/*
This file includes default parameter values.
*/

params {
    // PIRATE
    use_pirate = false
    pirate_steps = '50,60,70,80,90,95,98'	// % identity thresholds to use for pangenome construction
    pirate_features = 'CDS' //	choose features to use for pangenome construction. Multiple may be entered, separated by a comma
    pirate_para_off = false // switch off paralog identification [default: off]
    pirate_z = false // retain all intermediate files
    pirate_pan_opt = '' // Allows the params below to be given as a string
}
