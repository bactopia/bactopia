process {
    withName: 'PIRATE' {
        // Optional arguments
        ext.args = {[
            "--steps ${params.steps}",
            "--features ${params.features}",
            params.para_off ? "--para-off" : "",
            params.z ? "-z" : "",
            params.pan_opt
        ].join(' ').trim()}
        
        // Environment information
        ext.conda = "bioconda::pirate=1.0.5 bioconda::perl-bioperl=1.7.2"
        ext.singularity = "https://depot.galaxyproject.org/singularity/pirate%3A1.0.5--hdfd78af_0"
        ext.docker = "quay.io/biocontainers/pirate:1.0.5--hdfd78af_0"
        
        ext.prefix = { params.prefix ? params.prefix : "${params.wf == 'bactopia' ? meta.id : meta.name}" }
        ext.rundir = "${params.rundir}"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = params.is_workflow ? params.wf : params.process_name
    }
}
