/*
This file includes default process values for spatyper.
*/

process {
    withName: 'SPATYPER' {
        // Optional arguments
        ext.args = [
            params.do_enrich ? "--do_enrich" : ""
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.env = [
            toolName: "bioconda::spatyper=0.3.3".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/spatyper:0.3.3--pyhdfd78af_3",
            image: "https://depot.galaxyproject.org/singularity/spatyper:0.3.3--pyhdfd78af_3",
            condaDir: "${params.condadir}",
        ]
        
        ext.wf = params.wf
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "spatyper"
    }
}
