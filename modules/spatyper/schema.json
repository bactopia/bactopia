{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/bactopia/bactopia/master/modules/spatyper/schema.json",
    "title": "SpaTyper Module",
    "description": "A module for spa typing Staphylococcus aureus",
    "type": "object",
    "$defs": {
        "spatyper_parameters": {
            "title": "spaTyper Parameters",
            "type": "object",
            "description": "",
            "default": "",
            "fa_icon": "fas fa-exclamation-circle",
            "properties": {
                "spatyper_repeats": {
                    "type": "string",
                    "description": "List of spa repeats",
                    "fa_icon": "fas fa-font",
                    "hidden": true
                },
                "spatyper_repeat_order": {
                    "type": "string",
                    "description": "List spa types and order of repeats",
                    "fa_icon": "fas fa-font",
                    "hidden": true
                },
                "spatyper_do_enrich": {
                    "type": "boolean",
                    "default": false,
                    "description": "Do PCR product enrichment",
                    "fa_icon": "fas fa-toggle-on"
                }
            }
        }
    },
    "allOf": [
        {
            "$ref": "#/$defs/spatyper_parameters"
        }
    ]
}
