params {
    // seqsero2
    seqsero2_bwa_mode = 'mem'
    seqsero2_input_type = 'assembly'
    seqsero2_run_mode = 'k'
}

process {
    withName: 'SEQSERO2' {
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "seqsero2"

        // Tool arguments
        ext.args = [
            "-m ${params.seqsero2_run_mode}",
            params.seqsero2_input_type == "assembly" ? "-t 4" : "-t 2",
            "-b ${params.seqsero2_bwa_mode}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::seqsero2=1.3.2".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/seqsero2:1.3.2--pyhdfd78af_0"
        ext.image = "https://depot.galaxyproject.org/singularity/seqsero2:1.3.2--pyhdfd78af_0"
        ext.condaDir = "${params.condadir}"
    }
}
