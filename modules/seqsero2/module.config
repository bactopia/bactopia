params {
    // SeqSero2
    seqsero2_run_mode = 'k'
    seqsero2_input_type = 'assembly'
    seqsero2_bwa_mode = 'mem'
}

process {
    withName: 'SEQSERO2' {
        // Optional arguments
        ext.args = [
            "-m ${params.seqsero2_run_mode}",
            params.seqsero2_input_type == "assembly" ? "-t 4" : "-t 2",
            "-b ${params.seqsero2_bwa_mode}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.toolName = "bioconda::seqsero2=1.3.1".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/seqsero2:1.3.1--pyhdfd78af_1"
        ext.image = "https://depot.galaxyproject.org/singularity/seqsero2:1.3.1--pyhdfd78af_1"
        ext.condaDir = "${params.condadir}"
        
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "seqsero2"
    }
}
