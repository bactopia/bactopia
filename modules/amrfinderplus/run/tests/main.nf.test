nextflow_process {
    name "Test AMRFINDERPLUS_RUN"
    script "../main.nf"
    process "AMRFINDERPLUS_RUN"
    tag "modules"
    tag "amrfinderplus"
    tag "amrfinderplus_run"

    test("amrfinderplus_run - module - SRR2838702 - uncompressed") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        meta: [name: "SRR2838702"],
                        fna: file("${params.test_data_dir}/species/portiera/uncompressed/SRR2838702/main/annotator/prokka/SRR2838702.fna"),
                        faa: file("${params.test_data_dir}/species/portiera/uncompressed/SRR2838702/main/annotator/prokka/SRR2838702.faa"),
                        gff: file("${params.test_data_dir}/species/portiera/uncompressed/SRR2838702/main/annotator/prokka/SRR2838702.gff")
                    )
                )
                input[1] = file("${params.test_data_dir}/datasets/amrfinderplus/amrfinderplus.tar.gz")
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.report,
                    record.versions
                ).match() }
            )
        }
    }

    test("amrfinderplus_run - module - SRR2838702 - compressed") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        meta: [name: "SRR2838702"],
                        fna: file("${params.test_data_dir}/species/portiera/reads/illumina/SRR2838702.fna.gz"),
                        faa: file("${params.test_data_dir}/species/portiera/reads/illumina/SRR2838702.faa.gz"),
                        gff: file("${params.test_data_dir}/species/portiera/reads/illumina/SRR2838702.gff.gz")
                    )
                )
                input[1] = file("${params.test_data_dir}/datasets/amrfinderplus/amrfinderplus.tar.gz")
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.report,
                    record.versions
                ).match() }
            )
        }
    }
}
