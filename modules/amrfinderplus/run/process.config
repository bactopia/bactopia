/*
This file includes default process values for amrfinderplus.
*/

process {
    withName: 'AMRFINDERPLUS_RUN' {
        // Optional arguments
        ext.args = [
            params.amrfinder_report_common ? "--report_common" : "",
            params.amrfinder_report_all_equal ? "--report_all_equal" : "",
            params.amrfinder_organism ? "--organism ${params.organism}" : "",
            params.amrfinder_noplus ? "" : "--plus",
            "--ident_min ${params.amrfinder_ident_min}",
            "--coverage_min ${params.amrfinder_coverage_min}",
            "--translation_table ${params.amrfinder_translation_table}",
            "${params.amrfinder_opts}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.env = [
            toolName: "bioconda::ncbi-amrfinderplus=4.0.19".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/ncbi-amrfinderplus:4.0.19--hf69ffd2_0",
            image: "https://depot.galaxyproject.org/singularity/ncbi-amrfinderplus:4.0.19--hf69ffd2_0",
            condaDir: "${params.condadir}",
        ]

        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "amrfinderplus"
    }
}
