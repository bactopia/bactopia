// bactopia-lint: ignore JS005
params {
    // amrfinderplus_run
    amrfinderplus_coverage_min = 0.5
    amrfinderplus_db = ""
    amrfinderplus_ident_min = -1
    amrfinderplus_noplus = false
    amrfinderplus_opts = ""
    amrfinderplus_organism = ""
    amrfinderplus_report_all_equal = false
    amrfinderplus_report_common = false
    amrfinderplus_translation_table = 11
}

process {
    withName: 'AMRFINDERPLUS_RUN' {
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "amrfinderplus"

        // Tool arguments
        ext.args = [
            params.amrfinderplus_report_common ? "--report_common" : "",
            params.amrfinderplus_report_all_equal ? "--report_all_equal" : "",
            params.amrfinderplus_organism ? "--organism ${params.amrfinderplus_organism}" : "",
            params.amrfinderplus_noplus ? "" : "--plus",
            "--ident_min ${params.amrfinderplus_ident_min}",
            "--coverage_min ${params.amrfinderplus_coverage_min}",
            "--translation_table ${params.amrfinderplus_translation_table}",
            "${params.amrfinderplus_opts}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::ncbi-amrfinderplus=4.2.7".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/ncbi-amrfinderplus:4.2.7--hf69ffd2_0"
        ext.image = "https://depot.galaxyproject.org/singularity/ncbi-amrfinderplus:4.2.7--hf69ffd2_0"
        ext.condaDir = "${params.condadir}"
    }
}
