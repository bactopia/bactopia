{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/bactopia/bactopia/master/modules/amrfinderplus/run/schema.json",
    "title": "AMRFinder+ Module",
    "description": "A module to identify antimicrobial resistance in genes or proteins",
    "type": "object",
    "$defs": {
        "amrfinderplus_parameters": {
            "title": "AMRFinder+ Parameters",
            "type": "object",
            "description": "",
            "default": "",
            "fa_icon": "fas fa-exclamation-circle",
            "properties": {
                "amrfinderplus_ident_min": {
                    "type": "number",
                    "default": -1,
                    "description": "Minimum proportion of identical amino acids in alignment for hit (0..1)",
                    "fa_icon": "fas fa-expand-arrows-alt",
                    "hidden": true
                },
                "amrfinderplus_coverage_min": {
                    "type": "number",
                    "default": 0.5,
                    "description": "Minimum coverage of the reference protein (0..1)",
                    "fa_icon": "fas fa-expand-arrows-alt",
                    "hidden": true
                },
                "amrfinderplus_organism": {
                    "type": "string",
                    "description": "Taxonomy group to run additional screens against",
                    "fa_icon": "fas fa-expand-arrows-alt",
                    "hidden": true
                },
                "amrfinderplus_translation_table": {
                    "type": "integer",
                    "default": 11,
                    "description": "NCBI genetic code for translated BLAST",
                    "fa_icon": "fas fa-expand-arrows-alt",
                    "hidden": true
                },
                "amrfinderplus_noplus": {
                    "type": "boolean",
                    "default": false,
                    "description": "Disable running AMRFinder+ with the --plus option",
                    "fa_icon": "fas fa-expand-arrows-alt",
                    "hidden": true
                },
                "amrfinderplus_report_common": {
                    "type": "boolean",
                    "default": false,
                    "description": "Report proteins common to a taxonomy group",
                    "fa_icon": "fas fa-expand-arrows-alt",
                    "hidden": true
                },
                "amrfinderplus_report_all_equal": {
                    "type": "boolean",
                    "default": false,
                    "description": "Report all equally-scoring BLAST and HMM matches",
                    "fa_icon": "fas fa-expand-arrows-alt",
                    "hidden": true
                },
                "amrfinderplus_opts": {
                    "type": "string",
                    "description": "Extra AMRFinder+ options in quotes.",
                    "fa_icon": "fas fa-expand-arrows-alt"
                },
                "amrfinderplus_db": {
                    "type": "string",
                    "default": "",
                    "description": "A custom AMRFinder+ database to use, either a tarball or a folder",
                    "fa_icon": "fas fa-expand-arrows-alt",
                    "hidden": true
                }
            }
        }
    },
    "allOf": [
        {
            "$ref": "#/$defs/amrfinderplus_parameters"
        }
    ]
}
