/*
This file includes default process values for amrfinderplus update.
*/

process {
    withName: 'AMRFINDERPLUS_UPDATE' {
        storeDir = params.datasets_cache
        publishDir = params.datasets_cache

        // Environment information
        ext.env = [
            toolName: "bioconda::ncbi-amrfinderplus=4.0.19".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/ncbi-amrfinderplus:4.0.19--hf69ffd2_0",
            image: "https://depot.galaxyproject.org/singularity/ncbi-amrfinderplus:4.0.19--hf69ffd2_0",
            condaDir: "${params.condadir}",
        ]

        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "amrfinderplus_update"
    }
}
