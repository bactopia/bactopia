/*
Bactopia Module Configuration

Defines parameter defaults, the container images, resource labels, and other settings
for the process defined in this directory.
*/

params {
    // ClonalFrameML
    skip_recombination = false
    clonal_emsim = 100
    clonal_opts = ""
}

process {
    withName: 'CLONALFRAMEML' {
        // Optional arguments
        ext.args = [
            "-emsim ${params.clonal_emsim}", 
            "${params.clonal_opts}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::clonalframeml=1.13".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/clonalframeml:1.13--h4675bf2_2"
        ext.image = "https://depot.galaxyproject.org/singularity/clonalframeml:1.13--h4675bf2_2"
        ext.condaDir = "${params.condadir}"

        ext.wf = params.wf
        ext.scope = "run"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "clonalframeml"
    }
}
