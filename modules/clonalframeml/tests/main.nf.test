nextflow_process {
    name "Test CLONALFRAMEML"
    script "../main.nf"
    process "CLONALFRAMEML"
    tag "modules"
    tag "clonalframeml"

    test("clonalframeml - module - portiera - uncompressed") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "portiera"],
                        aln: file("${params.test_data_dir}/datasets/generic/genome/genome.aln"),
                        nwk: file("${params.test_data_dir}/datasets/generic/genome/genome.aln.nwk")
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.em,
                    record.status,
                    record.nwk,
                    record.versions
                ).match() }
            )
        }
    }

    test("clonalframeml - module - portiera - compressed") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "portiera"],
                        aln: file("${params.test_data_dir}/datasets/generic/genome/genome.aln.gz"),
                        nwk: file("${params.test_data_dir}/datasets/generic/genome/genome.aln.nwk")
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.em,
                    record.status,
                    record.nwk,
                    record.versions
                ).match() }
            )
        }
    }
}
