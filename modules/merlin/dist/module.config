/*
Bactopia Module Configuration

Defines parameter defaults, the container images, resource labels, and other settings
for the process defined in this directory.
*/

params {
    // Mash (dist)
    //mash_sketch = null // TODO: Remove when Path? is fixed
    mash_seed = 42
    mash_table = false
    mash_m = 1
    mash_w = 0.01
    mash_max_p = 1.0
    mash_max_dist = 1.0 // report all
    merlin_dist = 0.10 // report only close matches
    mash_use_fastqs = false
    full_merlin = false
}

process {
    withName: 'MERLIN_DIST' {
        // Optional arguments
        ext.args = [
            "-v ${params.mash_max_p}",
            params.ask_merlin || params.wf == "merlin" ? "-d ${params.merlin_dist}" : "-d ${params.mash_max_dist}",
            "-w ${params.mash_w}",
            "-m ${params.mash_m}",
            "-S ${params.mash_seed}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::mash=2.3".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/mash:2.3--he348c14_1"
        ext.image = "https://depot.galaxyproject.org/singularity/mash:2.3--he348c14_1"
        ext.condaDir = "${params.condadir}"

        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = params.run_name
        ext.logs_subdir = ""
        ext.logs_use_prefix = true
        ext.process_name = "mashdist"
        
        // WF specific parameters
        ext.full_merlin = params.full_merlin
    }
}
