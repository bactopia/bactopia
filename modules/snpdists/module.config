params {
    // snpdists
    snpdists_a = false
    snpdists_b = false
    snpdists_csv = false
    snpdists_k = false
}

process {
    withName: 'SNPDISTS' {
        ext.wf = params.wf
        ext.scope = "run"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "snpdists"

        // Tool arguments
        ext.args = [
            params.snpdists_a ? "-a" : "",
            params.snpdists_b ? "-b" : "",
            params.snpdists_csv ? "-c" : "",
            params.snpdists_k ? "-k" : ""
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::snp-dists=1.2.0".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/snp-dists:1.2.0--h577a1d6_0"
        ext.image = "https://depot.galaxyproject.org/singularity/snp-dists:1.2.0--h577a1d6_0"
        ext.condaDir = "${params.condadir}"
    }
}
