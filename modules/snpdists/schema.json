{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "id": "https://raw.githubusercontent.com/bactopia/bactopia/master/modules/snpdists/schema.json",
    "title": "bactopia/modules/snpdists module",
    "description": "A Module to run snp-dists for pairwise SNP distance calculations",
    "type": "object",
    "properties": {
        "a": {
            "type": "boolean",
            "default": false,
            "description": "Count all differences not just [AGTC]",
            "fa_icon": "fas fa-hashtag"
        },
        "b": {
            "type": "boolean",
            "default": false,
            "description": "Keep top left corner cell",
            "fa_icon": "fas fa-hashtag"
        },
        "csv": {
            "type": "boolean",
            "default": false,
            "description": "Output CSV instead of TSV",
            "fa_icon": "fas fa-hashtag"
        },
        "k": {
            "type": "boolean",
            "default": false,
            "description": "Keep case, don't uppercase all letters",
            "fa_icon": "fas fa-hashtag"
        }
    }
}
