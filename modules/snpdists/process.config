/*
This file includes default process values for snpdists.
*/

process {
    withName: 'SNPDISTS' {
        // Optional arguments
        ext.args = [
            params.snpdists_a ? "-a" : "",
            params.snpdists_b ? "-b" : "",
            params.snpdists_csv ? "-c" : "",
            params.snpdists_k ? "-k" : ""
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.toolName = "bioconda::snp-dists=0.8.2".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/snp-dists:0.8.2--h7132678_1"
        ext.image = "https://depot.galaxyproject.org/singularity/snp-dists:0.8.2--h7132678_1"
        ext.condaDir = "${params.condadir}"
        
        ext.wf = params.wf
        ext.scope = "run"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "snpdists"
    }
}
