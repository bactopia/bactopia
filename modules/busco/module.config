params {
    // busco
    busco_augustus_long = false
    busco_augustus_parameters = ""
    busco_augustus_species = ""
    busco_evalue = "1e-03"
    busco_limit = 3
    busco_lineage = "bacteria_odb10"
    busco_metaeuk_parameters = ""
    busco_metaeuk_rerun_parameters = ""
    busco_use_augustus = false
    run_name = "${params.workflow.name}-${params.busco_lineage}"
}

process {
    withName: 'BUSCO' {
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = params.busco_lineage
        ext.logs_subdir = ""
        ext.logs_use_prefix = true
        ext.process_name = "busco"

        // Tool arguments
        ext.args = [
            params.busco_metaeuk_parameters ? "--metaeuk_parameters '${params.busco_metaeuk_parameters}'" : "",
            params.busco_metaeuk_rerun_parameters ? "--metaeuk_rerun_parameters '${params.busco_metaeuk_rerun_parameters}'" : "",
            params.busco_use_augustus ? "--augustus" : "",
            params.busco_augustus_parameters ? "--augustus_parameters '${params.busco_augustus_parameters}'" : "",
            params.busco_augustus_species ? "--augustus_species '${params.busco_augustus_species}'" : "",
            params.busco_augustus_long ? "--long" : "",
            "--evalue ${params.busco_evalue}",
            "--limit ${params.busco_limit}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::busco=6.0.0".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/busco:6.0.0--pyhdfd78af_3"
        ext.image = "https://depot.galaxyproject.org/singularity/busco:6.0.0--pyhdfd78af_3"
        ext.condaDir = "${params.condadir}"

        // Module-specific parameters
        ext.busco_lineage = params.busco_lineage
    }
}
