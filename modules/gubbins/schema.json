{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/bactopia/bactopia/main/modules/gubbins/schema.json",
    "title": "Gubbins Parameters",
    "description": "The schema for Gubbins parameters",
    "type": "object",
    "properties": {
        "iterations": {
            "type": "integer",
            "default": 5,
            "description": "Maximum number of iterations"
        },
        "min_snps": {
            "type": "integer",
            "default": 3,
            "description": "Minimum number of SNPs to identify a recombination block"
        },
        "min_window_size": {
            "type": "integer",
            "default": 100,
            "description": "Minimum window size"
        },
        "max_window_size": {
            "type": "integer",
            "default": 10000,
            "description": "Maximum window size"
        },
        "filter_percentage": {
            "type": "number",
            "default": 25.0,
            "description": "Filter percentage for taxa to be included"
        },
        "remove_identical_sequences": {
            "type": "boolean",
            "default": false,
            "description": "Remove identical sequences"
        },
        "skip_recombination": {
            "type": "boolean",
            "default": false,
            "description": "Skip recombination detection"
        },
        "gubbin_opts": {
            "type": "string",
            "default": "",
            "description": "Additional Gubbins options"
        }
    }
}
