/*
Bactopia Module Configuration

Defines parameter defaults, the container images, resource labels, and other settings
for the process defined in this directory.
*/

params {
    // Gubbins
    gubbins_iterations = 5
    gubbins_min_snps = 3
    gubbins_min_window_size = 100
    gubbins_max_window_size = 10000
    gubbins_filter_percentage = 25.0
    gubbins_remove_identical_sequences = false
    skip_recombination = false
    gubbins_opts = ""
}

process {
    withName: 'GUBBINS' {
        // Optional arguments
        ext.args = [
            params.gubbins_remove_identical_sequences ? "--remove-identical-sequences" : "",
            "--iterations ${params.gubbins_iterations}",
            "--min-snps ${params.gubbins_min_snps}",
            "--min-window-size ${params.gubbins_min_window_size}",
            "--max-window-size ${params.gubbins_max_window_size}",
            "--filter-percentage ${params.gubbins_filter_percentage }",
            "${params.gubbin_opts}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.toolName = "bioconda::gubbins=3.4".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/gubbins:3.4--py39pl5321he4a0461_0"
        ext.image = "https://depot.galaxyproject.org/singularity/gubbins:3.4--py39pl5321he4a0461_0"
        ext.condaDir = "${params.condadir}"
        
        ext.wf = params.wf
        ext.scope = "run"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "gubbins"
    }
}
