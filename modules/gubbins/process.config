/*
This file includes default process values for gubbins.
*/

process {
    withName: 'GUBBINS' {
        // Optional arguments
        ext.args = [
            params.gubbins_remove_identical_sequences ? "--remove-identical-sequences" : "",
            "--iterations ${params.gubbins_iterations}",
            "--min-snps ${params.gubbins_min_snps}",
            "--min-window-size ${params.gubbins_min_window_size}",
            "--max-window-size ${params.gubbins_max_window_size}",
            "--filter-percentage ${params.gubbins_filter_percentage }",
            "${params.gubbin_opts}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.env = [
            toolName: "bioconda::gubbins=3.4".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/gubbins:3.4--py39pl5321he4a0461_0",
            image: "https://depot.galaxyproject.org/singularity/gubbins:3.4--py39pl5321he4a0461_0",
            condaDir: "${params.condadir}",
        ]
        
        ext.wf = params.wf
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "gubbins"
    }
}
