params {
    // prokka
    // prokka_prodigal_tf = null // TODO: Remove when Path? is fixed
    prokka_centre = 'Bactopia'
    prokka_compliant = false
    prokka_coverage = 80
    prokka_debug = false
    prokka_evalue = "1e-09"
    prokka_opts = ""
    prokka_proteins = "${projectDir}/data/proteins.faa"
}

process {
    withName: 'PROKKA' {
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "prokka"

        // Tool arguments
        ext.args = [
            "--evalue ${params.prokka_evalue}",
            "--coverage ${params.prokka_coverage}",
            "--centre ${params.prokka_centre}",
            "${params.prokka_opts}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::prokka=1.15.6".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/prokka:1.15.6--pl5321hdfd78af_0"
        ext.image = "https://depot.galaxyproject.org/singularity/prokka:1.15.6--pl5321hdfd78af_0"
        ext.condaDir = "${params.condadir}"

        // Module-specific parameters
        ext.compliant = params.prokka_compliant
        ext.centre = params.prokka_centre
        ext.prokka_debug = params.prokka_debug
        ext.skip_compression = params.skip_compression
    }
}
