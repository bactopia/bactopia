/*
This file includes default process values for prokka.
*/

process {
    withName: 'PROKKA' {
        // Optional arguments
        ext.args = [
            params.prokka_opts,
            "--evalue ${params.prokka_evalue}",
            "--coverage ${params.prokka_coverage}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.env = [
            toolName: "bioconda::prokka=1.14.6".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "quay.io/biocontainers/prokka:1.14.6--pl5321hdfd78af_5",
            image: "https://depot.galaxyproject.org/singularity/prokka:1.14.6--pl5321hdfd78af_5",
            condaDir: "${params.condadir}",
        ]
        
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "prokka"
    }
}
