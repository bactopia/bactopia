/*
This file includes default process configurations
*/

process {
    withName: 'PROKKA' {
        // Optional arguments
        ext.args = {[
            params.prokka_opts,
            "--evalue ${params.prokka_evalue}",
            "--coverage ${params.prokka_coverage}"
        ].join(' ').trim()}
        
        // Environment information
        ext.conda = "${moduleDir}/environment.yml"
        ext.singularity = 'https://depot.galaxyproject.org/singularity/prokka:1.14.6--pl5321hdfd78af_5'
        ext.docker = 'quay.io/biocontainers/prokka:1.14.6--pl5321hdfd78af_5'

        // Misc
        ext.prefix = { "${meta.id}" }
        ext.rundir = "${task.process}"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = { "${task.process}".replace(":", "_") }
    }
}
