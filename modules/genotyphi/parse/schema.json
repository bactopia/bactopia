{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/bactopia/bactopia/master/modules/genotyphi/parse/schema.json",
    "title": "GenoTyphi Module",
    "description": "A module to genotype Salmonella Typhi from Mykrobe outputs",
    "type": "object",
    "$defs": {
        "genotyphi_parameters": {
            "title": "GenoTyphi Parameters",
            "type": "object",
            "description": "",
            "default": "",
            "fa_icon": "fas fa-exclamation-circle",
            "properties": {
                "kmer": {
                    "type": "integer",
                    "default": 21,
                    "description": "K-mer length"
                },
                "min_depth": {
                    "type": "integer",
                    "default": 1,
                    "description": "Minimum depth"
                },
                "model": {
                    "type": "string",
                    "default": "kmer_count",
                    "description": "Genotype model used.",
                    "enum": [
                        "kmer_count",
                        "median_depth"
                    ]
                },
                "report_all_calls": {
                    "type": "boolean",
                    "default": false,
                    "description": "Report all calls"
                },
                "mykrobe_opts": {
                    "type": "string",
                    "default": "",
                    "description": "Extra Mykrobe options in quotes"
                }
            }
        }
    },
    "allOf": [
        {
            "$ref": "#/$defs/genotyphi_parameters"
        }
    ]
}
