// NOTE: This test requires a Mykrobe JSON output file as input.
// To make this test functional:
//   1. Run `mykrobe predict --species typhi --format json_and_csv --sample test_typhi
//      --output test_typhi --seq <typhi_reads>` to produce a test_typhi.json file
//   2. Place the JSON at: $BACTOPIA_TESTS/data/datasets/genotyphi/test_typhi.json
//   3. Uncomment the input and assertion blocks below
// The JSON is parsed by `parse_typhi_mykrobe.py --jsons <json> --prefix <name>` which
// produces a <prefix>_predictResults.tsv that is renamed to <prefix>.tsv.
nextflow_process {
    name "Test GENOTYPHI_PARSE"
    script "../main.nf"
    process "GENOTYPHI_PARSE"
    tag "modules"
    tag "genotyphi"
    tag "genotyphi_parse"

    test("genotyphi_parse - module - stub") {

        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                // TODO: Activate once a Mykrobe JSON fixture is available at:
                //   \${params.test_data_dir}/data/datasets/genotyphi/test_typhi.json
                // input[0] = Channel.of(
                //     record(
                //         _meta: [name: "test_typhi"],
                //         json: file("\${params.test_data_dir}/data/datasets/genotyphi/test_typhi.json")
                //     )
                // )
                input[0] = Channel.empty()
                """
            }
        }

        then {
            // TODO: Replace with full assertions once fixture is available:
            // def record = process.out[0][0]
            // assertAll(
            //     { assert process.success },
            //     { assert snapshot(
            //         record.meta,
            //         record.tsv,
            //         record.versions
            //     ).match() }
            // )
            assertAll(
                { assert process.success }
            )
        }
    }
}
