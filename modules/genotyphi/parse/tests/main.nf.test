nextflow_process {
    name "Test GENOTYPHI_PARSE"
    script "../main.nf"
    process "GENOTYPHI_PARSE"
    tag "modules"
    tag "genotyphi"
    tag "genotyphi_parse"

    test("genotyphi_parse - module - SRR2838702") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "SRR2838702"],
                        json: file("${params.test_data_dir}/datasets/genotyphi/test.json")
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.versions
                ).match() }
            )
        }
    }
}
