/*
Bactopia Module Configuration

Defines parameter defaults, the container images, resource labels, and other settings
for the process defined in this directory.
*/

params {
    // meningotype
    meningotype_finetype = false
    meningotype_porB = false
    meningotype_bast = false
    meningotype_mlst = false
    meningotype_all = false
}

process {
    withName: 'MENINGOTYPE' {
        // Optional arguments
        ext.args = [
            params.meningotype_finetype ? "--finetype" : "",
            params.meningotype_porB ? "--porB" : "",
            params.meningotype_bast ? "--bast" : "",
            params.meningotype_mlst ? "--mlst" : "",
            params.meningotype_all ? "--all" : ""
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.toolName = "bioconda::meningotype=0.8.5".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/meningotype:0.8.5--pyhdfd78af_0"
        ext.image = "https://depot.galaxyproject.org/singularity/meningotype:0.8.5--pyhdfd78af_0"
        ext.condaDir = "${params.condadir}"
        
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "meningotype"
    }
}
