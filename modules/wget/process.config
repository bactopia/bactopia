process {
    withName: 'WGET' {
        storeDir = params.datasets_cache

        // Optional arguments
        ext.args = [
            params.no_check_certificate ? "--no-check-certificate" : "",
            "${params.wget_opts}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.env = [
            toolName: "bioconda::gnu-wget=1.18".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/gnu-wget:1.18--h36e9172_9",
            image: "https://depot.galaxyproject.org/singularity/gnu-wget:1.18--h36e9172_9",
            condaDir: "${params.condadir}",
        ]

        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "wget"
    }
}
