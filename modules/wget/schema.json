{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/bactopia/bactopia/master/modules/custom/wget/schema.json",
    "title": "Custom Wget Module",
    "description": "A module to download files using wget",
    "type": "object",
    "$defs": {
        "wget_parameters": {
            "title": "Wget Parameters",
            "type": "object",
            "description": "",
            "default": "",
            "fa_icon": "fas fa-exclamation-circle",
            "properties": {
                "no_check_certificate": {
                    "type": "boolean",
                    "default": false,
                    "description": "Don't validate the server's certificate",
                    "fa_icon": "fas fa-shield-alt"
                },
                "wget_opts": {
                    "type": "string",
                    "description": "Additional wget options",
                    "default": ""
                }
            }
        }
    },
    "allOf": [
        {
            "$ref": "#/$defs/wget_parameters"
        }
    ]
}
