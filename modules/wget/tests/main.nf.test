nextflow_process {
    name "Test WGET"
    script "../main.nf"
    process "WGET"
    tag "modules"
    tag "wget"

    // This test requires internet access to download files.
    // It should only be run in environments with network connectivity.

    test("wget - module - download small file") {

        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    [
                        name: "test-download",
                        url: "https://raw.githubusercontent.com/bactopia/bactopia-tests/main/data/README.md",
                        save_as: "README.md"
                    ]
                )
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.download[0].name == "README.md" }
            )
        }
    }
}
