/*
This file includes default process values for pneumocat.
*/

process {
    withName: 'PNEUMOCAT' {
        // Optional arguments
        ext.args = ""
        
        // Environment information
        ext.env = [
            toolName: "bioconda::pneumocat=1.2.1".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "quay.io/biocontainers/pneumocat:1.2.1--pyhdfd78af_2",
            image: "https://depot.galaxyproject.org/singularity/pneumocat:1.2.1--pyhdfd78af_2",
            condaDir: "${params.condadir}",
        ]
        
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "pneumocat"
    }
}
