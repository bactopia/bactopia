params {
    // PneumoCaT has no opts
}

process {
    withName: 'PNEUMOCAT' {
        // Optional arguments
        ext.args = ""
        
        // Environment information
        ext.toolName = "bioconda::pneumocat=1.2.1".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/pneumocat:1.2.1--hdfd78af_1"
        ext.image = "https://depot.galaxyproject.org/singularity/pneumocat:1.2.1--hdfd78af_1"
        ext.condaDir = "${params.condadir}"
        
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "pneumocat"
    }
}
