/*
Bactopia Module Configuration

Defines parameter defaults, the container images, resource labels, and other settings
for the process defined in this directory.
*/

params {
    // No parameters for this module
}

process {
    withName: 'PNEUMOCAT' {
        // Optional arguments
        ext.args = ""
        
        // Environment information
        ext.toolName = "bioconda::pneumocat=1.2.1".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/pneumocat:1.2.1--hdfd78af_1"
        ext.image = "https://depot.galaxyproject.org/singularity/pneumocat:1.2.1--hdfd78af_1"
        ext.condaDir = "${params.condadir}"
        
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "pneumocat"
    }
}
