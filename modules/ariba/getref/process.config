/*
This file includes default process values for ariba getref.
*/

process {
    withName: 'ARIBA_GETREF' {
        // Environment information
        ext.env = [
            toolName: "bioconda::ariba=2.14.6".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/ariba:2.14.6--py39h67e14b5_4",
            image: "https://depot.galaxyproject.org/singularity/ariba:2.14.6--py39h67e14b5_4",
            condaDir: "${params.condadir}",
        ]

        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "ariba_getref"
    }
}
