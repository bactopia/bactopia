/*
This file includes default process values for ariba.
*/

process {
    withName: 'ARIBA_RUN' {
        // Optional arguments
        ext.args = [
            params.spades_options ? "--spades_options '${params.spades_options}'" : "",
            params.ariba_no_clean ? "--noclean" : "",
            "--nucmer_min_id ${params.nucmer_min_id}",
            "--nucmer_min_len ${params.nucmer_min_len}",
            "--nucmer_breaklen ${params.nucmer_breaklen}",
            "--assembly_cov ${params.assembly_cov}",
            "--min_scaff_depth ${params.min_scaff_depth}",
            "--assembled_threshold ${params.assembled_threshold}",
            "--gene_nt_extend ${params.gene_nt_extend}",
            "--unique_threshold ${params.unique_threshold}",
            "--force",
            "--verbose",
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.env = [
            toolName: "bioconda::ariba=2.14.6".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/ariba:2.14.6--py39h67e14b5_4",
            image: "https://depot.galaxyproject.org/singularity/ariba:2.14.6--py39h67e14b5_4",
            condaDir: "${params.condadir}",
        ]

        ext.rundir = params.rundir
        ext.subdir = params.ariba_db
        ext.logs_subdir = ""
        ext.process_name = "ariba"
    }

    withName: 'CSVTK_CONCAT_REPORT' {
        ext.args = '-C "$" --lazy-quotes'
        ext.logs_subdir = "${params.ariba_db}-report"
        ext.prefix = "ariba-${params.ariba_db}"
        ext.process_name = params.merge_folder
        ext.subdir = params.ariba_db
    }

    withName: 'CSVTK_CONCAT_SUMMARY' {
        ext.args = '--lazy-quotes'
        ext.logs_subdir = "${params.ariba_db}-summary"
        ext.prefix = "ariba-${params.ariba_db}"
        ext.process_name = params.merge_folder
        ext.subdir = params.ariba_db
    }
}
