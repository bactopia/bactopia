/*
Bactopia Module Configuration

Defines parameter defaults, the container images, resource labels, and other settings
for the process defined in this directory.
*/

params {
    // Ariba Run Parameters
    ariba_db = null
    ariba_nucmer_min_id = 90
    ariba_nucmer_min_len = 20
    ariba_nucmer_breaklen = 200
    ariba_assembly_cov = 50
    ariba_min_scaff_depth = 10
    ariba_spades_options = null
    ariba_assembled_threshold = 0.95
    ariba_gene_nt_extend = 30
    ariba_unique_threshold = 0.03
    ariba_no_clean = false
    run_name = "${params.workflow.name}-${params.ariba_db}"
}

process {
    withName: 'ARIBA_GETREF|ARIBA_RUN' {
        // Environment information
        ext.toolName = "bioconda::ariba=2.14.7".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/ariba:2.14.7--py310hd9fea4d_0"
        ext.image = "https://depot.galaxyproject.org/singularity/ariba:2.14.7--py310hd9fea4d_0"
        ext.condaDir = "${params.condadir}"

        ext.wf = params.wf
    }

    withName: 'ARIBA_RUN' {
        // Optional arguments
        ext.args = [
            params.ariba_spades_options ? "--spades_options '${params.ariba_spades_options}'" : "",
            params.ariba_no_clean ? "--noclean" : "",
            "--nucmer_min_id ${params.ariba_nucmer_min_id}",
            "--nucmer_min_len ${params.ariba_nucmer_min_len}",
            "--nucmer_breaklen ${params.ariba_nucmer_breaklen}",
            "--assembly_cov ${params.ariba_assembly_cov}",
            "--min_scaff_depth ${params.ariba_min_scaff_depth}",
            "--assembled_threshold ${params.ariba_assembled_threshold}",
            "--gene_nt_extend ${params.ariba_gene_nt_extend}",
            "--unique_threshold ${params.ariba_unique_threshold}",
            "--force",
            "--verbose",
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        ext.scope = "sample"
        ext.subdir = params.ariba_db
        ext.logs_subdir = params.ariba_db
        ext.process_name = "ariba"
    }

    withName: 'ARIBA_GETREF' {
        storeDir = params.datasets_cache

        ext.scope = "run"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "ariba_getref"
    }
}
