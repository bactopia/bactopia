{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/bactopia/bactopia/master/modules/fastani/schema.json",
    "title": "fastANI Module",
    "description": "A module for alignment-free computation Average Nucleotide Identity (ANI)",
    "type": "object",
    "$defs": {
        "fastani_parameters": {
            "title": "fastANI Parameters",
            "type": "object",
            "description": "",
            "default": "",
            "fa_icon": "fas fa-exclamation-circle",
            "properties": {
                "fastani_reference": {
                    "title": "Reference genome in FASTA format",
                    "type": "string",
                    "description": "Path to reference genome in FASTA format",
                    "fa_icon": "fas fa-file-alt",
                },
                "kmer": {
                    "type": "integer",
                    "default": 16,
                    "description": "kmer size (<= 16) for ANI calculation ",
                    "fa_icon": "fas fa-expand-arrows-alt"
                },
                "min_fraction": {
                    "type": "number",
                    "default": 0.2,
                    "description": "Minimum fraction of genome that must be shared for trusting ANI.",
                    "help": "If reference and query genome size differ, smaller one among the two is considered.",
                    "fa_icon": "fas fa-expand-arrows-alt"
                },
                "frag_len": {
                    "type": "integer",
                    "default": 3000,
                    "description": "fragment length",
                    "fa_icon": "fas fa-expand-arrows-alt"
                },
                "fastani_pairwise": {
                    "type": "boolean",
                    "default": false,
                    "description": "Conduct All-vs-All pairwise ANI calculations",
                    "fa_icon": "fas fa-expand-arrows-alt"
                }
            }
        }
    },
    "allOf": [
        {
            "$ref": "#/$defs/fastani_parameters"
        }
    ]
}
