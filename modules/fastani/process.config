/*
This file includes default process values for fastani.
*/

process {
    withName: 'FASTANI' {
        // Optional arguments
        ext.args = [
            "--kmer ${params.kmer}",
            "--fragLen ${params.frag_len}",
            "--minFraction ${params.min_fraction}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.env = [
            toolName: "bioconda::fastani=1.34".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/fastani:1.34--h4dfc31f_0",
            image: "https://depot.galaxyproject.org/singularity/fastani:1.34--h4dfc31f_0",
            condaDir: "${params.condadir}",
        ]

        ext.wf = params.wf
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "fastani"
    }
}
