/*
This file includes default process values for gtdbtk.
*/

process {
    withName: 'GTDBTK_DOWNLOAD' {
        publishDir = [[
            path: params.gtdb,
            mode: params.publish_dir_mode,
            overwrite: true
        ]]

        // Optional arguments
        ext.args = ""
        
        // Environment information
        ext.env = [
            toolName: "bioconda::gtdbtk=2.5.2".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/gtdbtk:2.5.2--pyh1f0d9b5_0",
            image: "https://depot.galaxyproject.org/singularity/gtdbtk:2.5.2--pyh1f0d9b5_0",
            condaDir: "${params.condadir}",
        ]
        
        ext.wf = params.wf
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "gtdbtk"
        ext.gtdb_save_as_tarball = params.gtdb_save_as_tarball
    }
}

