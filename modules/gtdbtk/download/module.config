// bactopia-lint: ignore MC009,JS003,JS004
params {
    // gtdbtk_download
    download_gtdb = false
    gtdb = null
    gtdb_save_as_tarball = false
}

process {
    withName: 'GTDBTK_DOWNLOAD' {
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "gtdbtk"
        publishDir = [[
            path: params.gtdb,
            mode: params.publish_dir_mode,
            overwrite: true
        ]]

        // Tool arguments
        ext.args = ""

        // Environment information
        ext.toolName = "bioconda::gtdbtk=2.7.1".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/gtdbtk:2.7.1--pyhdfd78af_0"
        ext.image = "https://depot.galaxyproject.org/singularity/gtdbtk:2.7.1--pyhdfd78af_0"
        ext.condaDir = "${params.condadir}"

        // Module-specific parameters
        ext.gtdb_save_as_tarball = params.gtdb_save_as_tarball
    }
}

