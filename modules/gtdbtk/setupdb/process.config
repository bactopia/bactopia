process {
    withName: 'GTDBTK_SETUPDB' {
        // Optional arguments
        ext.args = ""
        
        // Environment information
        ext.conda = "bioconda::gtdbtk=2.4.0"
        ext.singularity = "https://depot.galaxyproject.org/singularity/gtdbtk:2.4.0--pyhdfd78af_0"
        ext.docker = "quay.io/biocontainers/gtdbtk:2.4.0--pyhdfd78af_0"
        
        ext.prefix = { params.prefix ? params.prefix : "${params.wf == 'bactopia' ? meta.id : meta.name}" }
        ext.rundir = "${params.rundir}"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = params.is_workflow ? params.wf : params.process_name
        ext.gtdb_save_as_tarball = params.gtdb_save_as_tarball
    }
}
