/*
This file includes default process values for gtdbtk.
*/

process {
    withName: 'GTDBTK_CLASSIFYWF' {
        // Optional arguments
        ext.args = [
            "--min_af ${params.min_af}",
            "--min_perc_aa ${params.min_perc_aa}",
            "--tmpdir ${params.gtdb_tmp}",
            params.gtdb_use_scratch ? "--scratch_dir ${params.gtdb_tmp}" : "",
            params.gtdb_debug ? "--debug" : "",
            params.force_gtdb ? "--force" : ""
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.env = [
            toolName: "bioconda::gtdbtk=2.4.0".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/gtdbtk:2.4.0--pyhdfd78af_0",
            image: "https://depot.galaxyproject.org/singularity/gtdbtk:2.4.0--pyhdfd78af_0",
            condaDir: "${params.condadir}",
        ]
        
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "gtdbtk"
        ext.gtdb_keep_msa = params.gtdb_keep_msa
    }
}
