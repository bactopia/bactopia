process {
    withName: 'KLEBORATE' {
        // Optional arguments
        ext.args = {[
            "--preset ${params.kleborate_preset}",
            params.kleborate_opts
        ].join(' ').trim()}
        
        // Environment information
        ext.conda = "bioconda::kleborate=3.1.3"
        ext.singularity = "https://depot.galaxyproject.org/singularity/kleborate:3.1.3--pyhdfd78af_0"
        ext.docker = "quay.io/biocontainers/kleborate:3.1.3--pyhdfd78af_0"
        
        ext.prefix = { params.prefix ? params.prefix : "${params.wf == 'bactopia' ? meta.id : meta.name}" }
        ext.rundir = "${params.rundir}"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = params.is_workflow ? params.wf : params.process_name
    }
}
