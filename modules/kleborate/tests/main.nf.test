nextflow_process {
    name "Test KLEBORATE"
    script "../main.nf"
    process "KLEBORATE"
    tag "modules"
    tag "kleborate"

    test("kleborate - module - GCF_000009885") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_000009885"],
                        assembly: file("${params.test_data_dir}/data/species/klebsiella_pneumoniae/genome/GCF_000009885.fna.gz")
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.versions
                ).match() }
            )
        }
    }
}
