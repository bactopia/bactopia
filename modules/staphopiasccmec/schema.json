{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/bactopia/bactopia/master/modules/staphopiasccmec/schema.json",
    "title": "bactopia/staphopiasccmec module",
    "description": "Predicts SCCmec types for Staphylococcus aureus genomes",
    "type": "object",
    "$defs": {
        "staphopiasccmec_parameters": {
            "title": "Staphopia SCCmec Parameters",
