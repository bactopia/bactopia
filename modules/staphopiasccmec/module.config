params {
    // Staphopia SCCmec
    staphopia_hamming = false
}

process {
    withName: 'STAPHOPIASCCMEC' {
        // Optional arguments
        ext.args = params.staphopia_hamming ? "--hamming" : ""

        // Environment information
        ext.toolName = "bioconda::staphopia-sccmec=1.0.0".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/staphopia-sccmec:1.0.0--hdfd78af_0"
        ext.image = "https://depot.galaxyproject.org/singularity/staphopia-sccmec:1.0.0--hdfd78af_0"
        ext.condaDir = "${params.condadir}"

        // Additional parameters
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "staphopiasccmec"
    }
}
