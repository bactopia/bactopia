nextflow_process {
    name "Test ABRICATE_SUMMARY"
    script "../main.nf"
    process "ABRICATE_SUMMARY"
    tag "modules"
    tag "abricate"
    tag "abricate_summary"

    test("abricate summary - module - multiple reports") {

        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                // Create inline Abricate report files for testing
                def report1 = file("\${workDir}/sample1.txt")
                report1.text = [
                    "#FILE\tSEQUENCE\tSTART\tEND\tSTRAND\tGENE\tCOVERAGE\tCOVERAGE_MAP\tGAPS\t%COVERAGE\t%IDENTITY\tDATABASE\tACCESSION\tPRODUCT\tRESISTANCE",
                    "sample1.fna\tcontig1\t1\t100\t+\tblaTEM-1\t1-100/100\t===============\t0/0\t100.00\t99.50\tncbi\tNG_050145.1\tTEM-1\tAMPICILLIN"
                ].join("\\n")

                def report2 = file("\${workDir}/sample2.txt")
                report2.text = [
                    "#FILE\tSEQUENCE\tSTART\tEND\tSTRAND\tGENE\tCOVERAGE\tCOVERAGE_MAP\tGAPS\t%COVERAGE\t%IDENTITY\tDATABASE\tACCESSION\tPRODUCT\tRESISTANCE",
                    "sample2.fna\tcontig1\t200\t500\t+\tmecA\t1-300/300\t===============\t0/0\t100.00\t98.75\tncbi\tNG_047937.1\tPBP2a\tMETHICILLIN"
                ].join("\\n")

                input[0] = Channel.of(
                    record(
                        meta: [name: "abricate-ncbi"],
                        reports: [report1, report2]
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.report,
                    record.versions
                ).match() }
            )
        }
    }
}
