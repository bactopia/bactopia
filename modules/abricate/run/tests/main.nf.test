nextflow_process {
    name "Test ABRICATE_RUN"
    script "../main.nf"
    process "ABRICATE_RUN"

    test("abricate - module - GCF_000292685") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_000292685"],
                        assembly: file("${params.test_data_dir}/data/species/portiera/genome/GCF_000292685.fna.gz")
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.report,
                    record.results,
                    record.versions
                ).match() }
            )
        }
    }
}
