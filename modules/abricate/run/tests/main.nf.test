nextflow_process {
    name "Test ABRICATE_RUN"
    script "../main.nf"
    process "ABRICATE_RUN"
    tag "modules"
    tag "abricate"
    tag "abricate_run"

    test("abricate_run - module - SRR2838702") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "SRR2838702"],
                        fna: file("${params.test_data_dir}/species/portiera/compressed/SRR2838702/main/assembler/SRR2838702.fna.gz")
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.report,
                    record.versions
                ).match() }
            )
        }
    }
}
