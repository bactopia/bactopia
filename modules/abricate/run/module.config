/*
This file includes default configuration values for abricate_run.
*/

params {
    // Abricate
    abricate_db = "ncbi"
    minid = 80
    mincov = 80
    run_name = "${params.wf}-${params.abricate_db}"
}

process {
    withName: 'ABRICATE_RUN' {
        // Optional arguments
        ext.args = [
            "--db ${params.abricate_db}",
            "--minid ${params.minid}",
            "--mincov ${params.mincov}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.env = [
            tool: "bioconda::abricate=1.0.1".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/abricate:1.0.1--ha8f3691_1",
            image: "https://depot.galaxyproject.org/singularity/abricate:1.0.1--ha8f3691_1",
            conda: "${params.condadir}/${ext.env.tool}",
        ]
    }
}
