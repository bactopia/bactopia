params {
    // abricate_run
    abricate_db = "ncbi"
    abricate_mincov = 80
    abricate_minid = 80
    run_name = "${params.workflow.name}-${params.abricate_db}"
}

process {
    withName: 'ABRICATE_RUN' {
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = params.abricate_db
        ext.logs_subdir = ""
        ext.process_name = "abricate"

        // Tool arguments
        ext.args = [
            "--db ${params.abricate_db}",
            "--minid ${params.abricate_minid}",
            "--mincov ${params.abricate_mincov}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::abricate=1.4.0".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/abricate:1.4.0--h05cac1d_0"
        ext.image = "https://depot.galaxyproject.org/singularity/abricate:1.4.0--h05cac1d_0"
        ext.condaDir = "${params.condadir}"
    }
}
