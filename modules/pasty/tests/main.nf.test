nextflow_process {
    name "Test PASTY"
    script "../main.nf"
    process "PASTY"

    test("pasty - module - GCF_000006765") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_000006765"],
                        assembly: file("${params.test_data_dir}/data/species/pseudomonas_aeruginosa/genome/GCF_000006765.fna.gz")
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.blast,
                    record.details,
                    record.versions
                ).match() }
            )
        }
    }
}
