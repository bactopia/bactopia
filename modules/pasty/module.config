/*
Bactopia Module Configuration

Defines parameter defaults, the container images, resource labels, and other settings
for the process defined in this directory.
*/

params {
    // pasty
    pasty_min_pident = 95
    pasty_min_coverage = 95
}

process {
    withName: 'PASTY' {
        // Optional arguments
        ext.args = [
            "--min-pident ${params.pasty_min_pident}",
            "--min-coverage ${params.pasty_min_coverage}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.toolName = "bioconda::pasty=2.2.1".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/pasty:2.2.1--hdfd78af_0"
        ext.image = "https://depot.galaxyproject.org/singularity/pasty:2.2.1--hdfd78af_0"
        ext.condaDir = "${params.condadir}"
        
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "pasty"
    }
}
