/*
This file includes default process values for pasty.
*/

process {
    withName: 'PASTY' {
        // Optional arguments
        ext.args = [
            "--min_pident ${params.pasty_min_pident}",
            "--min_coverage ${params.pasty_min_coverage}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()
        
        // Environment information
        ext.env = [
            toolName: "bioconda::pasty=2.2.1".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/pasty:2.2.1--hdfd78af_0",
            image: "https://depot.galaxyproject.org/singularity/pasty:2.2.1--hdfd78af_0",
            condaDir: "${params.condadir}",
        ]
        
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "pasty"
    }
}
