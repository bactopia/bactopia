{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/bactopia/bactopia/master/modules/pasty/schema.json",
    "title": "pasty Module",
    "description": "A module for in silico serogrouping of Pseudomonas aeruginosa isolates",
    "type": "object",
    "$defs": {
        "pasty_parameters": {
            "title": "pasty Parameters",
            "type": "object",
            "description": "",
            "default": "",
            "fa_icon": "fas fa-exclamation-circle",
            "properties": {
                "pasty_min_pident": {
                    "type": "integer",
                    "default": 95,
                    "description": "Minimum percent identity to count a hit",
                    "fa_icon": "fas fa-hashtag"
                },
                "pasty_min_coverage": {
                    "type": "integer",
                    "default": 95,
                    "description": "Minimum percent coverage to count a hit",
                    "fa_icon": "fas fa-hashtag"
                }
            }
        }
    },
    "allOf": [
        {
            "$ref": "#/$defs/pasty_parameters"
        }
    ]
}
