nextflow_process {
    name "Test MASHTREE"
    script "../main.nf"
    process "MASHTREE"
    tag "modules"
    tag "mashtree"

    test("mashtree - module - multiple genomes") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [id: "mashtree-test", name: "mashtree-test"],
                        seqs: [
                            file("${params.test_data_dir}/data/species/klebsiella_pneumoniae/genome/GCF_000009885.fna.gz"),
                            file("${params.test_data_dir}/data/species/staphylococcus_aureus/genome/GCF_000017085.fna.gz"),
                            file("${params.test_data_dir}/data/species/portiera/genome/GCF_000292685.fna.gz")
                        ]
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tree,
                    record.tsv,
                    record.versions
                ).match() }
            )
        }
    }
}
