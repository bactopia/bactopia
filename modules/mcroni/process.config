/*
This file includes default process values for mcroni.
*/

process {
    withName: 'MCRONI' {
        // Optional arguments
        ext.args = ""
        
        // Environment information
        ext.env = [
            toolName: "bioconda::mcroni=1.0.4".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/mcroni:1.0.4--pyh5e36f6f_0",
            image: "https://depot.galaxyproject.org/singularity/mcroni:1.0.4--pyh5e36f6f_0",
            condaDir: "${params.condadir}",
        ]
        
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "mcroni"
    }
}
