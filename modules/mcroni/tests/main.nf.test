nextflow_process {
    name "Test MCRONI"
    script "../main.nf"
    process "MCRONI"
    tag "modules"
    tag "mcroni"

    test("mcroni - module - GCF_001682305 - uncompressed") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_001682305"],
                        fna: file("${params.test_data_dir}/species/escherichia_coli_mcr1/uncompressed/GCF_001682305/main/assembler/GCF_001682305.fna")
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.fa,
                    record.versions
                ).match() }
            )
        }
    }

    test("mcroni - module - GCF_001682305 - compressed") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_001682305"],
                        fna: file("${params.test_data_dir}/species/escherichia_coli_mcr1/compressed/GCF_001682305/main/assembler/GCF_001682305.fna.gz")
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.fa,
                    record.versions
                ).match() }
            )
        }
    }
}
