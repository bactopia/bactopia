nextflow_process {
    name "Test SKETCHER"
    script "../main.nf"
    process "SKETCHER"
    tag "modules"
    tag "bactopia"
    tag "bactopia_sketcher"

    test("sketcher - module - SRR2838702") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "SRR2838702"],
                        fna: file("${params.test_data_dir}/species/portiera/compressed/SRR2838702/main/assembler/SRR2838702.fna.gz")
                    )
                )
                input[1] = file("${params.test_data_dir}/datasets/sketcher/mash-refseq88.k21.msh.xz")
                input[2] = file("${params.test_data_dir}/datasets/sketcher/gtdb-rs207.genomic-reps.dna.k31.lca.json.gz")
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert record.sig != null },
                { assert record.mash != null },
                { assert record.sourmash != null },
                { assert snapshot(
                    record.meta,
                    record.mash,
                    record.sourmash,
                    record.versions
                ).match() }
            )
        }
    }
}
