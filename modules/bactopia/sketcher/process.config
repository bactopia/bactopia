/*
This file includes default process values for sketcher.
*/

process {
    withName: 'SKETCHER' {
        // Optional arguments
        ext.args = [
            params.sketch_size ? "--sketch-size ${params.sketch_size}" : ""
        ].join(' ')
        
        ext.args2 = [
            params.sourmash_scale ? "--scaled ${params.sourmash_scale}" : ""
        ].join(' ')
        
        ext.args3 = [
            params.no_winner_take_all ? "--no-winner-take-all" : "",
            params.screen_i ? "-i ${params.screen_i}" : ""
        ].join(' ')

        // Environment information
        ext.env = [
            toolName: "bioconda::bactopia-sketcher=1.0.1".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/bactopia-sketcher:1.0.1--hdfd78af_0",
            image: "https://depot.galaxyproject.org/singularity/bactopia-sketcher:1.0.1--hdfd78af_0",
            condaDir: "${params.condadir}",
        ]

        ext.prefix = { "" }
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "sketcher"
    }
}
