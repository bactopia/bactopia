/*
This file includes default process values for qc.
*/

process {
    withName: 'QC' {
        // Optional arguments
        ext.args = [
            params.disable_adapter_trimming ? "--disable_adapter_trimming" : "",
            params.use_fastp_adapter_fasta ? "--adapter_fasta ${params.use_fastp_adapter_fasta}" : "",
            params.fastp_opts ? params.fastp_opts : ""
        ].join(' ')

        // Environment information
        ext.env = [
            toolName: "bioconda::bactopia-qc=1.0.3".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "quay.io/biocontainers/bactopia-qc:1.0.3--hdfd78af_0",
            image: "https://depot.galaxyproject.org/singularity/bactopia-qc:1.0.3--hdfd78af_0",
            condaDir: "${params.condadir}",
        ]

        ext.prefix = { "" }
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "qc"
    }
}
