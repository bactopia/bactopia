nextflow_process {
    name "Test ASSEMBLER"
    script "../main.nf"
    process "ASSEMBLER"
    tag "modules"
    tag "bactopia"
    tag "bactopia_assembler"

    test("assembler - module - paired-end") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        meta: [name: "output", runtype: "paired-end", single_end: false, genome_size: 350000, species: "Portiera aleyrodidarum"],
                        r1: file("${params.test_data_dir}/species/portiera/reads/illumina/SRR2838702_R1.fastq.gz"),
                        r2: file("${params.test_data_dir}/species/portiera/reads/illumina/SRR2838702_R2.fastq.gz"),
                        se: file("${params.test_data_dir}/empty/EMPTYSE.fastq.gz"),
                        lr: file("${params.test_data_dir}/empty/EMPTY.fastq.gz"),
                        fna: null
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert record.fna != null },
                { assert record.tsv != null },
                { assert snapshot(
                    record.meta,
                    record.versions
                ).match() }
            )
        }
    }

