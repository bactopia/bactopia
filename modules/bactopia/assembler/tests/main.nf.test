                        r2: file("${params.test_data_dir}/empty/EMPTY_R2.fastq.gz"),
                        se: file("${params.test_data_dir}/species/portiera/reads/illumina/SRR2838702SE.fastq.gz"),
                        lr: file("${params.test_data_dir}/empty/EMPTY.fastq.gz"),
