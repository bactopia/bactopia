    test("assembler - module - paired-end - megahit") {
        // Note: megahit produces 0 contigs from this small test dataset,
        // so this tests the assembly-error handling path
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
                shovill_assembler = "megahit"
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        meta: [name: "output", runtype: "paired-end", single_end: false, genome_size: 350000, species: "Portiera aleyrodidarum"],
