nextflow_process {
    name "Test GATHER"
    script "../main.nf"
    process "GATHER"
    tag "modules"
    tag "bactopia"
    tag "bactopia_gather"

    test("gather - module - paired-end") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        meta: [name: "output", runtype: "paired-end", genome_size: 350000, species: "Portiera aleyrodidarum"],
                        r1_files: [file("${params.test_data_dir}/species/portiera/reads/illumina/SRR2838702_R1.fastq.gz")] as Set,
                        r2_files: [file("${params.test_data_dir}/species/portiera/reads/illumina/SRR2838702_R2.fastq.gz")] as Set,
                        se_files: [] as Set,
                        lr_files: [] as Set,
                        fna_files: [] as Set
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert record.r1 != null },
                { assert record.r2 != null },
                { assert record.tsv != null },
                { assert snapshot(
                    record.meta,
                    record.tsv,
                    record.versions
                ).match() }
            )
        }
    }

