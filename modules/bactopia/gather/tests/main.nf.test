                        fna_files: [] as Set
                    )
                )
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert record.r1 == null },
                { assert record.r2 == null },
                { assert record.tsv != null },
                { assert snapshot(
                    record.meta,
                    record.versions
                ).match() }
            )
        }
    }

