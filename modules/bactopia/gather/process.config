/*
This file includes default process values for gather.
*/

process {
    withName: 'GATHER' {
        // Optional arguments
        ext.args = ""

        // Environment information
        ext.env = [
            toolName: "bioconda::bactopia-gather=1.0.4".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/bactopia-gather:1.0.4--hdfd78af_0",
            image: "https://depot.galaxyproject.org/singularity/bactopia-gather:1.0.4--hdfd78af_0",
            condaDir: "${params.condadir}",
        ]

        ext.prefix = { "" }
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "gather"
    }
}
