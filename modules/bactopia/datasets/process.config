/*
This file includes default process values for datasets.
*/

process {
    withName: 'DATASETS' {
        storeDir = params.datasets_cache
        publishDir = params.datasets_cache

        // Optional arguments
        ext.args = ""

        // Environment information
        ext.env = [
            toolName: "bioconda::gnu-wget=1.18".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "quay.io/biocontainers/gnu-wget:1.18--h36e9172_9",
            image: "https://depot.galaxyproject.org/singularity/gnu-wget:1.18--h36e9172_9",
            condaDir: "${params.condadir}",
        ]

        ext.wf = params.wf
        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "datasets"

        // WF specific parameters
        ext.amrfinder_url = params.amrfinder_url
        ext.mash_url = params.mash_url
        ext.mlst_url = params.mlst_url
        ext.sourmash_url = params.sourmash_url
    }
}
