/*
This file includes default process values for datasets.
*/

process {
    withName: 'DATASETS' {
        storeDir = params.datasets_cache

        // Optional arguments
        ext.args = ""

        // Environment information
        ext.toolName = "bioconda::gnu-wget=1.18".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/gnu-wget:1.18--h36e9172_9"
        ext.image = "https://depot.galaxyproject.org/singularity/gnu-wget:1.18--h36e9172_9"
        ext.condaDir = "${params.condadir}"

        ext.wf = params.wf
        ext.scope = "run"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "datasets"

        // WF specific parameters
        ext.amrfinder_url = params.amrfinder_url
        ext.mash_url = params.mash_url
        ext.mlst_url = params.mlst_url
        ext.sourmash_url = params.sourmash_url
    }
}
