/*
This file includes default process values for datasets.
*/

process {
    withName: 'DATASETS' {
        // Optional arguments
        ext.args = ""

        // Environment information
        ext.env = [
            toolName: "bioconda::gnu-wget=1.18".replace("=", "-").replace(":", "-").replace(" ", "-"),
            docker: "biocontainers/gnu-wget:1.18--h60da905_7",
            image: "https://depot.galaxyproject.org/singularity/gnu-wget:1.18--h60da905_7",
            condaDir: "${params.condadir}",
        ]

        ext.rundir = params.rundir
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "datasets"
    }
}
