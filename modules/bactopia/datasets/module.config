params {
    // No parameters
}

process {
    withName: 'DATASETS' {
        ext.wf = params.wf
        ext.scope = "run"
        ext.subdir = ""
        ext.logs_subdir = ""
        ext.process_name = "datasets"
        storeDir = params.datasets_cache

        // Tool arguments
        ext.args = ""

        // Environment information
        ext.toolName = "bioconda::gnu-wget=1.18".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/gnu-wget:1.18--hb829ee6_10"
        ext.image = "https://depot.galaxyproject.org/singularity/gnu-wget:1.18--hb829ee6_10"
        ext.condaDir = "${params.condadir}"

        // Module-specific parameters
        ext.amrfinder_url = params.amrfinderplus_url
        ext.mash_url = params.mash_url
        ext.mlst_url = params.mlst_url
        ext.sourmash_url = params.sourmash_url
    }
}
