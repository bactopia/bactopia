nextflow_process {
    name "Test MASH_DIST"
    script "../main.nf"
    process "MASH_DIST"

    test("mash dist - module - portiera vs refseq sketch") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            process {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "mashdist-test"],
                        query: [
                            file("${params.test_data_dir}/data/species/portiera/genome/GCF_000292685.fna.gz")
                        ]
                    )
                )
                input[1] = file("${params.test_data_dir}/data/datasets/variants/refseq-genomes.msh")
                """
            }
        }

        then {
            def record = process.out[0][0]
            assertAll(
                { assert process.success },
                { assert snapshot(
                    record.meta,
                    record.dist,
                    record.versions
                ).match() }
            )
        }
    }
}
