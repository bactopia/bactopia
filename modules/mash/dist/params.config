/*
This file includes default parameter values for mashdist.
*/

params {
    // Mash (dist)
    mash_sketch = null
    mash_seed = 42
    mash_table = false
    mash_m = 1
    mash_w = 0.01
    mash_max_p = 1.0
    mash_max_dist = 1.0 // report all
    merlin_dist = 0.10 // report only close matches
    mash_use_fastqs = false
    full_merlin = false
}
