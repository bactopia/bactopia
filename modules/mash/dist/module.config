params {
    // mash_dist
    //mash_sketch = null // TODO: Remove when Path? is fixed
    full_merlin = false         // bactopia-lint: ignore MC009,JS003,JS004
    mash_m = 1
    mash_max_dist = 1.0         // report all
    mash_max_p = 1.0
    mash_seed = 42
    mash_table = false
    mash_use_fastqs = false
    mash_w = 0.01
    merlin_dist = 0.10          // bactopia-lint: ignore MC009,JS003,JS004
}

process {
    withName: 'MASH_DIST' {
        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = params.run_name
        ext.logs_subdir = ""
        ext.logs_use_prefix = true
        ext.process_name = "mashdist"

        // Tool arguments
        ext.args = [
            "-v ${params.mash_max_p}",
            params.ask_merlin || params.wf == "merlin" ? "-d ${params.merlin_dist}" : "-d ${params.mash_max_dist}",
            "-w ${params.mash_w}",
            "-m ${params.mash_m}",
            "-S ${params.mash_seed}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::mash=2.3".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/mash:2.3--hb105d93_10"
        ext.image = "https://depot.galaxyproject.org/singularity/mash:2.3--hb105d93_10"
        ext.condaDir = "${params.condadir}"

        // Module-specific parameters
        ext.full_merlin = params.full_merlin
    }
}
