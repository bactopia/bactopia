/*
This file includes default process values for mashdist.
*/

process {
    withName: 'MASH_DIST|MERLIN_DIST' {
        // Optional arguments
        ext.args = [
            "-v ${params.mash_max_p}",
            params.ask_merlin || params.wf == "merlin" ? "-d ${params.merlin_dist}" : "-d ${params.mash_max_dist}",
            "-w ${params.mash_w}",
            "-m ${params.mash_m}",
            "-S ${params.mash_seed}"
        ].join(' ').replaceAll("\\s{2,}", " ").trim()

        // Environment information
        ext.toolName = "bioconda::mash=2.3".replace("=", "-").replace(":", "-").replace(" ", "-")
        ext.docker = "biocontainers/mash:2.3--he348c14_1"
        ext.image = "https://depot.galaxyproject.org/singularity/mash:2.3--he348c14_1"
        ext.condaDir = "${params.condadir}"

        ext.wf = params.wf
        ext.scope = "sample"
        ext.subdir = params.run_name
        ext.logs_subdir = ""
        ext.logs_use_prefix = true
        ext.process_name = "mashdist"
        
        // WF specific parameters
        ext.full_merlin = params.full_merlin
    }
}
