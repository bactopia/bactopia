nextflow_workflow {
    name "Test KRAKEN2 Subworkflow"
    script "../main.nf"
    workflow "KRAKEN2"
    tag "subworkflows"
    tag "kraken2"

    test("kraken2 - subworkflow - SRR2838702") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "SRR2838702"],
                        r1: file("${params.test_data_dir}/data/species/portiera/illumina/SRR2838702_R1.fastq.gz"),
                        r2: file("${params.test_data_dir}/data/species/portiera/illumina/SRR2838702_R2.fastq.gz"),
                        se: null,
                        lr: null
                    )
                )
                input[1] = file("${params.test_data_dir}/data/datasets/kraken2/k2_viral_20251015.tar.gz")
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert workflow.out.sample_outputs != null },
                { assert snapshot(
                    sample.meta,
                    sample.kraken2_report,
                    sample.versions
                ).match() },
                { assert sample.results != null }
            )
        }
    }
}
