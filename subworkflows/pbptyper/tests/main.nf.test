nextflow_workflow {
    name "Test PBPTYPER Subworkflow"
    script "../main.nf"
    workflow "PBPTYPER"
    tag "subworkflows"
    tag "pbptyper"

    test("pbptyper - subworkflow - GCF_001457635") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_001457635"],
                        fna: file("${params.test_data_dir}/species/streptococcus_pneumoniae/assembly/GCF_001457635/main/assembler/GCF_001457635.fna.gz")
                    )
                )
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            def run = workflow.out.run_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert workflow.out.sample_outputs != null },
                { assert workflow.out.run_outputs != null },
                { assert snapshot(
                    sample.meta,
                    sample.tsv,
                    sample.blast,
                    sample.versions,
                    run.meta,
                    run.versions
                ).match() },
                { assert sample.results != null },
                { assert run.csv != null },
                { assert run.results != null }
            )
        }
    }
}
