nextflow_workflow {
    name "Test PANAROO Subworkflow"
    script "../main.nf"
    workflow "PANAROO"
    tag "subworkflows"
    tag "panaroo"

    test("panaroo - subworkflow - portiera") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "portiera-test"],
                        gff: [
                            file("${params.test_data_dir}/data/species/portiera/genome/gff/GCF_000292685.gff.gz"),
                            file("${params.test_data_dir}/data/species/portiera/genome/gff/GCF_000298385.gff.gz"),
                            file("${params.test_data_dir}/data/species/portiera/genome/gff/GCF_002849995.gff.gz"),
                            file("${params.test_data_dir}/data/species/portiera/genome/gff/GCF_000300075.gff.gz")
                        ]
                    )
                )
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert workflow.out.sample_outputs != null },
                { assert snapshot(
                    sample.meta,
                    sample.versions
                ).match() },
                { assert sample.results != null }
            )
        }
    }
}
