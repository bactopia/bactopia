nextflow_workflow {
    name "Test MLST Subworkflow"
    script "../main.nf"
    workflow "MLST"
    tag "subworkflows"
    tag "mlst"

    test("mlst - subworkflow - GCF_000017085") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_000017085"],
                        assembly: file("${params.test_data_dir}/data/species/staphylococcus_aureus/genome/GCF_000017085.fna.gz")
                    )
                )
                input[1] = file("${params.test_data_dir}/data/datasets/mlst/mlst.tar.gz")
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            def run = workflow.out.run_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    sample.meta,
                    sample.tsv,
                    sample.results,
                    sample.versions,
                    run.meta,
                    run.csv,
                    run.results,
                    run.versions
                ).match() }
            )
        }
    }
}
