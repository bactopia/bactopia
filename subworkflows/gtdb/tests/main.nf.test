nextflow_workflow {
    name "Test GTDB Subworkflow"
    script "../main.nf"
    workflow "GTDB"
    tag "subworkflows"
    tag "gtdb"

    test("gtdb - subworkflow - gtdbtk-test") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "gtdbtk-test"],
                        fna: [
                            file("${params.test_data_dir}/data/species/staphylococcus_aureus/genome/GCF_000017085.fna.gz"),
                            file("${params.test_data_dir}/data/species/portiera/genome/GCF_000292685.fna.gz")
                        ]
                    )
                )
                input[1] = file("${params.test_data_dir}/data/datasets/gtdbtk/db")
                input[2] = false
                input[3] = false
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            def run = workflow.out.run_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert workflow.out.sample_outputs != null },
                { assert workflow.out.run_outputs != null },
                { assert snapshot(
                    sample.meta,
                    sample.bac_tsv,
                    sample.versions,
                    run.meta,
                    run.versions
                ).match() },
                { assert sample.results != null },
                { assert run.csv != null },
                { assert run.results != null }
            )
        }
    }
}
