nextflow_workflow {
    name "Test SISTR Subworkflow"
    script "../main.nf"
    workflow "SISTR"
    tag "subworkflows"
    tag "sistr"

    test("sistr - subworkflow - GCF_016028495") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_016028495"],
                        assembly: file("${params.test_data_dir}/data/species/salmonella_enterica/genome/GCF_016028495.fna.gz")
                    )
                )
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            def run = workflow.out.run_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert workflow.out.sample_outputs != null },
                { assert workflow.out.run_outputs != null },
                { assert snapshot(
                    sample.meta,
                    sample.versions,
                    run.meta,
                    run.versions
                ).match() },
                { assert sample.tsv != null },
                { assert sample.results != null },
                { assert run.csv != null },
                { assert run.results != null }
            )
        }
    }
}
