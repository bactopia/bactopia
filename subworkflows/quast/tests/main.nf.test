nextflow_workflow {
    name "Test QUAST Subworkflow"
    script "../main.nf"
    workflow "QUAST"
    tag "subworkflows"
    tag "quast"

    test("quast - subworkflow - GCF_000292685") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_000292685"],
                        assembly: file("${params.test_data_dir}/data/species/portiera/genome/GCF_000292685.fna.gz"),
                        meta_file: file("${params.test_data_dir}/data/species/portiera/genome/GCF_000292685-meta.tsv")
                    )
                )
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            def run = workflow.out.run_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    sample.meta,
                    sample.tsv,
                    sample.results,
                    sample.versions,
                    run.meta,
                    run.csv,
                    run.results,
                    run.versions
                ).match() }
            )
        }
    }
}
