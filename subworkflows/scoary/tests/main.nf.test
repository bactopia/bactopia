nextflow_workflow {
    name "Test SCOARY Subworkflow"
    script "../main.nf"
    workflow "SCOARY"
    tag "subworkflows"
    tag "scoary"

    test("scoary - subworkflow - portiera") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "scoary"],
                        genes: file("${params.test_data_dir}/data/species/portiera/genome/gene_presence_absence.csv")
                    )
                )
                input[1] = file("${params.test_data_dir}/data/species/portiera/genome/gene_traits.csv")
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert workflow.out.sample_outputs != null },
                { assert snapshot(
                    sample.meta,
                    sample.versions
                ).match() },
                { assert sample.results != null }
            )
        }
    }
}
