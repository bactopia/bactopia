nextflow_workflow {
    name "Test SCOARY Subworkflow"
    script "../main.nf"
    workflow "SCOARY"
    tag "subworkflows"
    tag "scoary"

    test("scoary - subworkflow - portiera") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        meta: [name: "scoary"],
                        csv: file("${params.test_data_dir}/datasets/generic/genome/gene_presence_absence.csv")
                    )
                )
                input[1] = file("${params.test_data_dir}/datasets/generic/gene_traits.csv")
                """
            }
        }

        then {
            def run = workflow.out.run_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert workflow.out.run_outputs != null },
                { assert snapshot(
                    run.meta,
                    run.versions
                ).match() },
                { assert run.results != null }
            )
        }
    }
}
