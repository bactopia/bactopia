nextflow_workflow {
    name "Test BAKTA Subworkflow"
    script "../main.nf"
    workflow "BAKTA"
    tag "subworkflows"
    tag "bakta"

    test("bakta - subworkflow - GCF_000292685") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_000292685"],
                        assembly: file("${params.test_data_dir}/data/species/portiera/genome/GCF_000292685.fna.gz")
                    )
                )
                input[1] = file("${params.test_data_dir}/data/datasets/bakta/light/bakta-light.tar.gz")
                input[2] = false
                input[3] = false
                input[4] = file("${params.test_data_dir}/data/empty/EMPTY_PROTEINS")
                input[5] = file("${params.test_data_dir}/data/empty/EMPTY_PRODIGAL_TF")
                input[6] = file("${params.test_data_dir}/data/empty/EMPTY_REPLICONS")
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert workflow.out.sample_outputs != null },
                { assert snapshot(
                    sample.meta,
                    sample.tsv,
                    sample.txt,
                    sample.versions
                ).match() },
                { assert sample.results != null }
            )
        }
    }
}
