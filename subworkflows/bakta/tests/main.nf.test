nextflow_workflow {
    name "Test BAKTA Subworkflow"
    script "../main.nf"
    workflow "BAKTA"
    tag "subworkflows"
    tag "bakta"

    test("bakta - subworkflow - SRR2838702") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        meta: [name: "SRR2838702"],
                        fna: file("${params.test_data_dir}/species/portiera/compressed/SRR2838702/main/assembler/SRR2838702.fna.gz")
                    )
                )
                input[1] = file("${params.test_data_dir}/datasets/bakta/light/bakta-light.tar.gz")
                input[2] = false
                input[3] = false
                input[4] = null
                input[5] = null
                input[6] = null
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert workflow.out.sample_outputs != null },
                { assert snapshot(
                    sample.meta,
                    sample.tsv,
                    sample.txt,
                    sample.versions
                ).match() },
                { assert sample.results != null }
            )
        }
    }
}
