nextflow_workflow {
    name "Test HICAP Subworkflow"
    script "../main.nf"
    workflow "HICAP"
    tag "subworkflows"
    tag "hicap"

    test("hicap - subworkflow - GCF_900478275") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_900478275"],
                        assembly: file("${params.test_data_dir}/data/species/haemophilus_influenzae/genome/GCF_900478275.fna.gz")
                    )
                )
                input[1] = null
                input[2] = null
                """
            }
        }

        then {
            def sample_outputs = workflow.out.sample_outputs[0]
            def run_outputs = workflow.out.run_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    sample_outputs.meta,
                    sample_outputs.results,
                    sample_outputs.versions,
                    run_outputs.meta,
                    run_outputs.results,
                    run_outputs.versions
                ).match() }
            )
        }
    }
}
