nextflow_workflow {
    name "Test MASHDIST Subworkflow"
    script "../main.nf"
    workflow "MASHDIST"
    tag "subworkflows"
    tag "mashdist"

    test("mashdist - subworkflow - SRR2838702") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "mashdist-test"],
                        fna: file("${params.test_data_dir}/species/portiera/compressed/SRR2838702/main/assembler/SRR2838702.fna.gz")
                    )
                )
                input[1] = file("${params.test_data_dir}/datasets/variants/refseq-genomes.msh")
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            def run = workflow.out.run_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert workflow.out.sample_outputs != null },
                { assert workflow.out.run_outputs != null },
                { assert snapshot(
                    sample.meta,
                    sample.dist,
                    sample.versions,
                    run.meta,
                    run.versions
                ).match() },
                { assert sample.results != null },
                { assert run.csv != null },
                { assert run.results != null }
            )
        }
    }
}
