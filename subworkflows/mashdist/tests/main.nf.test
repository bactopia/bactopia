nextflow_workflow {
    name "Test MASHDIST Subworkflow"
    script "../main.nf"
    workflow "MASHDIST"
    tag "subworkflows"
    tag "mashdist"

    test("mashdist - subworkflow - GCF_000292685") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "mashdist-test"],
                        query: [
                            file("${params.test_data_dir}/data/species/portiera/genome/GCF_000292685.fna.gz")
                        ]
                    )
                )
                input[1] = file("${params.test_data_dir}/data/datasets/variants/refseq-genomes.msh")
                """
            }
        }

        then {
            def sample_outputs = workflow.out.sample_outputs[0]
            def run_outputs = workflow.out.run_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    sample_outputs.meta,
                    sample_outputs.results,
                    sample_outputs.versions,
                    run_outputs.meta,
                    run_outputs.results,
                    run_outputs.versions
                ).match() }
            )
        }
    }
}
