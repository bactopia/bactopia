nextflow_workflow {
    name "Test DEFENSEFINDER Subworkflow"
    script "../main.nf"
    workflow "DEFENSEFINDER"
    tag "subworkflows"
    tag "defensefinder"

    test("defensefinder - subworkflow - GCF_000292685") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_000292685"],
                        proteins: file("${params.test_data_dir}/data/species/portiera/genome/GCF_000292685.fna.gz")
                    )
                )
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            def run = workflow.out.run_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert workflow.out.sample_outputs != null },
                { assert workflow.out.run_outputs != null },
                { assert snapshot(
                    sample.meta,
                    sample.versions,
                    run.meta,
                    run.versions
                ).match() },
                { assert sample.genes_tsv != null },
                { assert sample.hmmer_tsv != null },
                { assert sample.systems_tsv != null },
                { assert sample.results != null },
                { assert run.csv != null },
                { assert run.results != null }
            )
        }
    }
}
