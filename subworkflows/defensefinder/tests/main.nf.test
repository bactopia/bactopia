nextflow_workflow {
    name "Test DEFENSEFINDER Subworkflow"
    script "../main.nf"
    workflow "DEFENSEFINDER"
    tag "subworkflows"
    tag "defensefinder"

    test("defensefinder - subworkflow - SRR2838702") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "SRR2838702"],
                        faa: file("${params.test_data_dir}/species/portiera/compressed/SRR2838702/main/assembler/SRR2838702.fna.gz")
                    )
                )
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert workflow.out.sample_outputs != null },
                { assert workflow.out.run_outputs != null },
                { assert workflow.out.run_outputs.size() == 3 },
                { assert snapshot(
                    sample.meta,
                    sample.versions
                ).match() },
                { assert sample.genes_tsv != null },
                { assert sample.hmmer_tsv != null },
                { assert sample.systems_tsv != null },
                { assert sample.results != null }
            )
        }
    }
}
