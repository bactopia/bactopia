nextflow_workflow {
    name "Test SNIPPY_CORE Subworkflow"
    script "../main.nf"
    workflow "SNIPPY_CORE"
    tag "subworkflows"
    tag "snippy"
    tag "snippy_core"

    test("snippy-core - subworkflow - test") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "snippy-core-test"],
                        _vcf: [
                            file("${params.test_data_dir}/data/datasets/snippy/test1.vcf.gz"),
                            file("${params.test_data_dir}/data/datasets/snippy/test2.vcf.gz"),
                            file("${params.test_data_dir}/data/datasets/snippy/test3.vcf.gz"),
                            file("${params.test_data_dir}/data/datasets/snippy/test4.vcf.gz"),
                            file("${params.test_data_dir}/data/datasets/snippy/test5.vcf.gz")
                        ],
                        _aligned_fa: [
                            file("${params.test_data_dir}/data/datasets/snippy/test1.aligned.fa.gz"),
                            file("${params.test_data_dir}/data/datasets/snippy/test2.aligned.fa.gz"),
                            file("${params.test_data_dir}/data/datasets/snippy/test3.aligned.fa.gz"),
                            file("${params.test_data_dir}/data/datasets/snippy/test4.aligned.fa.gz"),
                            file("${params.test_data_dir}/data/datasets/snippy/test5.aligned.fa.gz")
                        ]
                    )
                )
                input[1] = file("${params.test_data_dir}/data/species/portiera/genome/GCF_000292685.gbk.gz")
                input[2] = null
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            def snpdists = workflow.out.snpdists_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    sample.meta,
                    sample.results,
                    sample.versions,
                    snpdists.meta,
                    snpdists.tsv,
                    snpdists.results,
                    snpdists.versions
                ).match() }
            )
        }
    }
}
