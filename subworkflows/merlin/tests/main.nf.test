nextflow_workflow {
    name "Test MERLIN Subworkflow"
    script "../main.nf"
    workflow "MERLIN"
    tag "subworkflows"
    tag "merlin"

    test("merlin - subworkflow - GCF_000017085") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_000017085", runtype: "paired-end", single_end: false],
                        fna: file("${params.test_data_dir}/data/species/staphylococcus_aureus/genome/GCF_000017085.fna.gz"),
                        r1: file("${params.test_data_dir}/data/species/portiera/illumina/SRR2838702_R1.fastq.gz"),
                        r2: file("${params.test_data_dir}/data/species/portiera/illumina/SRR2838702_R2.fastq.gz"),
                        se: file("${params.test_data_dir}/data/empty/EMPTYSE.fastq.gz"),
                        lr: file("${params.test_data_dir}/data/empty/EMPTY.fastq.gz")
                    )
                )
                input[1] = file("${params.test_data_dir}/data/datasets/sketcher/mash-refseq88.k21.msh")
                input[2] = null
                input[3] = null
                input[4] = null
                input[5] = null
                input[6] = null
                """
            }
        }

        then {
            def dist = workflow.out.dist_outputs[0]
            def sample = workflow.out.sample_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    dist.meta,
                    dist.dist,
                    dist.results,
                    dist.versions,
                    sample.meta,
                    sample.results,
                    sample.versions
                ).match() }
            )
        }
    }
}
