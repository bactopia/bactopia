nextflow_workflow {
    name "Test PNEUMOCAT Subworkflow"
    script "../main.nf"
    workflow "PNEUMOCAT"
    tag "subworkflows"
    tag "pneumocat"

    test("pneumocat - subworkflow - ERR1438863") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "ERR1438863"],
                        r1: file("${params.test_data_dir}/species/streptococcus_pneumoniae/reads/ERR1438863/main/qc/ERR1438863_R1.fastq.gz"),
                        r2: file("${params.test_data_dir}/species/streptococcus_pneumoniae/reads/ERR1438863/main/qc/ERR1438863_R2.fastq.gz"),
                        se: file("${params.test_data_dir}/empty/EMPTYSE.fastq.gz"),
                        lr: file("${params.test_data_dir}/empty/EMPTY.fastq.gz")
                    )
                )
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert workflow.out.sample_outputs != null },
                { assert snapshot(
                    sample.meta,
                    sample.versions
                ).match() },
                { assert sample.results != null }
            )
        }
    }
}
