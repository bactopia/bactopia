nextflow_workflow {
    name "Test STECFINDER Subworkflow"
    script "../main.nf"
    workflow "STECFINDER"
    tag "subworkflows"
    tag "stecfinder"

    test("stecfinder - subworkflow - GCF_002949675") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_002949675"],
                        fna: file("${params.test_data_dir}/data/species/shigella_dysenteriae/genome/GCF_002949675.fna.gz"),
                        r1: file("${params.test_data_dir}/data/species/shigella_dysenteriae/illumina/ERR6005894_R1.fastq.gz"),
                        r2: file("${params.test_data_dir}/data/species/shigella_dysenteriae/illumina/ERR6005894_R2.fastq.gz"),
                        se: file("${params.test_data_dir}/data/empty/EMPTY.fastq.gz"),
                        lr: file("${params.test_data_dir}/data/empty/EMPTY.fastq.gz")
                    )
                )
                """
            }
        }

        then {
            def sample_outputs = workflow.out.sample_outputs[0]
            def run_outputs = workflow.out.run_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    sample_outputs.meta,
                    sample_outputs.results,
                    sample_outputs.versions,
                    run_outputs.meta,
                    run_outputs.results,
                    run_outputs.versions
                ).match() }
            )
        }
    }
}
