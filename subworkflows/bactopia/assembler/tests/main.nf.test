nextflow_workflow {
    name "Test ASSEMBLER Subworkflow"
    script "../main.nf"
    workflow "ASSEMBLER"
    tag "subworkflows"
    tag "bactopia"
    tag "bactopia_assembler"

    test("assembler - subworkflow - SRR2838702") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                // PE reads assembly test
                input[0] = Channel.of(
                    record(
                        meta: [name: "SRR2838702", runtype: "paired-end", single_end: false, genome_size: "358242", species: "Portiera aleyrodidarum"],
                        r1: file("${params.test_data_dir}/species/portiera/reads/illumina/SRR2838702_R1.fastq.gz"),
                        r2: file("${params.test_data_dir}/species/portiera/reads/illumina/SRR2838702_R2.fastq.gz"),
                        se: null,
                        lr: null,
                        fna: null
                    )
                )
                """
            }
        }

        then {
            def sample = workflow.out.assembly[0]
            def full_record = workflow.out.sample_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert workflow.out.assembly != null },
                { assert workflow.out.assembly_reads != null },
                { assert workflow.out.sample_outputs != null },
                { assert workflow.out.run_outputs != null },
                { assert sample.fna != null }
            )
        }
    }
}
