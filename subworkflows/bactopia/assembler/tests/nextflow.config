// Minimal config for subworkflow-level testing of ASSEMBLER
nextflow.preview.types = true
nextflow.enable.strict = true

params {
    workflow {
        name = "assembler"
        logo_name = "bactopia-tools"
        description = "Assemble bacterial genomes using short read, long read, or hybrid strategies"
        ext = "fna"
    }

    bactopia_version = '4.0.0'
    bactopia_cache = System.getenv("BACTOPIA_CACHEDIR") ?: "${System.getenv('HOME')}/.bactopia"
    condadir = "${params.bactopia_cache}/conda"
    wf = params.workflow.name
    merge_folder = "merged-results"
    test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
    is_ci = true

    // Max Job Request Parameters
    max_retry = 1
    max_time = 2.h
    max_memory = 8.GB
    max_cpus = 12

    // Nextflow Profile Parameters
    registry = "quay.io"
    singularity_cache = "${params.bactopia_cache}/singularity"
    singularity_pull_docker_container = false
    container_opts = ""

    // Module-specific defaults
    contig_namefmt = "contig%05d"
    dragonflye_assembler = "flye"
    dragonflye_opts = ""
    keep_all_files = false
    medaka_model = ""
    medaka_rounds = 1
    min_component_size = 1000
    min_contig_cov = 2
    min_contig_len = 500
    min_dead_end_size = 1000
    min_genome_size = 0
    max_genome_size = 18000000
    nanohq = false
    no_corr = false
    no_miniasm = false
    no_polish = false
    no_rotate = false
    no_stitch = false
    pilon_rounds = 0
    polypolish_rounds = 0
    racon_rounds = 1
    reassemble = false
    shovill_assembler = "skesa"
    shovill_kmers = ""
    shovill_opts = ""
    skip_compression = false
    unicycler_mode = "normal"
    use_unicycler = false
}

includeConfig "../../../../modules/bactopia/assembler/module.config"
includeConfig "../../../../modules/csvtk/concat/module.config"
includeConfig "../../../../conf/base.config"
includeConfig "../../../../conf/profiles.config"

plugins {
    id 'nf-bactopia@2.0.3'
}
