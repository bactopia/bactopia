nextflow_workflow {
    name "Test TBPROFILER Subworkflow"
    script "../main.nf"
    workflow "TBPROFILER"
    tag "subworkflows"
    tag "tbprofiler"

    test("tbprofiler - subworkflow - SRR2838702") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "SRR2838702"],
                        r1: file("${params.test_data_dir}/data/species/portiera/illumina/SRR2838702_R1.fastq.gz"),
                        r2: file("${params.test_data_dir}/data/species/portiera/illumina/SRR2838702_R2.fastq.gz"),
                        se: file("${params.test_data_dir}/data/empty/EMPTYSE.fastq.gz"),
                        lr: file("${params.test_data_dir}/data/empty/EMPTY.fastq.gz")
                    )
                )
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            def run = workflow.out.run_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    sample.meta,
                    sample.csv,
                    sample.json,
                    sample.txt,
                    sample.results,
                    sample.versions,
                    run.meta,
                    run.csv,
                    run.variants_csv,
                    run.variants_txt,
                    run.results,
                    run.versions
                ).match() }
            )
        }
    }
}
