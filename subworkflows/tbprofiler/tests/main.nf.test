nextflow_workflow {
    name "Test TBPROFILER Subworkflow"
    script "../main.nf"
    workflow "TBPROFILER"
    tag "subworkflows"
    tag "tbprofiler"

    test("tbprofiler - subworkflow - SRR2838702") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        meta: [name: "SRR2838702"],
                        r1: file("${params.test_data_dir}/species/portiera/reads/illumina/SRR2838702_R1.fastq.gz"),
                        r2: file("${params.test_data_dir}/species/portiera/reads/illumina/SRR2838702_R2.fastq.gz"),
                        se: file("${params.test_data_dir}/empty/EMPTYSE.fastq.gz"),
                        lr: file("${params.test_data_dir}/empty/EMPTY.fastq.gz")
                    )
                )
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            def run = workflow.out.run_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert workflow.out.sample_outputs != null },
                { assert workflow.out.run_outputs != null },
                { assert snapshot(
                    sample.meta,
                    sample.versions,
                    run.meta,
                    run.versions
                ).match() },
                { assert sample.csv != null },
                { assert sample.json != null },
                { assert sample.txt != null },
                { assert sample.results != null },
                { assert run.csv != null },
                { assert run.variants_csv != null },
                { assert run.variants_txt != null },
                { assert run.results != null }
            )
        }
    }
}
