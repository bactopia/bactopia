nextflow_workflow {
    name "Test SHIGATYPER Subworkflow"
    script "../main.nf"
    workflow "SHIGATYPER"
    tag "subworkflows"
    tag "shigatyper"

    test("shigatyper - subworkflow - ERR6005894") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "ERR6005894"],
                        r1: file("${params.test_data_dir}/data/species/shigella_dysenteriae/illumina/ERR6005894_R1.fastq.gz"),
                        r2: file("${params.test_data_dir}/data/species/shigella_dysenteriae/illumina/ERR6005894_R2.fastq.gz"),
                        se: file("${params.test_data_dir}/data/empty/EMPTY.fastq.gz"),
                        lr: file("${params.test_data_dir}/data/empty/EMPTY.fastq.gz")
                    )
                )
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            def run = workflow.out.run_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    sample.meta,
                    sample.tsv,
                    sample.results,
                    sample.versions,
                    run.meta,
                    run.csv,
                    run.results,
                    run.versions
                ).match() }
            )
        }
    }
}
