nextflow_workflow {
    name "Test CLONALFRAMEML Subworkflow"
    script "../main.nf"
    workflow "CLONALFRAMEML"
    tag "subworkflows"
    tag "clonalframeml"

    test("clonalframeml - subworkflow - portiera") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "portiera"],
                        alignment: file("${params.test_data_dir}/datasets/generic/genome/genome.aln.gz")
                    )
                )
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            def iqtree = workflow.out.iqtree_outputs[0]
            def snpdists = workflow.out.snpdists_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert workflow.out.sample_outputs != null },
                { assert workflow.out.iqtree_outputs != null },
                { assert workflow.out.snpdists_outputs != null },
                { assert snapshot(
                    sample.meta,
                    sample.em,
                    sample.status,
                    sample.newick,
                    sample.masked_aln,
                    sample.versions,
                    iqtree.meta,
                    iqtree.versions,
                    snpdists.meta,
                    snpdists.tsv,
                    snpdists.versions
                ).match() },
                { assert sample.results != null },
                { assert iqtree.results != null },
                { assert snpdists.results != null }
            )
        }
    }
}
