nextflow_workflow {
    name "Test TETON Subworkflow"
    script "../main.nf"
    workflow "TETON"
    tag "subworkflows"
    tag "teton"

    test("teton - subworkflow - SRR2838702") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "SRR2838702", runtype: "paired-end"],
                        r1: file("${params.test_data_dir}/species/portiera/reads/illumina/SRR2838702_R1.fastq.gz"),
                        r2: file("${params.test_data_dir}/species/portiera/reads/illumina/SRR2838702_R2.fastq.gz"),
                        se: null,
                        lr: null
                    )
                )
                input[1] = file("${params.test_data_dir}/datasets/kraken2/k2_standard_08_GB_20251015")
                input[2] = false
                input[3] = file("${params.test_data_dir}/datasets/nohuman/HPRC.r2")
                input[4] = false
                input[5] = false
                """
            }
        }

        then {
            def scrubber = workflow.out.scrubber_outputs[0]
            def bracken = workflow.out.bracken_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert workflow.out.scrubber_outputs != null },
                { assert workflow.out.bracken_outputs != null },
                { assert snapshot(
                    scrubber.meta,
                    scrubber.versions,
                    bracken.meta,
                    bracken.versions
                ).match() },
                { assert scrubber.results != null },
                { assert bracken.results != null }
            )
        }
    }
}
