nextflow_workflow {
    name "Test ARIBA Subworkflow"
    script "../main.nf"
    workflow "ARIBA"
    tag "subworkflows"
    tag "ariba"

    test("ariba - subworkflow - SRR2838702") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "SRR2838702"],
                        r1: file("${params.test_data_dir}/data/species/portiera/illumina/SRR2838702_R1.fastq.gz"),
                        r2: file("${params.test_data_dir}/data/species/portiera/illumina/SRR2838702_R2.fastq.gz"),
                        se: file("${params.test_data_dir}/data/empty/EMPTY.fastq.gz"),
                        lr: file("${params.test_data_dir}/data/empty/EMPTY.fastq.gz")
                    )
                )
                input[1] = "card"
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert workflow.out.sample_outputs != null },
                { assert workflow.out.run_outputs != null },
                { assert snapshot(
                    sample.meta,
                    sample.versions
                ).match() },
                { assert sample.report != null },
                { assert sample.summary != null },
                { assert sample.results != null }
            )
        }
    }
}
