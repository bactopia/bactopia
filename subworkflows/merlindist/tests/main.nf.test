nextflow_workflow {
    name "Test MERLINDIST Subworkflow"
    script "../main.nf"
    workflow "MERLINDIST"
    tag "subworkflows"
    tag "merlindist"

    test("merlindist - subworkflow - GCF_000017085") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_000017085"],
                        assembly: file("${params.test_data_dir}/data/species/staphylococcus_aureus/genome/GCF_000017085.fna.gz")
                    )
                )
                input[1] = file("${params.test_data_dir}/data/datasets/sketcher/mash-refseq88.k21.msh")
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    sample.meta,
                    sample.dist,
                    sample.results,
                    sample.versions
                ).match() }
            )
        }
    }
}
