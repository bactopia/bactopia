nextflow_workflow {
    name "Test NGMASTER Subworkflow"
    script "../main.nf"
    workflow "NGMASTER"
    tag "subworkflows"
    tag "ngmaster"

    test("ngmaster - subworkflow - GCF_001047255") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_001047255"],
                        assembly: file("${params.test_data_dir}/data/species/neisseria_gonorrhoeae/genome/GCF_001047255.fna.gz")
                    )
                )
                """
            }
        }

        then {
            def sample_outputs = workflow.out.sample_outputs[0]
            def run_outputs = workflow.out.run_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    sample_outputs.meta,
                    sample_outputs.results,
                    sample_outputs.versions,
                    run_outputs.meta,
                    run_outputs.results,
                    run_outputs.versions
                ).match() }
            )
        }
    }
}
