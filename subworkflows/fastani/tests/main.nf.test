nextflow_workflow {
    name "Test FASTANI Subworkflow"
    script "../main.nf"
    workflow "FASTANI"
    tag "subworkflows"
    tag "fastani"

    test("fastani - subworkflow - haemophilus") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        meta: [name: "fastani-test"],
                        fna: file("${params.test_data_dir}/species/haemophilus_influenzae/compressed/GCF_900478275/main/assembler/GCF_900478275.fna.gz")
                    )
                )
                input[1] = Channel.of(
                    record(
                        meta: [name: "fastani-ref"],
                        fna: file("${params.test_data_dir}/species/haemophilus_influenzae/compressed/GCA_000027305/main/assembler/GCA_000027305.fna.gz")
                    )
                )
                """
            }
        }

        then {
            def runs = workflow.out.run_outputs
            def fastani = runs.find { it.meta.process_name == 'fastani' }
            def concat = runs.find { it.meta.process_name == 'fastani-concat' }
            assertAll(
                { assert workflow.success },
                { assert workflow.out.run_outputs != null },
                { assert snapshot(
                    fastani.meta,
                    fastani.tsv,
                    fastani.versions,
                    concat.meta,
                    concat.versions
                ).match() },
                { assert fastani.results != null },
                { assert concat.csv != null },
                { assert concat.results != null }
            )
        }
    }
}
