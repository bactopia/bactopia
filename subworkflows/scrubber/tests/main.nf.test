nextflow_workflow {
    name "Test SCRUBBER Subworkflow"
    script "../main.nf"
    workflow "SCRUBBER"
    tag "subworkflows"
    tag "scrubber"

    test("scrubber - subworkflow - SRR2838702") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    tuple(
                        [name: "SRR2838702", runtype: "paired-end"],
                        file("${params.test_data_dir}/data/species/portiera/illumina/SRR2838702_R1.fastq.gz"),
                        file("${params.test_data_dir}/data/species/portiera/illumina/SRR2838702_R2.fastq.gz"),
                        null,
                        null
                    )
                )
                input[1] = false
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            def run = workflow.out.run_outputs[0]
            assertAll(
                { assert workflow.success },
                // Verify named fields from the k2scrubber module record
                { assert sample.kraken2_report != null },
                { assert sample.scrub_report != null },
                // Verify scrubbed reads channel was populated
                { assert workflow.out.scrubbed.size() > 0 },
                // Verify special_tsv channel was populated
                { assert workflow.out.special_tsv.size() > 0 },
                { assert snapshot(
                    sample.meta,
                    sample.results,
                    sample.versions,
                    run.meta,
                    run.results,
                    run.versions
                ).match() }
            )
        }
    }
}
