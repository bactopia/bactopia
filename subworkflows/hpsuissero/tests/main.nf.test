nextflow_workflow {
    name "Test HPSUISSERO Subworkflow"
    script "../main.nf"
    workflow "HPSUISSERO"
    tag "subworkflows"
    tag "hpsuissero"

    test("hpsuissero - subworkflow - GCF_002777395") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_002777395"],
                        assembly: file("${params.test_data_dir}/data/species/glaesserella_parasuis/genome/GCF_002777395.fna.gz")
                    )
                )
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            def run = workflow.out.run_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    sample.meta,
                    sample.tsv,
                    sample.results,
                    sample.versions,
                    run.meta,
                    run.csv,
                    run.results,
                    run.versions
                ).match() }
            )
        }
    }
}
