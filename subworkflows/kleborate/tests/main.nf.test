nextflow_workflow {
    name "Test KLEBORATE Subworkflow"
    script "../main.nf"
    workflow "KLEBORATE"
    tag "subworkflows"
    tag "kleborate"

    test("kleborate - subworkflow - GCF_000009885") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        meta: [name: "GCF_000009885"],
                        fna: file("${params.test_data_dir}/species/klebsiella_pneumoniae/GCF_000009885/main/assembler/GCF_000009885.fna.gz")
                    )
                )
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            def run = workflow.out.run_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert workflow.out.sample_outputs != null },
                { assert workflow.out.run_outputs != null },
                { assert snapshot(
                    sample.meta,
                    sample.versions,
                    run.meta,
                    run.versions
                ).match() },
                { assert sample.tsv != null },
                { assert sample.results != null },
                { assert run.csv != null },
                { assert run.results != null }
            )
        }
    }
}
