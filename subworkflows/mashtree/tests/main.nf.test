nextflow_workflow {
    name "Test MASHTREE Subworkflow"
    script "../main.nf"
    workflow "MASHTREE"
    tag "subworkflows"
    tag "mashtree"

    test("mashtree - subworkflow - multi-species") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "mashtree-test"],
                        assembly: [
                            file("${params.test_data_dir}/species/klebsiella_pneumoniae/GCF_000009885/main/assembler/GCF_000009885.fna.gz"),
                            file("${params.test_data_dir}/species/staphylococcus_aureus/compressed/GCF_000017085/main/assembler/GCF_000017085.fna.gz"),
                            file("${params.test_data_dir}/species/portiera/compressed/SRR2838702/main/assembler/SRR2838702.fna.gz")
                        ]
                    )
                )
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert workflow.out.sample_outputs != null },
                { assert snapshot(
                    sample.meta,
                    sample.versions
                ).match() },
                { assert sample.results != null }
            )
        }
    }
}
