nextflow_workflow {
    name "Test BTYPER3 Subworkflow"
    script "../main.nf"
    workflow "BTYPER3"
    tag "subworkflows"
    tag "btyper3"

    test("btyper3 - subworkflow - GCF_000008445") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_000008445"],
                        assembly: file("${params.test_data_dir}/data/species/bacillus_anthracis/genome/GCF_000008445.fna.gz")
                    )
                )
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            def run = workflow.out.run_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    sample.meta,
                    sample.tsv,
                    sample.results,
                    sample.versions,
                    run.meta,
                    run.csv,
                    run.results,
                    run.versions
                ).match() }
            )
        }
    }
}
