nextflow_workflow {
    name "Test SNPDISTS Subworkflow"
    script "../main.nf"
    workflow "SNPDISTS"
    tag "subworkflows"
    tag "snpdists"

    test("snpdists - subworkflow - portiera") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "portiera"],
                        _msa: [file("${params.test_data_dir}/data/species/portiera/genome/genome.aln.gz")] as Set
                    )
                )
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert workflow.out.sample_outputs != null },
                { assert snapshot(
                    sample.meta,
                    sample.tsv,
                    sample.versions
                ).match() },
                { assert sample.results != null }
            )
        }
    }
}
