nextflow_workflow {
    name "Test GUBBINS Subworkflow"
    script "../main.nf"
    workflow "GUBBINS"
    tag "subworkflows"
    tag "gubbins"

    test("gubbins - subworkflow - portiera") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "portiera"],
                        aln: file("${params.test_data_dir}/datasets/generic/genome/genome.aln.gz")
                    )
                )
                """
            }
        }

        then {
            def runs = workflow.out.run_outputs
            def gubbins = runs.find { it.meta.process_name == 'gubbins' }
            def snpdists = runs.find { it.meta.process_name == 'snpdists-masked' }
            assertAll(
                { assert workflow.success },
                { assert workflow.out.run_outputs != null },
                { assert snapshot(
                    gubbins.meta,
                    gubbins.masked_aln,
                    gubbins.versions,
                    snpdists.meta,
                    snpdists.tsv,
                    snpdists.versions
                ).match() },
                { assert gubbins.results != null },
                { assert snpdists.results != null }
            )
        }
    }
}
