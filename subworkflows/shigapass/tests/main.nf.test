nextflow_workflow {
    name "Test SHIGAPASS Subworkflow"
    script "../main.nf"
    workflow "SHIGAPASS"
    tag "subworkflows"
    tag "shigapass"

    test("shigapass - subworkflow - GCF_016726285") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_016726285"],
                        fna: file("${params.test_data_dir}/species/shigella_boydii/compressed/GCF_016726285/main/assembler/GCF_016726285.fna.gz")
                    )
                )
                """
            }
        }

        then {
            def sample = workflow.out.sample_outputs[0]
            def run = workflow.out.run_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert workflow.out.sample_outputs != null },
                { assert workflow.out.run_outputs != null },
                { assert snapshot(
                    sample.meta,
                    sample.tsv,
                    sample.flex_tsv,
                    sample.versions,
                    run.meta,
                    run.versions
                ).match() },
                { assert sample.results != null },
                { assert run.csv != null },
                { assert run.results != null }
            )
        }
    }
}
