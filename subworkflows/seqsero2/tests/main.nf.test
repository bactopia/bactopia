nextflow_workflow {
    name "Test SEQSERO2 Subworkflow"
    script "../main.nf"
    workflow "SEQSERO2"
    tag "subworkflows"
    tag "seqsero2"

    test("seqsero2 - subworkflow - GCF_016028495") {
        when {
            params {
                test_data_dir = System.getenv("BACTOPIA_TESTS") ?: ""
            }
            workflow {
                """
                input[0] = Channel.of(
                    record(
                        _meta: [name: "GCF_016028495"],
                        assembly: file("${params.test_data_dir}/data/species/salmonella_enterica/genome/GCF_016028495.fna.gz")
                    )
                )
                """
            }
        }

        then {
            def sample_outputs = workflow.out.sample_outputs[0]
            def run_outputs = workflow.out.run_outputs[0]
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    sample_outputs.meta,
                    sample_outputs.results,
                    sample_outputs.versions,
                    run_outputs.meta,
                    run_outputs.results,
                    run_outputs.versions
                ).match() }
            )
        }
    }
}
