// Test data to be used by Bactopia tests
// Modeled after nf-core/modules setup

params {
    // Test-only parameter defaults (overridden by nf-test when { params {} })
    bactopia_test = null
    test_dataset = null
    test_dataset2 = null
    test_dataset3 = null
    test_r1 = null
    test_r2 = null
    test_se = null
    test_ont = null
    gamma_test = null
    nohuman_test = null

    is_ci = true
    max_retry = 1
    condadir = System.getenv("BACTOPIA_CONDA")
    singularity_pull_docker_container = true
    test_data_dir = System.getenv("BACTOPIA_TESTS")
    bactopia = params.bactopia_test ? "${params.test_data_dir}/${params.bactopia_test}" : null

    // General inputs
    r1 = params.test_r1 ? "${params.test_data_dir}/${params.test_r1}" : null
    r2 = params.test_r2 ? "${params.test_data_dir}/${params.test_r2}" : null
    se = params.test_se ? "${params.test_data_dir}/${params.test_se}" : null
    ont = params.test_ont ? "${params.test_data_dir}/${params.test_ont}" : null

    // Database inputs
    amrfinderplus_db = params.test_dataset ? "${params.test_data_dir}/${params.test_dataset}" : null
    ariba_db = params.test_dataset
    bakta_db = "${params.test_data_dir}/${params.test_dataset}"
    blastn_query = "${params.test_data_dir}/${params.test_dataset}"
    blastp_query = "${params.test_data_dir}/${params.test_dataset}"
    blastx_query = "${params.test_data_dir}/${params.test_dataset}"
    checkm2_db = "${params.test_data_dir}/${params.test_dataset}"
    eggnog_db = "${params.test_data_dir}/${params.test_dataset}"
    emmtyper_blastdb = params.test_dataset ? "${params.test_data_dir}/${params.test_dataset}" : null
    fastani_reference = params.test_dataset ? "${params.test_data_dir}/${params.test_dataset}" : null
    gamma_db = params.gamma_test ? "${params.test_data_dir}/${params.gamma_test}" : "${params.test_data_dir}/${params.test_dataset}"
    gtdb = "${params.test_data_dir}/${params.test_dataset}"
    insertions = "${params.test_data_dir}/${params.test_dataset}"
    kraken2_db = params.test_dataset ? "${params.test_data_dir}/${params.test_dataset}" : null
    mash_sketch = "${params.test_data_dir}/${params.test_dataset}"
    midas_db = "${params.test_data_dir}/${params.test_dataset}"
    mlst_db = params.test_dataset ? "${params.test_data_dir}/${params.test_dataset}" : null
    mykrobe_species = params.test_dataset2
    nohuman_db = params.nohuman_test ? "${params.test_data_dir}/${params.nohuman_test}" : null
    reference = "${params.test_data_dir}/${params.test_dataset2}"
    scoary_traits = params.test_dataset ? "${params.test_data_dir}/${params.test_dataset}" : null
    snippy_core_mask = params.test_dataset ? "${params.test_data_dir}/${params.test_dataset}" : null
    sylph_db = "${params.test_data_dir}/${params.test_dataset}"
    tblastn_query = "${params.test_data_dir}/${params.test_dataset}"
    tblastx_query = "${params.test_data_dir}/${params.test_dataset}"
    traitar_db = "${params.test_data_dir}/${params.test_dataset}"

    // Static data inputs
    prokka_proteins = "${params.test_data_dir}/datasets/generic/proteins.faa"

    // Nullable database inputs (tools use built-in defaults when null)
    hicap_database_dir = null
    hicap_model_fp = null
}
