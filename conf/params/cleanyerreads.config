/*
This file includes default values for shared parameters.
*/

params {
    // Max Job Request Parameters
    max_time = 4.h

    // Parameters to ignore
    empty_r1 = "${projectDir}/../../data/empty/EMPTY_R1"
    empty_r2 = "${projectDir}/../../data/empty/EMPTY_R2"
    empty_se = "${projectDir}/../../data/empty/EMPTY_SE"
    empty_ont = "${projectDir}/../../data/empty/EMPTY_ONT"
    empty_extra = "${projectDir}/../../data/empty/EMPTY_EXTRA"
    empty_proteins = "${projectDir}/../../data/empty/EMPTY_PROTEINS"
    empty_tf = "${projectDir}/../../data/empty/EMPTY_TF"
    empty_adapters = "${projectDir}/../../data/empty/EMPTY_ADAPTERS"
    empty_phix = "${projectDir}/../../data/empty/EMPTY_PHIX"

    // Optional Parameters
    coverage = 0
    genome_size = "1"

    //  Gather Samples Parameters
    enable_fastq_check = false
    skip_fastq_check = params.enable_fastq_check ? false : true

    // QC Reads
    enable_error_correction = false
    skip_error_correction = params.enable_fastq_check ? false : true

    // Params to ignore
    schema_ignore_params = "${params.schema_ignore_params},bactopia,kraken2_db,use_bakta,skip_scrubber,skip_fastq_check,skip_error_correction,ask_merlin,species,datasets,reassemble,assembly,short_polish,hybrid,available_datasets"
}
