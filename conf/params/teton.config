/*
This file includes default values for shared parameters.
*/

params {
    // Parameters to ignore
    empty_r1 = "${projectDir}/../../data/empty/EMPTY_R1"
    empty_r2 = "${projectDir}/../../data/empty/EMPTY_R2"
    empty_extra = "${projectDir}/../../data/empty/EMPTY_EXTRA"
    empty_proteins = "${projectDir}/../../data/empty/EMPTY_PROTEINS"
    empty_tf = "${projectDir}/../../data/empty/EMPTY_TF"
    empty_adapters = "${projectDir}/../../data/empty/EMPTY_ADAPTERS"
    empty_phix = "${projectDir}/../../data/empty/EMPTY_PHIX"

    // Optional Parameters
    coverage = 0
    genome_size = "1"
    sampleseed = 42

    // Kraken2 Parameters
    keep_filtered_reads = true

    // Bracken Parameters
    kraken2_keep_raw_output = false

    // scrubber Parameters
    skip_scrubber = false

    // Params to ignore
    schema_ignore_params = "${params.schema_ignore_params},bactopia,use_bakta,sampleseed,skip_scrubber,skip_fastq_check,ask_merlin,species,datasets,reassemble,assembly,short_polish,hybrid,available_datasets,use_k2scrubber"
}
