process {
    // Defaults
    container     = "bactopia/bactopia:${params.bactopia_version}"
    errorStrategy = 'retry'
    maxRetries    = params.max_retry

    // Resolve container image based on engine
    // Module configs set ext.docker (Docker Hub) and ext.image (Galaxy depot .sif)
    // This closure picks the right one at task time
    withName: '.*' {
        ext.container = { ->
            (workflow.containerEngine == 'singularity' && !params.singularity_pull_docker_container)
                ? task.ext.image
                : task.ext.docker
        }
    }

    // Resource Limits
    resourceLimits = [ 
        cpus: params.max_cpus,
        memory: params.max_memory,
        time: params.max_time
    ]

    // Resources
    cpus   = { 1    }
    memory = { 4.GB }
    time   = { 1.h  }

    // Modules imported from nf-core
    withLabel: process_single {
        cpus   = { 1                    }
        memory = { 4.GB  * task.attempt }
        time   = { 2.h   * task.attempt }
    }
    withLabel: process_low {
        cpus   = { 4                    }
        memory = { 8.GB  * task.attempt }
        time   = { 4.h   * task.attempt }
    }
    withLabel: process_medium {
        cpus   = { 8                    }
        memory = { 32.GB * task.attempt }
        time   = { 12.h  * task.attempt }
    }
    withLabel: process_high {
        cpus   = { 12                   }
        memory = { 64.GB * task.attempt }
        time   = { 24.h  * task.attempt }
    }
    withLabel: process_long {
        time   = { 96.h  * task.attempt }
    }
    withLabel: process_high_memory {
        memory = { 128.GB * task.attempt }
    }
    withLabel: error_ignore {
        errorStrategy = 'ignore'
    }
    withLabel: error_retry {
        errorStrategy = 'retry'
        maxRetries    = 2
    }
}
