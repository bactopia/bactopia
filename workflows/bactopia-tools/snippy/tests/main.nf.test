nextflow_pipeline {
    name "Test Snippy Workflow"
    script "../main.nf"
    config "../../../../conf/test.config"
    tag "workflows"
    tag "bactopia-tools"
    tag "snippy"

    test("Snippy - Mixed|compressed_fastq") {
        when {
            params {
                bactopia_test = "/species/mixed/reads"
                test_dataset = ""
                test_dataset2 = "/datasets/generic/GCF_000292685.gbk"
                test_dataset3 = ""
                test_r1 = ""
                test_r2 = ""
                test_se = ""
                test_ont = ""
                is_ci = true
                outdir = "$outputDir"
                gubbins_min_window_size = 5000
                snippy_mincov = 1
                snippy_minqual = 1
                snippy_basequal = 1
                snippy_mapqual = 1
                snippy_maxsoft = 1
            }
        }

        then {
            // stable_name: All files + folders in ${params.outdir}/ with a stable name
            def stable_name = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: [])
            // stable_path: All files in ${params.outdir}/ with stable content
            def stable_path = getAllFilesFromDir(params.outdir, ignoreFile: '.nftignore')
            assertAll(
                { assert workflow.success},
                { assert snapshot(
                    // Number of successful tasks
                    workflow.trace.succeeded().size(),
                    // All stable path name, with a relative path
                    stable_name,
                    // All files with stable contents
                    stable_path
                ).match() }
            )
        }
    }

    test("Snippy (mask) - Mixed|compressed_fastq") {
        when {
            params {
                bactopia_test = "/species/mixed/reads"
                test_dataset = "/datasets/generic/GCF_000292685.bed"
                test_dataset2 = "/datasets/generic/GCF_000292685.gbk"
                test_dataset3 = ""
                test_r1 = ""
                test_r2 = ""
                test_se = ""
                test_ont = ""
                is_ci = true
                outdir = "$outputDir"
                gubbins_min_window_size = 5000
                snippy_mincov = 1
                snippy_minqual = 1
                snippy_basequal = 1
                snippy_mapqual = 1
                snippy_maxsoft = 1
            }
        }

        then {
            // stable_name: All files + folders in ${params.outdir}/ with a stable name
            def stable_name = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: [])
            // stable_path: All files in ${params.outdir}/ with stable content
            def stable_path = getAllFilesFromDir(params.outdir, ignoreFile: '.nftignore')
            assertAll(
                { assert workflow.success},
                { assert snapshot(
                    // Number of successful tasks
                    workflow.trace.succeeded().size(),
                    // All stable path name, with a relative path
                    stable_name,
                    // All files with stable contents
                    stable_path
                ).match() }
            )
        }
    }
}
