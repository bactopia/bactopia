nextflow_pipeline {
    name "Test Kraken2 Workflow"
    script "../main.nf"
    config "../../../../conf/test.config"
    tag "kraken2"
    tag "bactopia-tools"

    test("Kraken2 - SRR2838702|portiera|compressed_fastq") {
        when {
            params {
                bactopia_test = "/species/portiera/compressed"
                test_dataset = "/datasets/kraken2/"
                test_dataset2 = ""
                is_ci = true
                outdir = "$outputDir"
            }
        }

        then {
            // stable_name: All files + folders in ${params.outdir}/ with a stable name
            def stable_name = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: [])
            // stable_path: All files in ${params.outdir}/ with stable content
            def stable_path = getAllFilesFromDir(params.outdir, ignoreFile: '.nftignore')
            assertAll(
                { assert workflow.success},
                { assert snapshot(
                    // Number of successful tasks
                    workflow.trace.succeeded().size(),
                    // All stable path name, with a relative path
                    stable_name,
                    // All files with stable contents
                    stable_path
                ).match() }
            )
        }
    }

    test("Kraken2 (tarball) - SRR2838702|portiera|compressed_fastq") {
        when {
            params {
                bactopia_test = "/species/portiera/compressed"
                test_dataset = "/datasets/kraken2/kraken2.tar.gz"
                test_dataset2 = ""
                is_ci = true
                outdir = "$outputDir"
            }
        }

        then {
            // stable_name: All files + folders in ${params.outdir}/ with a stable name
            def stable_name = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: [])
            // stable_path: All files in ${params.outdir}/ with stable content
            def stable_path = getAllFilesFromDir(params.outdir, ignoreFile: '.nftignore')
            assertAll(
                { assert workflow.success},
                { assert snapshot(
                    // Number of successful tasks
                    workflow.trace.succeeded().size(),
                    // All stable path name, with a relative path
                    stable_name,
                    // All files with stable contents
                    stable_path
                ).match() }
            )
        }
    }
}
