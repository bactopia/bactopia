nextflow_pipeline {
    name "Test tblastx Workflow"
    script "../main.nf"
    config "../../../../conf/test.config"
    tag "workflows"
    tag "bactopia-tools"
    tag "tblastx"

    test("tblastx (single-gene.ffn.gz) - SRR2838702|portiera|blastdb") {
        when {
            params {
                bactopia_test = "/species/portiera/compressed"
                test_dataset = "datasets/blast/single-gene.ffn.gz"
                test_dataset2 = ""
                test_dataset3 = ""
                test_r1 = ""
                test_r2 = ""
                test_se = ""
                test_ont = ""
                is_ci = true
                outdir = "$outputDir"
            }
        }

        then {
            // stable_name: All files + folders in ${params.outdir}/ with a stable name
            def stable_name = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: [])
            // stable_path: All files in ${params.outdir}/ with stable content
            def stable_path = getAllFilesFromDir(params.outdir, ignoreFile: '.nftignore')
            assertAll(
                { assert workflow.success},
                { assert snapshot(
                    // Number of successful tasks
                    workflow.trace.succeeded().size(),
                    // All stable path name, with a relative path
                    stable_name,
                    // All files with stable contents
                    stable_path
                ).match() }
            )
        }
    }

    test("tblastx (single-gene.ffn.gz|--tblastx_use_genes) - SRR2838702|portiera|blastdb") {
        when {
            params {
                bactopia_test = "/species/portiera/compressed"
                test_dataset = "datasets/blast/single-gene.ffn.gz"
                tblastx_use_genes = true
                test_dataset2 = ""
                test_dataset3 = ""
                test_r1 = ""
                test_r2 = ""
                test_se = ""
                test_ont = ""
                is_ci = true
                outdir = "$outputDir"
            }
        }

        then {
            // stable_name: All files + folders in ${params.outdir}/ with a stable name
            def stable_name = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: [])
            // stable_path: All files in ${params.outdir}/ with stable content
            def stable_path = getAllFilesFromDir(params.outdir, ignoreFile: '.nftignore')
            assertAll(
                { assert workflow.success},
                { assert snapshot(
                    // Number of successful tasks
                    workflow.trace.succeeded().size(),
                    // All stable path name, with a relative path
                    stable_name,
                    // All files with stable contents
                    stable_path
                ).match() }
            )
        }
    }

    test("tblastx (single-gene.ffn) - SRR2838702|portiera|blastdb") {
        when {
            params {
                bactopia_test = "/species/portiera/compressed"
                test_dataset = "datasets/blast/single-gene.ffn"
                test_dataset2 = ""
                test_dataset3 = ""
                test_r1 = ""
                test_r2 = ""
                test_se = ""
                test_ont = ""
                is_ci = true
                outdir = "$outputDir"
            }
        }

        then {
            // stable_name: All files + folders in ${params.outdir}/ with a stable name
            def stable_name = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: [])
            // stable_path: All files in ${params.outdir}/ with stable content
            def stable_path = getAllFilesFromDir(params.outdir, ignoreFile: '.nftignore')
            assertAll(
                { assert workflow.success},
                { assert snapshot(
                    // Number of successful tasks
                    workflow.trace.succeeded().size(),
                    // All stable path name, with a relative path
                    stable_name,
                    // All files with stable contents
                    stable_path
                ).match() }
            )
        }
    }
}
